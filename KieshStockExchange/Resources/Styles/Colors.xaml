<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<!-- Colors.xaml - THEME-INDEPENDENT keys only.
     The full palette (Primary, surfaces, text, BuyGreen, ChartBg, Gray*, ...)
     lives in Resources/Styles/Themes/Theme.*.xaml and is merged at slot 0.
     This file only carries:
       - ChartPriceLine* : default fallbacks consumed by ChartView.xaml.cs
         via TryGetColor when a theme does not override them. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Chart price-line accents - themes can override later. -->
    <Color x:Key="ChartPriceLineUp">#26A69A</Color>
    <Color x:Key="ChartPriceLineDown">#EF5350</Color>

    <!-- Moving-average overlay palette. Five distinct hues so the user can stack
         several MAs without colour collisions. Themes can override individually. -->
    <Color x:Key="ChartMaColor1">#3B82F6</Color>  <!-- blue -->
    <Color x:Key="ChartMaColor2">#F59E0B</Color>  <!-- amber -->
    <Color x:Key="ChartMaColor3">#A855F7</Color>  <!-- purple -->
    <Color x:Key="ChartMaColor4">#06B6D4</Color>  <!-- cyan -->
    <Color x:Key="ChartMaColor5">#FACC15</Color>  <!-- yellow -->

    <!-- Price-marker line accent. Drawn for user-placed horizontal markers. -->
    <Color x:Key="ChartMarker">#EAB308</Color>

    <!-- §F2: fired-trigger firing-point arrow. Blue so it reads distinctly from the green/red
         fill triangles and the amber armed-trigger line. -->
    <Color x:Key="ChartTrigger">#3B82F6</Color>

    <!-- Open-position average-entry line. Teal so it reads distinctly from the green/red order
         lines and the blue trigger arrows; the attached P&L tag paints green/red by profit/loss. -->
    <Color x:Key="ChartPositionLine">#26C6DA</Color>

</ResourceDictionary>
