<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<!-- Colors.xaml - THEME-INDEPENDENT keys only.
     The full palette (Primary, surfaces, text, BuyGreen, ChartBg, Gray*, ...)
     lives in Resources/Styles/Themes/Theme.*.xaml and is merged at slot 0.
     This file only carries:
       - ChartPriceLine* : default fallbacks consumed by ChartView.xaml.cs
         via TryGetColor when a theme does not override them. -->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Chart price-line accents - themes can override later. -->
    <Color x:Key="ChartPriceLineUp">#26A69A</Color>
    <Color x:Key="ChartPriceLineDown">#EF5350</Color>

</ResourceDictionary>
