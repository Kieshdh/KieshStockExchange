<?xml version="1.0" encoding="utf-8" ?>
<!-- OrderBookStyles.xaml - DOM ladder and shared trade-table styles.
     (OpenOrders, OrderHistory, TransactionHistory, Positions tables)
     All colors come from the active theme dictionary. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels">

    <!-- ============================================================
         ORDER BOOK - DOM LADDER
         ============================================================ -->

    <Style x:Key="OrderBookHeaderLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{DynamicResource TextMuted}" />
        <Setter Property="FontFamily"              Value="OpenSansSemibold" />
        <Setter Property="FontSize"                Value="11" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <Style x:Key="OrderBookAskPriceLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{DynamicResource SellRed}" />
        <Setter Property="FontFamily"              Value="OpenSansSemibold" />
        <Setter Property="FontSize"                Value="12" />
        <Setter Property="HorizontalOptions"       Value="Start" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <Style x:Key="OrderBookBidPriceLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{DynamicResource BuyGreen}" />
        <Setter Property="FontFamily"              Value="OpenSansSemibold" />
        <Setter Property="FontSize"                Value="12" />
        <Setter Property="HorizontalOptions"       Value="Start" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <Style x:Key="OrderBookQuantityLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize"                Value="12" />
        <Setter Property="HorizontalOptions"       Value="End" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <Style x:Key="OrderBookSpreadRow" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="Padding"         Value="6,4" />
        <Setter Property="ColumnSpacing"   Value="6" />
    </Style>

    <Style x:Key="OrderBookEmptyMessageLabel" TargetType="Label">
        <Setter Property="TextColor"         Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize"          Value="13" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions"   Value="Center" />
    </Style>

    <Style x:Key="OrderBookDepthBar.Sell" TargetType="Border">
        <Setter Property="BackgroundColor"   Value="{DynamicResource SellRed}" />
        <Setter Property="Stroke"            Value="Transparent" />
        <Setter Property="StrokeThickness"   Value="0" />
        <Setter Property="Opacity"           Value="0.18" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions"   Value="Fill" />
        <Setter Property="InputTransparent"  Value="True" />
    </Style>

    <Style x:Key="OrderBookDepthBar.Buy" TargetType="Border">
        <Setter Property="BackgroundColor"   Value="{DynamicResource BuyGreen}" />
        <Setter Property="Stroke"            Value="Transparent" />
        <Setter Property="StrokeThickness"   Value="0" />
        <Setter Property="Opacity"           Value="0.18" />
        <Setter Property="HorizontalOptions" Value="End" />
        <Setter Property="VerticalOptions"   Value="Fill" />
        <Setter Property="InputTransparent"  Value="True" />
    </Style>

    <!-- Best-level row: gets a tinted bg when IsBestLevel == True -->
    <Style x:Key="OrderBookBestLevelRow" TargetType="Border">
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="StrokeShape"     Value="Rectangle" />
        <Style.Triggers>
            <DataTrigger TargetType="Border" Value="True">
                <DataTrigger.Binding>
                    <Binding Path="IsBestLevel" x:DataType="vm:LevelRow" />
                </DataTrigger.Binding>
                <Setter Property="BackgroundColor" Value="{DynamicResource CardSurfaceMuted}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Trade-table styles (TradeTable* / TableSymbolNavGlyph / TableActionButton) now live in
         TradeStyles.xaml. WatchStarButton stays here as it's shared by the Market/Trade symbol bars. -->

    <!-- Star toggle on Market rows. Tight, borderless, sized so it doesn't
         visually compete with the Trade action button. Text and color are
         set by DataTriggers on IsWatched at the call site. -->
    <Style x:Key="WatchStarButton" TargetType="Button">
        <Setter Property="BackgroundColor"     Value="Transparent" />
        <Setter Property="BorderWidth"         Value="0" />
        <Setter Property="FontSize"            Value="16" />
        <Setter Property="Padding"             Value="0" />
        <Setter Property="WidthRequest"        Value="28" />
        <Setter Property="HeightRequest"       Value="28" />
        <Setter Property="HorizontalOptions"   Value="Center" />
        <Setter Property="VerticalOptions"     Value="Center" />
    </Style>

    <!-- ============================================================
         NEW DESIGN SYSTEM STYLES
         ============================================================ -->

    <!-- Framed order-book container (Border instead of bare Grid) -->
    <Style x:Key="OrderBookFrame" TargetType="Border">
        <Setter Property="BackgroundColor"   Value="{DynamicResource CardSurface}" />
        <Setter Property="Stroke"            Value="{DynamicResource Divider}" />
        <Setter Property="StrokeThickness"   Value="1" />
        <Setter Property="StrokeShape"       Value="RoundRectangle 8" />
        <Setter Property="Padding"           Value="0" />
    </Style>

    <!-- Column header row grid inside the order book -->
    <Style x:Key="OrderBookHeaderGrid" TargetType="Grid">
        <Setter Property="BackgroundColor"   Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="Padding"           Value="8,5" />
        <Setter Property="ColumnSpacing"     Value="4" />
    </Style>

    <!-- "Spread" caption label -->
    <Style x:Key="OrderBookSpreadKeyLabel" TargetType="Label">
        <Setter Property="FontSize"          Value="10" />
        <Setter Property="TextColor"         Value="{DynamicResource TextMuted}" />
    </Style>

    <!-- Spread value (the numeric gap) -->
    <Style x:Key="OrderBookSpreadValueLabel" TargetType="Label">
        <Setter Property="FontFamily"        Value="OpenSansSemibold" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="TextColor"         Value="{DynamicResource TextPrimary}" />
    </Style>

</ResourceDictionary>
