<?xml version="1.0" encoding="utf-8" ?>
<!-- SegmentedTabStyles.xaml - segmented pill control.
     All colors come from the active theme dictionary.
     Old inline color keys are removed; theme provides SegmentedPillBackground,
     SegmentedPillStroke, SelectedTabBg/Fg, UnselectedTabFg. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Outer pill container -->
    <Style x:Key="SegmentedPillContainerStyle" TargetType="Border">
        <Setter Property="Background"      Value="{DynamicResource SegmentedPillBackground}" />
        <Setter Property="Stroke"          Value="{DynamicResource SegmentedPillStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding"         Value="3" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Unselected tab button -->
    <Style x:Key="UnselectedSegmentButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource UnselectedTabFg}" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="Padding"         Value="14,8" />
        <Setter Property="CornerRadius"    Value="14" />
        <Setter Property="BorderColor"     Value="Transparent" />
        <Setter Property="BorderWidth"     Value="1" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Selected (raised, surface-colored) -->
    <Style x:Key="SelectedSegmentButtonStyle" TargetType="Button"
           BasedOn="{StaticResource UnselectedSegmentButtonStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource SelectedTabBg}" />
        <Setter Property="TextColor"       Value="{DynamicResource SelectedTabFg}" />
        <Setter Property="BorderColor"     Value="{DynamicResource Divider}" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{DynamicResource TextPrimaryBrush}" Radius="6" Opacity="0.08" Offset="0,1" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- BUY / SELL variants for the place-order toggle -->
    <Style x:Key="Seg_Selected_Buy" TargetType="Button"
           BasedOn="{StaticResource UnselectedSegmentButtonStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource BuyGreen}" />
        <Setter Property="TextColor"       Value="{DynamicResource White}" />
    </Style>

    <Style x:Key="Seg_Selected_Sell" TargetType="Button"
           BasedOn="{StaticResource UnselectedSegmentButtonStyle}">
        <Setter Property="BackgroundColor" Value="{DynamicResource SellRed}" />
        <Setter Property="TextColor"       Value="{DynamicResource White}" />
    </Style>

    <!-- ============================================================
         RAIL VARIANT - underline tabs (used by trade-tabs section)
         ============================================================ -->

    <!-- Transparent container, no border, no padding; the rail is just a
         row of bare tab buttons with optional underlines below. -->
    <Style x:Key="SegmentedRailContainer" TargetType="Border">
        <Setter Property="Background"      Value="Transparent" />
        <Setter Property="Stroke"          Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding"         Value="0" />
    </Style>

    <!-- Rail tab button - inactive state -->
    <Style x:Key="RailSegmentUnselected" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="Padding"         Value="12,10" />
        <Setter Property="CornerRadius"    Value="0" />
        <Setter Property="BorderColor"     Value="Transparent" />
        <Setter Property="BorderWidth"     Value="0" />
        <Setter Property="FontSize"        Value="13" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Rail tab button - active state (primary text; underline is painted
         on the BoxView the SegmentedTabView places under the button). -->
    <Style x:Key="RailSegmentSelected" TargetType="Button"
           BasedOn="{StaticResource RailSegmentUnselected}">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

</ResourceDictionary>
