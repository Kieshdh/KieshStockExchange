<?xml version="1.0" encoding="utf-8" ?>
<!-- TradeTableStyles.xaml - shared styles for the trade-page tables
     (OpenOrders / OrderHistory / TransactionHistory / Positions).
     All colors come from the active theme dictionary. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
            xmlns:models="clr-namespace:KieshStockExchange.Models;assembly=KieshStockExchange.Shared">

    <Style x:Key="TradeTableContainer" TargetType="VerticalStackLayout">
        <Setter Property="Spacing"  Value="8" />
        <Setter Property="Padding"  Value="12,8" />
    </Style>

    <!-- Grid host for the trade tables: header in the Auto row (fixed), the scrolling
         CollectionView in the * row. Tighter than the legacy VSL container so more rows fit
         and the content sits closer to the card's left edge. -->
    <Style x:Key="TradeTableContainerGrid" TargetType="Grid">
        <Setter Property="Padding"    Value="6,2" />
        <Setter Property="RowSpacing" Value="4" />
    </Style>

    <Style x:Key="TradeTableHeaderGrid" TargetType="Grid">
        <Setter Property="Padding"         Value="8,6" />
        <Setter Property="ColumnSpacing"   Value="4" />
        <Setter Property="BackgroundColor" Value="{DynamicResource CardSurfaceMuted}" />
    </Style>

    <Style x:Key="TradeTableHeaderLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontFamily"              Value="OpenSansSemibold" />
        <Setter Property="FontSize"                Value="11" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <Style x:Key="TradeTableRowGrid" TargetType="Grid">
        <Setter Property="Padding"         Value="8,2" />
        <Setter Property="ColumnSpacing"   Value="4" />
        <Setter Property="BackgroundColor" Value="{DynamicResource CardSurface}" />
    </Style>

    <Style x:Key="TradeTableRowLabel" TargetType="Label">
        <Setter Property="TextColor"               Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize"                Value="Small" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
    </Style>

    <Style x:Key="TradeTableSymbolLabel" TargetType="Label"
           BasedOn="{StaticResource TradeTableRowLabel}">
        <Setter Property="FontFamily"              Value="OpenSansSemibold" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <Style x:Key="TradeTableSideLabel" TargetType="Label"
           BasedOn="{StaticResource TradeTableRowLabel}">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Style.Triggers>
            <DataTrigger TargetType="Label" Value="True">
                <DataTrigger.Binding>
                    <Binding Path="IsBuyOrder" x:DataType="vm:ISideRow" />
                </DataTrigger.Binding>
                <Setter Property="TextColor" Value="{DynamicResource BuyGreen}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Value="True">
                <DataTrigger.Binding>
                    <Binding Path="IsSellOrder" x:DataType="vm:ISideRow" />
                </DataTrigger.Binding>
                <Setter Property="TextColor" Value="{DynamicResource SellRed}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- FundTransaction Kind column. Same green/red language as Side, but keyed
         on IsDeposit / IsWithdrawal so the binding works on FundTransaction
         directly (no IsBuyOrder/IsSellOrder available there). -->
    <Style x:Key="TradeTableKindLabel" TargetType="Label"
           BasedOn="{StaticResource TradeTableRowLabel}">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Style.Triggers>
            <DataTrigger TargetType="Label" Value="True">
                <DataTrigger.Binding>
                    <Binding Path="IsDeposit" x:DataType="models:FundTransaction" />
                </DataTrigger.Binding>
                <Setter Property="TextColor" Value="{DynamicResource BuyGreen}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Value="True">
                <DataTrigger.Binding>
                    <Binding Path="IsWithdrawal" x:DataType="models:FundTransaction" />
                </DataTrigger.Binding>
                <Setter Property="TextColor" Value="{DynamicResource SellRed}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Small icon-button for cancel / remove actions in a table row (✎ / ✕). -->
    <Style x:Key="TradeTableButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource SellRed}" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="FontSize"        Value="14" />
        <Setter Property="Padding"         Value="0" />
        <Setter Property="WidthRequest"    Value="22" />
        <Setter Property="HeightRequest"   Value="22" />
        <Setter Property="CornerRadius"    Value="11" />
        <Setter Property="BorderWidth"     Value="0" />
    </Style>

    <!-- ↗ glyph next to a table row's symbol — jumps the trade page to that stock. A Label (with a
         TapGestureRecognizer at the call site), NOT a Button: a WinUI Button keeps a ~32px template
         MinHeight that HeightRequest can't shrink, which inflated every row. A Label has no floor. -->
    <Style x:Key="TableSymbolNavGlyph" TargetType="Label">
        <Setter Property="Text"                  Value="↗" />
        <Setter Property="TextColor"             Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="FontSize"              Value="13" />
        <Setter Property="Padding"               Value="2,0" />
        <Setter Property="VerticalOptions"       Value="Center" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
    </Style>

    <!-- Outlined action button inside table rows (e.g. "Cancel", "View") -->
    <Style x:Key="TableActionButton" TargetType="Button">
        <Setter Property="BackgroundColor"     Value="Transparent" />
        <Setter Property="TextColor"           Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="FontSize"            Value="12" />
        <Setter Property="Padding"             Value="8,2" />
        <Setter Property="MinimumWidthRequest" Value="60" />
        <Setter Property="HeightRequest"       Value="28" />
        <Setter Property="CornerRadius"        Value="14" />
        <Setter Property="BorderColor"         Value="{DynamicResource Primary}" />
        <Setter Property="BorderWidth"         Value="1" />
    </Style>

</ResourceDictionary>
