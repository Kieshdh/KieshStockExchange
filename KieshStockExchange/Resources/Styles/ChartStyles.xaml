<?xml version="1.0" encoding="utf-8" ?>
<!-- ChartStyles.xaml - chart canvas, toolbar, interval pills, indicator chips,
     OHLC overlay, axis labels. All chart palette keys come from the active theme. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================
         LEGACY STYLES - kept so existing ChartView continues to compile.
         ============================================================ -->

    <Style x:Key="ChartSurface" TargetType="GraphicsView">
        <Setter Property="BackgroundColor"   Value="{DynamicResource ChartBg}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions"   Value="Fill" />
    </Style>

    <Style x:Key="ChartToolbar" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{DynamicResource ChartPanel}" />
        <Setter Property="Padding"         Value="4,1" />
        <Setter Property="ColumnSpacing"   Value="3" />
    </Style>

    <Style x:Key="ChartToolbarSeparator" TargetType="BoxView">
        <Setter Property="Color"           Value="{DynamicResource ChartGrid}" />
        <Setter Property="WidthRequest"    Value="1" />
        <Setter Property="HeightRequest"   Value="14" />
        <Setter Property="Margin"          Value="3,0" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="ChartResolutionButtonBase" TargetType="Button">
        <Setter Property="Padding"             Value="4,0" />
        <Setter Property="MinimumWidthRequest" Value="28" />
        <Setter Property="HeightRequest"       Value="18" />
        <Setter Property="CornerRadius"        Value="3" />
        <Setter Property="FontSize"            Value="10" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="BorderWidth"         Value="0" />
    </Style>

    <Style x:Key="ChartResolutionButton.Unselected" TargetType="Button"
           BasedOn="{StaticResource ChartResolutionButtonBase}">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
    </Style>

    <Style x:Key="ChartIconButton" TargetType="Button">
        <Setter Property="Padding"         Value="0" />
        <Setter Property="WidthRequest"    Value="18" />
        <Setter Property="HeightRequest"   Value="18" />
        <Setter Property="CornerRadius"    Value="3" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
        <Setter Property="BorderWidth"     Value="0" />
    </Style>

    <Style x:Key="ChartLiveButton.Off" TargetType="Button">
        <Setter Property="Padding"         Value="5,0" />
        <Setter Property="HeightRequest"   Value="18" />
        <Setter Property="CornerRadius"    Value="3" />
        <Setter Property="FontSize"        Value="9" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
        <Setter Property="BorderWidth"     Value="1" />
        <Setter Property="BorderColor"     Value="{DynamicResource ChartGrid}" />
    </Style>

    <!-- ============================================================
         NEW DESIGN SYSTEM STYLES
         ============================================================ -->

    <!-- Live OHLCV readout strip above the chart (O / H / L / C / V) -->
    <Style x:Key="ChartOhlcKey" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize"   Value="10" />
        <Setter Property="TextColor"  Value="{DynamicResource ChartAxis}" />
    </Style>

    <Style x:Key="ChartOhlcValue" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize"   Value="11" />
        <Setter Property="TextColor"  Value="{DynamicResource White}" />
    </Style>


</ResourceDictionary>
