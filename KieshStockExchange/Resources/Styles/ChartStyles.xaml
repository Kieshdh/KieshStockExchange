<?xml version="1.0" encoding="utf-8" ?>
<!-- ChartStyles.xaml - chart canvas, toolbar, interval pills, indicator chips,
     OHLC overlay, axis labels. All chart palette keys come from the active theme. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================
         LEGACY STYLES - kept so existing ChartView continues to compile.
         ============================================================ -->

    <Style x:Key="ChartSurface" TargetType="GraphicsView">
        <Setter Property="BackgroundColor"   Value="{DynamicResource ChartBg}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions"   Value="Fill" />
    </Style>

    <Style x:Key="ChartToolbar" TargetType="Grid">
        <Setter Property="BackgroundColor" Value="{DynamicResource ChartPanel}" />
        <Setter Property="Padding"         Value="4,1" />
        <Setter Property="ColumnSpacing"   Value="3" />
    </Style>

    <Style x:Key="ChartToolbarSeparator" TargetType="BoxView">
        <Setter Property="Color"           Value="{DynamicResource ChartGrid}" />
        <Setter Property="WidthRequest"    Value="1" />
        <Setter Property="HeightRequest"   Value="14" />
        <Setter Property="Margin"          Value="3,0" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <Style x:Key="ChartResolutionButtonBase" TargetType="Button">
        <Setter Property="Padding"             Value="4,0" />
        <Setter Property="MinimumWidthRequest" Value="28" />
        <Setter Property="HeightRequest"       Value="18" />
        <Setter Property="CornerRadius"        Value="3" />
        <Setter Property="FontSize"            Value="10" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="BorderWidth"         Value="0" />
    </Style>

    <Style x:Key="ChartResolutionButton.Unselected" TargetType="Button"
           BasedOn="{StaticResource ChartResolutionButtonBase}">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
    </Style>

    <Style x:Key="ChartIconButton" TargetType="Button">
        <Setter Property="Padding"         Value="0" />
        <Setter Property="WidthRequest"    Value="18" />
        <Setter Property="HeightRequest"   Value="18" />
        <Setter Property="CornerRadius"    Value="3" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
        <Setter Property="BorderWidth"     Value="0" />
    </Style>

    <Style x:Key="ChartLiveButton.Off" TargetType="Button">
        <Setter Property="Padding"         Value="5,0" />
        <Setter Property="HeightRequest"   Value="18" />
        <Setter Property="CornerRadius"    Value="3" />
        <Setter Property="FontSize"        Value="9" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
        <Setter Property="BorderWidth"     Value="1" />
        <Setter Property="BorderColor"     Value="{DynamicResource ChartGrid}" />
    </Style>

    <!-- Colour swatch in the floating drawing style-bar. BackgroundColor is set per-instance. -->
    <Style x:Key="ChartSwatchButton" TargetType="Button">
        <Setter Property="Padding"         Value="0" />
        <Setter Property="WidthRequest"    Value="20" />
        <Setter Property="HeightRequest"   Value="16" />
        <Setter Property="CornerRadius"    Value="3" />
        <Setter Property="BorderWidth"     Value="0" />
    </Style>

    <!-- Pen-tray specimen tile: a bordered cell hosting a live GraphicsView specimen. Fills its grid
         * column; the selected tile swaps Stroke to white via a DataTrigger. -->
    <Style x:Key="PenSpecimenTile" TargetType="Border">
        <Setter Property="HeightRequest"    Value="26" />
        <Setter Property="Stroke"           Value="Transparent" />
        <Setter Property="StrokeThickness"  Value="2" />
        <Setter Property="StrokeShape"      Value="RoundRectangle 3" />
        <Setter Property="BackgroundColor"  Value="{DynamicResource ChartBg}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>

    <Style x:Key="PenSpecimenView" TargetType="GraphicsView">
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="VerticalOptions"   Value="Fill" />
        <Setter Property="InputTransparent"  Value="True" />
    </Style>

    <!-- Pen-tray TOOL tile: a glyph button; selected tile gets the ChartGrid fill + white ring. -->
    <Style x:Key="PenToolTile" TargetType="Button">
        <Setter Property="Padding"         Value="0" />
        <Setter Property="WidthRequest"    Value="32" />
        <Setter Property="HeightRequest"   Value="32" />
        <Setter Property="CornerRadius"    Value="4" />
        <Setter Property="FontSize"        Value="14" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
        <Setter Property="BorderWidth"     Value="1" />
        <Setter Property="BorderColor"     Value="{DynamicResource ChartGrid}" />
    </Style>

    <!-- Thin vertical click-strip beside a rail group tile (~1/5 the tile width) carrying a › arrow:
         click toggles the group flyout, highlights on hover (no hover-open). -->
    <Style x:Key="ToolGroupStrip" TargetType="Button">
        <Setter Property="WidthRequest"        Value="8" />
        <Setter Property="MinimumWidthRequest" Value="8" />
        <Setter Property="HeightRequest"       Value="32" />
        <Setter Property="VerticalOptions"     Value="Center" />
        <!-- Slight top bias nudges the › glyph (which the font sets a hair high) to optical centre. -->
        <Setter Property="Padding"             Value="0,2,0,0" />
        <Setter Property="CornerRadius"        Value="2" />
        <Setter Property="BorderWidth"         Value="0" />
        <Setter Property="FontSize"            Value="10" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="Text"                Value="›" />
        <Setter Property="LineBreakMode"       Value="NoWrap" />
        <Setter Property="BackgroundColor"     Value="{DynamicResource ChartGrid}" />
        <Setter Property="TextColor"           Value="{DynamicResource ChartAxis}" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{DynamicResource ChartAxis}" />
                            <Setter Property="TextColor"       Value="{DynamicResource ChartPanel}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Text label beside a boxed tool icon in a group flyout (icon = the boxed button, label sits
         outside it but styled to match). Made tappable at the call site so the whole row picks the tool. -->
    <Style x:Key="ToolFlyoutLabel" TargetType="Label">
        <Setter Property="VerticalOptions" Value="Center" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="TextColor"       Value="{DynamicResource ChartAxis}" />
    </Style>

    <!-- ============================================================
         NEW DESIGN SYSTEM STYLES
         ============================================================ -->

    <!-- Live OHLCV readout strip above the chart (O / H / L / C / V) -->
    <Style x:Key="ChartOhlcKey" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize"   Value="10" />
        <Setter Property="TextColor"  Value="{DynamicResource ChartAxis}" />
    </Style>

    <Style x:Key="ChartOhlcValue" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize"   Value="11" />
        <Setter Property="TextColor"  Value="{DynamicResource White}" />
    </Style>

    <!-- The OHLCV strip's CLOSE value: tints bull/bear from the displayed candle's direction. -->
    <Style x:Key="ChartOhlcCloseValue" TargetType="Label" BasedOn="{StaticResource ChartOhlcValue}">
        <Style.Triggers>
            <DataTrigger TargetType="Label" Binding="{Binding DisplayedCandle.IsBullish}" Value="True">
                <Setter Property="TextColor" Value="{DynamicResource ChartBull}" />
            </DataTrigger>
            <DataTrigger TargetType="Label" Binding="{Binding DisplayedCandle.IsBearish}" Value="True">
                <Setter Property="TextColor" Value="{DynamicResource ChartBear}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>


</ResourceDictionary>
