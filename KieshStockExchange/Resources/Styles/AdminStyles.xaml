<?xml version="1.0" encoding="utf-8" ?>
<!-- AdminStyles.xaml - AdminPage shell, cards, tables, pagination, status dots.
     All surfaces use theme semantic tokens; legacy keys are preserved.
     Bot-stat card styles (AdminBotStat*) are used by BotDashboardPage. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================
         ADMIN SHELL - cards, metrics, buttons, status dots
         ============================================================ -->

    <Style x:Key="AdminCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor"     Value="{DynamicResource CardSurface}" />
        <Setter Property="Stroke"              Value="{DynamicResource Divider}" />
        <Setter Property="StrokeThickness"     Value="1" />
        <Setter Property="StrokeShape"         Value="RoundRectangle 10" />
        <Setter Property="Padding"             Value="12" />
        <Setter Property="Margin"              Value="12,6" />
    </Style>

    <Style x:Key="AdminCardTitle" TargetType="Label">
        <Setter Property="TextColor"           Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="FontSize"            Value="16" />
        <Setter Property="VerticalOptions"     Value="Center" />
    </Style>

    <Style x:Key="AdminCardSubtitle" TargetType="Label" BasedOn="{StaticResource AdminCardTitle}">
        <Setter Property="FontSize"            Value="13" />
    </Style>

    <Style x:Key="AdminMetricLabel" TargetType="Label">
        <Setter Property="TextColor"           Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize"            Value="12" />
        <Setter Property="VerticalOptions"     Value="Center" />
    </Style>

    <Style x:Key="AdminMetricValue" TargetType="Label">
        <Setter Property="TextColor"           Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="FontSize"            Value="14" />
        <Setter Property="VerticalOptions"     Value="Center" />
    </Style>

    <Style x:Key="AdminEntry" TargetType="Entry">
        <Setter Property="TextColor"           Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor"    Value="{DynamicResource TextMuted}" />
        <Setter Property="BackgroundColor"     Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="HeightRequest"       Value="32" />
        <Setter Property="FontSize"            Value="13" />
    </Style>

    <Style x:Key="AdminPrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor"     Value="{DynamicResource BuyGreen}" />
        <Setter Property="TextColor"           Value="{DynamicResource White}" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="FontSize"            Value="13" />
        <Setter Property="CornerRadius"        Value="6" />
        <Setter Property="HeightRequest"       Value="32" />
        <Setter Property="MinimumWidthRequest" Value="80" />
        <Setter Property="Padding"             Value="10,0" />
    </Style>

    <Style x:Key="AdminDangerButton" TargetType="Button" BasedOn="{StaticResource AdminPrimaryButton}">
        <Setter Property="BackgroundColor"     Value="{DynamicResource SellRed}" />
        <Setter Property="TextColor"           Value="{DynamicResource White}" />
    </Style>

    <Style x:Key="AdminGhostButton" TargetType="Button">
        <Setter Property="BackgroundColor"     Value="Transparent" />
        <Setter Property="TextColor"           Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
        <Setter Property="FontSize"            Value="13" />
        <Setter Property="CornerRadius"        Value="6" />
        <Setter Property="HeightRequest"       Value="32" />
        <Setter Property="MinimumWidthRequest" Value="80" />
        <Setter Property="BorderColor"         Value="{DynamicResource Primary}" />
        <Setter Property="BorderWidth"         Value="1" />
        <Setter Property="Padding"             Value="10,0" />
    </Style>

    <Style x:Key="AdminRefreshButton" TargetType="Button" BasedOn="{StaticResource AdminGhostButton}">
        <Setter Property="MinimumWidthRequest" Value="100" />
        <Setter Property="Margin"              Value="8,0,0,0" />
    </Style>

    <Style x:Key="AdminStatusDot" TargetType="Ellipse">
        <Setter Property="WidthRequest"        Value="10" />
        <Setter Property="HeightRequest"       Value="10" />
        <Setter Property="VerticalOptions"     Value="Center" />
        <Setter Property="HorizontalOptions"   Value="Center" />
    </Style>

    <Style x:Key="AdminStatusDot.Online" TargetType="Ellipse" BasedOn="{StaticResource AdminStatusDot}">
        <Setter Property="Fill"                Value="{DynamicResource BuyGreen}" />
    </Style>

    <Style x:Key="AdminStatusDot.Offline" TargetType="Ellipse" BasedOn="{StaticResource AdminStatusDot}">
        <Setter Property="Fill"                Value="{DynamicResource SellRed}" />
    </Style>

    <Style x:Key="AdminInsetPanel" TargetType="Border">
        <Setter Property="BackgroundColor"     Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="Stroke"              Value="{DynamicResource Divider}" />
        <Setter Property="StrokeThickness"     Value="1" />
        <Setter Property="StrokeShape"         Value="RoundRectangle 6" />
        <Setter Property="Padding"             Value="8" />
    </Style>

    <Style x:Key="AdminMutedNote" TargetType="Label">
        <Setter Property="TextColor"           Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize"            Value="11" />
        <Setter Property="LineBreakMode"       Value="WordWrap" />
    </Style>

    <!-- ============================================================
         ADMIN TABLES - header, rows, separators, pagination
         ============================================================ -->

    <Style x:Key="TableHeaderLabel" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="HorizontalOptions"     Value="Center" />
        <Setter Property="FontSize"              Value="Small" />
    </Style>

    <Style x:Key="TableRowLabel" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="HorizontalOptions"     Value="Center" />
        <Setter Property="VerticalOptions"       Value="Center" />
    </Style>

    <Style x:Key="TableRowEntry" TargetType="Entry">
        <Setter Property="TextColor"               Value="{DynamicResource TextPrimary}" />
        <Setter Property="VerticalOptions"         Value="Fill" />
        <Setter Property="HorizontalOptions"       Value="Fill" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="Background"              Value="{DynamicResource CardSurfaceMuted}" />
    </Style>

    <Style x:Key="TableEditLabel" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource BuyGreen}" />
        <Setter Property="HorizontalOptions"     Value="Center" />
        <Setter Property="VerticalOptions"       Value="Center" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="TableVerticalSeparator" TargetType="BoxView">
        <Setter Property="BackgroundColor"       Value="{DynamicResource Divider}" />
        <Setter Property="WidthRequest"          Value="1" />
        <Setter Property="HorizontalOptions"     Value="Start" />
    </Style>

    <Style x:Key="TableHorizontalSeparator" TargetType="BoxView">
        <Setter Property="BackgroundColor"       Value="{DynamicResource Divider}" />
        <Setter Property="HeightRequest"         Value="1" />
        <Setter Property="HorizontalOptions"     Value="Fill" />
        <Setter Property="VerticalOptions"       Value="End" />
        <Setter Property="Grid.ColumnSpan"       Value="10" />
    </Style>

    <Style x:Key="TableRowGrid" TargetType="Grid">
        <Setter Property="BackgroundColor"       Value="Transparent" />
        <Setter Property="RowDefinitions"        Value="Auto" />
        <Setter Property="Padding"               Value="0" />
        <Setter Property="Margin"                Value="0" />
    </Style>

    <Style x:Key="TableHeaderGrid" TargetType="Grid">
        <Setter Property="BackgroundColor"       Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="RowDefinitions"        Value="Auto" />
        <Setter Property="Padding"               Value="4" />
        <!-- Bottom margin is positive so the filter row and CollectionView
             below get breathing room instead of being pulled up under the
             header. -->
        <Setter Property="Margin"                Value="10,10,10,6" />
    </Style>

    <Style x:Key="PageNumberStackLayout" TargetType="HorizontalStackLayout">
        <Setter Property="HorizontalOptions"     Value="Center" />
        <Setter Property="Spacing"               Value="10" />
        <Setter Property="Margin"                Value="0,0,0,10" />
    </Style>

    <Style x:Key="PageNumberButton" TargetType="Button">
        <Setter Property="WidthRequest"          Value="40" />
        <Setter Property="HeightRequest"         Value="30" />
        <Setter Property="CornerRadius"          Value="15" />
        <Setter Property="Padding"               Value="5,0" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="TextColor"             Value="{DynamicResource TextSecondary}" />
        <Setter Property="BackgroundColor"       Value="{DynamicResource CardSurfaceMuted}" />
    </Style>

    <!-- Quick-filter chip used on the sort/filter rows (1h / 7d / 30d / All).
         Default sized 20x20 squares blended into the card background and were
         unreadable; this version is a proper pill that fits its label and
         contrasts against the table card. -->
    <Style x:Key="TableSortingButton" TargetType="Button">
        <Setter Property="BackgroundColor"       Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="BorderColor"           Value="{DynamicResource Divider}" />
        <Setter Property="BorderWidth"           Value="1" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="FontSize"              Value="12" />
        <Setter Property="CornerRadius"          Value="14" />
        <Setter Property="Padding"               Value="10,2" />
        <Setter Property="MinimumWidthRequest"   Value="44" />
        <Setter Property="HeightRequest"         Value="28" />
        <Setter Property="VerticalOptions"       Value="Center" />
    </Style>

    <Style x:Key="SortingStackLayout" TargetType="HorizontalStackLayout">
        <Setter Property="Spacing"               Value="10" />
        <Setter Property="HorizontalOptions"     Value="Center" />
    </Style>

    <!-- ============================================================
         NEW DESIGN SYSTEM STYLES
         ============================================================ -->

    <!-- Semantic column header label (11 px, muted, tracked) -->
    <Style x:Key="TableHeaderLabelStyle" TargetType="Label">
        <Setter Property="FontFamily"              Value="OpenSansSemibold" />
        <Setter Property="FontSize"                Value="11" />
        <Setter Property="TextColor"               Value="{DynamicResource TextMuted}" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="VerticalTextAlignment"   Value="Center" />
        <Setter Property="CharacterSpacing"        Value="0.3" />
    </Style>

    <!-- Semantic header row grid -->
    <Style x:Key="TableHeaderGridStyle" TargetType="Grid">
        <Setter Property="BackgroundColor"       Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="Padding"               Value="8,6" />
        <Setter Property="ColumnSpacing"         Value="4" />
    </Style>

    <!-- Loading overlay positioned absolutely over the table area -->
    <Style x:Key="AdminLoadingOverlay" TargetType="Border">
        <Setter Property="BackgroundColor"       Value="{DynamicResource CardSurface}" />
        <Setter Property="Opacity"               Value="0.85" />
        <Setter Property="Stroke"                Value="Transparent" />
        <Setter Property="StrokeThickness"       Value="0" />
        <Setter Property="HorizontalOptions"     Value="Fill" />
        <Setter Property="VerticalOptions"       Value="Fill" />
    </Style>

    <Style x:Key="AdminLoadingActivity" TargetType="ActivityIndicator">
        <Setter Property="Color"                 Value="{DynamicResource Primary}" />
        <Setter Property="WidthRequest"          Value="48" />
        <Setter Property="HeightRequest"         Value="48" />
        <Setter Property="HorizontalOptions"     Value="Center" />
        <Setter Property="VerticalOptions"       Value="Center" />
    </Style>

    <!-- Bot-stats card (BotDashboardPage) -->
    <Style x:Key="AdminBotStatCard" TargetType="Border">
        <Setter Property="BackgroundColor"       Value="{DynamicResource CardSurface}" />
        <Setter Property="Stroke"                Value="{DynamicResource Divider}" />
        <Setter Property="StrokeThickness"       Value="1" />
        <Setter Property="StrokeShape"           Value="RoundRectangle 8" />
        <Setter Property="Padding"               Value="14,10" />
    </Style>

    <Style x:Key="AdminBotStatLabel" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize"              Value="11" />
    </Style>

    <Style x:Key="AdminBotStatValue" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="FontSize"              Value="18" />
    </Style>

    <!-- ============================================================
         WAVE 6 — Sortable header + pager + numeric cell
         ============================================================ -->

    <!-- Clickable column header. Acts as the button surface for SortableHeader. -->
    <Style x:Key="SortableHeaderButton" TargetType="Border">
        <Setter Property="BackgroundColor"       Value="Transparent" />
        <Setter Property="Stroke"                Value="Transparent" />
        <Setter Property="StrokeThickness"       Value="0" />
        <Setter Property="Padding"               Value="6,4" />
        <Setter Property="HorizontalOptions"     Value="Fill" />
        <Setter Property="VerticalOptions"       Value="Fill" />
    </Style>

    <!-- Tiny arrow that appears next to the active sort column. -->
    <Style x:Key="SortableHeaderArrow" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource Primary}" />
        <Setter Property="FontSize"              Value="11" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
    </Style>

    <!-- Prev/Next chevron buttons in the pager. -->
    <Style x:Key="PagerNavButton" TargetType="Button">
        <Setter Property="BackgroundColor"       Value="Transparent" />
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="FontSize"              Value="14" />
        <Setter Property="Padding"               Value="8,4" />
        <Setter Property="CornerRadius"          Value="6" />
        <Setter Property="MinimumWidthRequest"   Value="36" />
        <Setter Property="HeightRequest"         Value="30" />
    </Style>

    <!-- Inactive page-number button. -->
    <Style x:Key="PagerPageButton" TargetType="Button">
        <Setter Property="BackgroundColor"       Value="Transparent" />
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="FontSize"              Value="13" />
        <Setter Property="Padding"               Value="0" />
        <Setter Property="CornerRadius"          Value="6" />
        <Setter Property="MinimumWidthRequest"   Value="30" />
        <Setter Property="HeightRequest"         Value="28" />
    </Style>

    <!-- Active page-number button. Applied via DataTrigger inside the pager. -->
    <Style x:Key="PagerActivePageButton" TargetType="Button" BasedOn="{StaticResource PagerPageButton}">
        <Setter Property="BackgroundColor"       Value="{DynamicResource Primary}" />
        <Setter Property="TextColor"             Value="{DynamicResource PrimaryDarkText}" />
    </Style>

    <!-- "Page X of Y · N rows" summary label. -->
    <Style x:Key="PagerSummaryLabel" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource TextMuted}" />
        <Setter Property="FontSize"              Value="12" />
        <Setter Property="VerticalOptions"       Value="Center" />
    </Style>

    <!-- Page-size picker. -->
    <Style x:Key="PagerSizePicker" TargetType="Picker">
        <Setter Property="BackgroundColor"       Value="Transparent" />
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize"              Value="12" />
        <Setter Property="MinimumWidthRequest"   Value="60" />
        <Setter Property="HeightRequest"         Value="28" />
    </Style>

    <!-- Right-aligned numeric cell (used for currency/quantity columns). -->
    <Style x:Key="TableRowLabelNumeric" TargetType="Label" BasedOn="{StaticResource TableRowLabel}">
        <Setter Property="HorizontalOptions"       Value="Fill" />
        <Setter Property="HorizontalTextAlignment" Value="End" />
        <Setter Property="Margin"                  Value="0,0,8,0" />
    </Style>

    <!-- Date + Time pickers on the Orders/Transactions filter rows: native
         WinUI peers have different default heights, so we force a matching
         visual height. HeightRequest + MinimumHeightRequest + VerticalOptions
         is the combination that actually sticks; HeightRequest alone is
         treated as a hint and gets overridden by the platform default. -->
    <Style x:Key="AdminDatePicker" TargetType="DatePicker">
        <Setter Property="HeightRequest"        Value="36" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="VerticalOptions"      Value="Fill" />
    </Style>
    <Style x:Key="AdminTimePicker" TargetType="TimePicker">
        <Setter Property="HeightRequest"        Value="36" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="VerticalOptions"      Value="Fill" />
        <Setter Property="Format"               Value="HH:mm" />
    </Style>

    <!-- Compact segment buttons for admin filter rows (less tall than the
         PlaceOrderView segments). Values inlined rather than BasedOn so the
         style doesn't depend on SegmentedTabStyles.xaml being merged first. -->
    <Style x:Key="AdminUnselectedSegment" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"       Value="{DynamicResource UnselectedTabFg}" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="Padding"         Value="10,2" />
        <Setter Property="CornerRadius"    Value="12" />
        <Setter Property="BorderColor"     Value="Transparent" />
        <Setter Property="BorderWidth"     Value="1" />
        <Setter Property="HeightRequest"   Value="28" />
    </Style>
    <Style x:Key="AdminSelectedSegment" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource SelectedTabBg}" />
        <Setter Property="TextColor"       Value="{DynamicResource SelectedTabFg}" />
        <Setter Property="FontFamily"      Value="OpenSansSemibold" />
        <Setter Property="FontSize"        Value="12" />
        <Setter Property="Padding"         Value="10,2" />
        <Setter Property="CornerRadius"    Value="12" />
        <Setter Property="BorderColor"     Value="{DynamicResource Divider}" />
        <Setter Property="BorderWidth"     Value="1" />
        <Setter Property="HeightRequest"   Value="28" />
    </Style>

</ResourceDictionary>
