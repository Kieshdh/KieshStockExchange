    <Color x:Key="Info">#22D3EE</Color>
    <Color x:Key="Disabled">#2E3A55</Color>
    <Color x:Key="SelectedTabBg">#15203A</Color>
    <Color x:Key="SelectedTabFg">#DCE6F5</Color>
    <Color x:Key="UnselectedTabFg">#8FA1C0</Color>
    <Color x:Key="SegmentedPillBackground">#15203A</Color>
    <Color x:Key="SegmentedPillStroke">#1E2C4D</Color>
    <Color x:Key="DarkGreen">#10B981</Color>
    <Color x:Key="DarkNavy">#060A14</Color>
    <Color x:Key="AccentGreen">#10B981</Color>
    <Color x:Key="SkyBlue">#22D3EE</Color>
    <Color x:Key="MutedGrey">#5A6A88</Color>
    <Color x:Key="SoftWhite">#DCE6F5</Color>
    <Color x:Key="MidnightBlue">#060A14</Color>
    <Color x:Key="OffBlack">#060A14</Color>
