<?xml version="1.0" encoding="UTF-8" ?>
<!-- Theme: Midnight Trader — deep blue-black, electric blue, cinematic
     Drop-in ResourceDictionary. Merge as the FIRST entry of
     App.xaml's MergedDictionaries. -->
<ResourceDictionary
    x:Class="KieshStockExchange.Resources.Styles.Themes.MidnightTrader"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackground">#060A14</Color>
    <Color x:Key="CardSurface">#0E1626</Color>
    <Color x:Key="CardSurfaceMuted">#15203A</Color>
    <Color x:Key="RowHover">#142039</Color>
    <Color x:Key="RowSelected">#1E305A</Color>
    <Color x:Key="TableRowBackground">#0E1626</Color>
    <Color x:Key="TextPrimary">#DCE6F5</Color>
    <Color x:Key="TextSecondary">#8FA1C0</Color>
    <Color x:Key="TextMuted">#5A6A88</Color>
    <Color x:Key="TextDisabled">#2E3A55</Color>
    <Color x:Key="TextOnPrimary">#060A14</Color>
    <Color x:Key="Divider">#18233B</Color>
    <Color x:Key="Primary">#3B82F6</Color>
    <Color x:Key="PrimaryHover">#60A5FA</Color>
    <Color x:Key="PrimaryPressed">#2563EB</Color>
    <Color x:Key="BuyGreen">#10B981</Color>
