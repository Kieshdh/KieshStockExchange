<?xml version="1.0" encoding="UTF-8" ?>
<!-- Theme: Institutional Blue — pure white, navy primary, Bloomberg-leaning
     Drop-in ResourceDictionary. Merge as the FIRST entry of
     App.xaml's MergedDictionaries. -->
<ResourceDictionary
    x:Class="KieshStockExchange.Resources.Styles.Themes.InstitutionalBlue"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackground">#FFFFFF</Color>
    <Color x:Key="CardSurface">#FFFFFF</Color>
    <Color x:Key="CardSurfaceMuted">#F1F4F9</Color>
    <Color x:Key="RowHover">#EEF3FA</Color>
    <Color x:Key="RowSelected">#DCE6F5</Color>
    <Color x:Key="TableRowBackground">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#0B1F3A</Color>
    <Color x:Key="TextSecondary">#3D4F6A</Color>
    <Color x:Key="TextMuted">#7E8AA0</Color>
    <Color x:Key="TextDisabled">#C5CCDA</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>
    <Color x:Key="Divider">#D8DFEA</Color>
    <Color x:Key="Primary">#0B3D91</Color>
    <Color x:Key="PrimaryHover">#082F73</Color>
    <Color x:Key="PrimaryPressed">#062356</Color>
    <Color x:Key="BuyGreen">#0E7A3D</Color>
    <Color x:Key="BuyGreenSoft">#D6EEDE</Color>
    <Color x:Key="SellRed">#B91C1C</Color>
    <Color x:Key="SellRedSoft">#F5DADA</Color>
    <Color x:Key="Warning">#B45309</Color>
    <Color x:Key="Info">#1D4ED8</Color>
    <Color x:Key="Disabled">#C5CCDA</Color>
    <Color x:Key="SelectedTabBg">#FFFFFF</Color>
    <Color x:Key="SelectedTabFg">#0B1F3A</Color>
    <Color x:Key="UnselectedTabFg">#3D4F6A</Color>
    <Color x:Key="SegmentedPillBackground">#F1F4F9</Color>
    <Color x:Key="SegmentedPillStroke">#D8DFEA</Color>
    <Color x:Key="DarkGreen">#0E7A3D</Color>
    <Color x:Key="DarkNavy">#FFFFFF</Color>
    <Color x:Key="AccentGreen">#0E7A3D</Color>
    <Color x:Key="SkyBlue">#1D4ED8</Color>
    <Color x:Key="MutedGrey">#7E8AA0</Color>
    <Color x:Key="SoftWhite">#FFFFFF</Color>
    <Color x:Key="MidnightBlue">#0B1F3A</Color>
    <Color x:Key="OffBlack">#FFFFFF</Color>
    <Color x:Key="Secondary">#F1F4F9</Color>
    <Color x:Key="PrimaryDark">#0B3D91</Color>
    <Color x:Key="PrimaryDarkText">#FFFFFF</Color>
    <Color x:Key="SecondaryDarkText">#3D4F6A</Color>
    <Color x:Key="Tertiary">#062356</Color>
    <Color x:Key="Magenta">#0B3D91</Color>
    <Color x:Key="Gray100">#F1F4F9</Color>
    <Color x:Key="Gray200">#D8DFEA</Color>
    <Color x:Key="Gray300">#C5CCDA</Color>
    <Color x:Key="Gray400">#7E8AA0</Color>
    <Color x:Key="Gray500">#5C6781</Color>
    <Color x:Key="Gray600">#3D4F6A</Color>
    <Color x:Key="Gray900">#172A4A</Color>
