<?xml version="1.0" encoding="UTF-8" ?>
<!-- Theme: Soft Broker — warm cream surfaces, deep navy ink, mustard primary
     Drop-in ResourceDictionary. Merge as the FIRST entry of
     App.xaml's MergedDictionaries. -->
<ResourceDictionary
    x:Class="KieshStockExchange.Resources.Styles.Themes.SoftBroker"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackground">#FBF7F0</Color>
    <Color x:Key="CardSurface">#FFFFFF</Color>
    <Color x:Key="CardSurfaceMuted">#F4EEDF</Color>
    <Color x:Key="RowHover">#F7F1E2</Color>
    <Color x:Key="RowSelected">#FAEBC9</Color>
    <Color x:Key="TableRowBackground">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#1A2238</Color>
    <Color x:Key="TextSecondary">#4F5670</Color>
    <Color x:Key="TextMuted">#8E94A8</Color>
    <Color x:Key="TextDisabled">#CCCFDA</Color>
    <Color x:Key="TextOnPrimary">#1A2238</Color>
    <Color x:Key="Divider">#E7E0D0</Color>
    <Color x:Key="Primary">#B8862C</Color>
    <Color x:Key="PrimaryHover">#9A6F23</Color>
    <Color x:Key="PrimaryPressed">#7C5818</Color>
    <Color x:Key="BuyGreen">#1F7A4D</Color>
    <Color x:Key="BuyGreenSoft">#D7EEE0</Color>
    <Color x:Key="SellRed">#B8453A</Color>
    <Color x:Key="SellRedSoft">#F2DEDC</Color>
    <Color x:Key="Warning">#C76A1F</Color>
    <Color x:Key="Info">#3A6FB0</Color>
    <Color x:Key="Disabled">#CCCFDA</Color>
    <Color x:Key="SelectedTabBg">#FFFFFF</Color>
    <Color x:Key="SelectedTabFg">#1A2238</Color>
    <Color x:Key="UnselectedTabFg">#4F5670</Color>
    <Color x:Key="SegmentedPillBackground">#F4EEDF</Color>
    <Color x:Key="SegmentedPillStroke">#E2D9BE</Color>
    <Color x:Key="DarkGreen">#1F7A4D</Color>
    <Color x:Key="DarkNavy">#FBF7F0</Color>
    <Color x:Key="AccentGreen">#1F7A4D</Color>
    <Color x:Key="SkyBlue">#3A6FB0</Color>
    <Color x:Key="MutedGrey">#8E94A8</Color>
    <Color x:Key="SoftWhite">#FFFFFF</Color>
    <Color x:Key="MidnightBlue">#1A2238</Color>
    <Color x:Key="OffBlack">#FFFFFF</Color>
    <Color x:Key="Secondary">#F4EEDF</Color>
    <Color x:Key="PrimaryDark">#B8862C</Color>
    <Color x:Key="PrimaryDarkText">#1A2238</Color>
    <Color x:Key="SecondaryDarkText">#4F5670</Color>
    <Color x:Key="Tertiary">#7C5818</Color>
    <Color x:Key="Magenta">#B8862C</Color>
    <Color x:Key="Gray100">#F7F1E2</Color>
    <Color x:Key="Gray200">#E7E0D0</Color>
    <Color x:Key="Gray300">#CFC6B0</Color>
    <Color x:Key="Gray400">#8E94A8</Color>
    <Color x:Key="Gray500">#6B7088</Color>
    <Color x:Key="Gray600">#4F5670</Color>
    <Color x:Key="Gray900">#262E48</Color>
    <Color x:Key="Gray950">#1A2238</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#1A2238</Color>
    <Color x:Key="LightGrey">#8E94A8</Color>
    <Color x:Key="DarkGrey">#4F5670</Color>

    <Color x:Key="ChartBg">#1A1814</Color>
    <Color x:Key="ChartPanel">#221F1A</Color>
    <Color x:Key="ChartGrid">#322D24</Color>
    <Color x:Key="ChartAxis">#998E78</Color>
    <Color x:Key="ChartBull">#6FA980</Color>
    <Color x:Key="ChartBear">#C76A60</Color>
    <Color x:Key="ChartCrosshair">#CCCFDA</Color>

    <SolidColorBrush x:Key="PageBackgroundBrush"    Color="{StaticResource PageBackground}"/>
    <SolidColorBrush x:Key="CardSurfaceBrush"       Color="{StaticResource CardSurface}"/>
    <SolidColorBrush x:Key="CardSurfaceMutedBrush"  Color="{StaticResource CardSurfaceMuted}"/>
    <SolidColorBrush x:Key="DividerBrush"           Color="{StaticResource Divider}"/>
    <SolidColorBrush x:Key="PrimaryBrush"           Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="BuyPriceBrush"          Color="{StaticResource BuyGreen}"/>
    <SolidColorBrush x:Key="SellPriceBrush"         Color="{StaticResource SellRed}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"         Color="{StaticResource TextMuted}"/>
