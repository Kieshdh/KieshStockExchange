<?xml version="1.0" encoding="UTF-8" ?>
<!-- Theme: Nordic Terminal — porcelain off-white, slate ink, muted teal
     Drop-in ResourceDictionary. Merge as the FIRST entry of
     App.xaml's MergedDictionaries. -->
<ResourceDictionary
    x:Class="KieshStockExchange.Resources.Styles.Themes.NordicTerminal"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackground">#F2EFEA</Color>
    <Color x:Key="CardSurface">#FBF9F5</Color>
    <Color x:Key="CardSurfaceMuted">#ECE7DE</Color>
    <Color x:Key="RowHover">#EFEBE3</Color>
    <Color x:Key="RowSelected">#DCE8E6</Color>
    <Color x:Key="TableRowBackground">#FBF9F5</Color>
    <Color x:Key="TextPrimary">#1F2933</Color>
    <Color x:Key="TextSecondary">#4B5663</Color>
    <Color x:Key="TextMuted">#8C97A2</Color>
    <Color x:Key="TextDisabled">#C7CFD8</Color>
    <Color x:Key="TextOnPrimary">#FBF9F5</Color>
    <Color x:Key="Divider">#DBD5CB</Color>
    <Color x:Key="Primary">#2E7D7A</Color>
    <Color x:Key="PrimaryHover">#246462</Color>
    <Color x:Key="PrimaryPressed">#1B4D4B</Color>
    <Color x:Key="BuyGreen">#2E7D5A</Color>
    <Color x:Key="BuyGreenSoft">#D8EADD</Color>
    <Color x:Key="SellRed">#B23A3A</Color>
    <Color x:Key="SellRedSoft">#F2DCDC</Color>
    <Color x:Key="Warning">#B8862C</Color>
    <Color x:Key="Info">#3A6A8A</Color>
    <Color x:Key="Disabled">#C7CFD8</Color>
    <Color x:Key="SelectedTabBg">#FBF9F5</Color>
    <Color x:Key="SelectedTabFg">#1F2933</Color>
    <Color x:Key="UnselectedTabFg">#4B5663</Color>
    <Color x:Key="SegmentedPillBackground">#ECE7DE</Color>
    <Color x:Key="SegmentedPillStroke">#D6CFC1</Color>
    <Color x:Key="DarkGreen">#2E7D5A</Color>
    <Color x:Key="DarkNavy">#F2EFEA</Color>
    <Color x:Key="AccentGreen">#2E7D5A</Color>
    <Color x:Key="SkyBlue">#3A6A8A</Color>
    <Color x:Key="MutedGrey">#8C97A2</Color>
    <Color x:Key="SoftWhite">#FBF9F5</Color>
    <Color x:Key="MidnightBlue">#1F2933</Color>
    <Color x:Key="OffBlack">#FBF9F5</Color>
    <Color x:Key="Secondary">#ECE7DE</Color>
    <Color x:Key="PrimaryDark">#2E7D7A</Color>
    <Color x:Key="PrimaryDarkText">#1F2933</Color>
    <Color x:Key="SecondaryDarkText">#4B5663</Color>
    <Color x:Key="Tertiary">#1B4D4B</Color>
    <Color x:Key="Magenta">#2E7D7A</Color>
    <Color x:Key="Gray100">#F2EFEA</Color>
    <Color x:Key="Gray200">#DBD5CB</Color>
    <Color x:Key="Gray300">#C7BEAE</Color>
    <Color x:Key="Gray400">#8C97A2</Color>
    <Color x:Key="Gray500">#6B7480</Color>
    <Color x:Key="Gray600">#4B5663</Color>
    <Color x:Key="Gray900">#2A323C</Color>
    <Color x:Key="Gray950">#1F2933</Color>
    <Color x:Key="White">#FBF9F5</Color>
    <Color x:Key="Black">#1F2933</Color>
    <Color x:Key="LightGrey">#8C97A2</Color>
    <Color x:Key="DarkGrey">#4B5663</Color>

    <Color x:Key="ChartBg">#1A1F1E</Color>
    <Color x:Key="ChartPanel">#1F2624</Color>
    <Color x:Key="ChartGrid">#2A332F</Color>
    <Color x:Key="ChartAxis">#889089</Color>
    <Color x:Key="ChartBull">#4E9F7E</Color>
    <Color x:Key="ChartBear">#C25555</Color>
    <Color x:Key="ChartCrosshair">#C7CFD8</Color>

    <SolidColorBrush x:Key="PageBackgroundBrush"    Color="{StaticResource PageBackground}"/>
    <SolidColorBrush x:Key="CardSurfaceBrush"       Color="{StaticResource CardSurface}"/>
    <SolidColorBrush x:Key="CardSurfaceMutedBrush"  Color="{StaticResource CardSurfaceMuted}"/>
    <SolidColorBrush x:Key="DividerBrush"           Color="{StaticResource Divider}"/>
    <SolidColorBrush x:Key="PrimaryBrush"           Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="BuyPriceBrush"          Color="{StaticResource BuyGreen}"/>
    <SolidColorBrush x:Key="SellPriceBrush"         Color="{StaticResource SellRed}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"       Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush"         Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="WhiteBrush"             Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush"             Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="DarkGreenBrush"         Color="{StaticResource DarkGreen}"/>
    <SolidColorBrush x:Key="DarkNavyBrush"          Color="{StaticResource DarkNavy}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"       Color="{StaticResource AccentGreen}"/>
    <SolidColorBrush x:Key="SkyBlueBrush"           Color="{StaticResource SkyBlue}"/>
    <SolidColorBrush x:Key="MutedGreyBrush"         Color="{StaticResource MutedGrey}"/>
    <SolidColorBrush x:Key="SoftWhiteBrush"         Color="{StaticResource SoftWhite}"/>
    <SolidColorBrush x:Key="SecondaryBrush"         Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="Gray100Brush"           Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush"           Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush"           Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush"           Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush"           Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush"           Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush"           Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush"           Color="{StaticResource Gray950}"/>
    <SolidColorBrush x:Key="LightGreyBrush"         Color="{StaticResource LightGrey}"/>
    <SolidColorBrush x:Key="DarkGreyBrush"          Color="{StaticResource DarkGrey}"/>
    <SolidColorBrush x:Key="ChartBgBrush"           Color="{StaticResource ChartBg}"/>
    <SolidColorBrush x:Key="ChartPanelBrush"        Color="{StaticResource ChartPanel}"/>
    <SolidColorBrush x:Key="ChartGridBrush"         Color="{StaticResource ChartGrid}"/>
    <SolidColorBrush x:Key="ChartAxisBrush"         Color="{StaticResource ChartAxis}"/>
    <SolidColorBrush x:Key="ChartBullBrush"         Color="{StaticResource ChartBull}"/>
    <SolidColorBrush x:Key="ChartBearBrush"         Color="{StaticResource ChartBear}"/>
    <SolidColorBrush x:Key="ChartCrosshairBrush"    Color="{StaticResource ChartCrosshair}"/>

</ResourceDictionary>
