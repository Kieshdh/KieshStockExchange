<?xml version="1.0" encoding="UTF-8" ?>
<!-- Theme: Exchange Dark — slate/charcoal, indigo primary, default night
     Drop-in ResourceDictionary. Merge as the FIRST entry of
     App.xaml's MergedDictionaries. -->
<ResourceDictionary
    x:Class="KieshStockExchange.Resources.Styles.Themes.ExchangeDark"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackground">#0E1320</Color>
    <Color x:Key="CardSurface">#161C2C</Color>
    <Color x:Key="CardSurfaceMuted">#1E2538</Color>
    <Color x:Key="RowHover">#1B2238</Color>
    <Color x:Key="RowSelected">#25305A</Color>
    <Color x:Key="TableRowBackground">#161C2C</Color>
    <Color x:Key="TextPrimary">#E6EAF2</Color>
    <Color x:Key="TextSecondary">#A0AAC2</Color>
