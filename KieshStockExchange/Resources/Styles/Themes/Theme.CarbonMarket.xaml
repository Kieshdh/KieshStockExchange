<?xml version="1.0" encoding="UTF-8" ?>
<!-- Theme: Carbon Market — neutral graphite, amber primary, console feel
     Drop-in ResourceDictionary. Merge as the FIRST entry of
     App.xaml's MergedDictionaries. -->
<ResourceDictionary
    x:Class="KieshStockExchange.Resources.Styles.Themes.CarbonMarket"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="PageBackground">#131316</Color>
    <Color x:Key="CardSurface">#1B1B20</Color>
    <Color x:Key="CardSurfaceMuted">#24242A</Color>
    <Color x:Key="RowHover">#232328</Color>
    <Color x:Key="RowSelected">#353035</Color>
