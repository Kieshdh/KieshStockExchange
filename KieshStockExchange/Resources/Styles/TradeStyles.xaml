<?xml version="1.0" encoding="utf-8" ?>
<!-- TradeStyles.xaml - PlaceOrderView, stock selector, quote strip, order action buttons.
     Legacy keys preserved; new styles use theme semantic tokens. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================
         LEGACY STYLES - kept so existing views continue to compile
         ============================================================ -->

    <Style x:Key="TradeContentOutline" TargetType="Border">
        <Setter Property="Stroke"           Value="{DynamicResource Divider}" />
        <Setter Property="StrokeShape"      Value="RoundRectangle 6" />
        <Setter Property="Padding"          Value="8" />
        <Setter Property="Margin"           Value="4" />
        <Setter Property="BackgroundColor"  Value="{DynamicResource CardSurface}" />
    </Style>

    <Style x:Key="StockSelectorPicker" TargetType="Picker">
        <Setter Property="MinimumWidthRequest" Value="80" />
        <Setter Property="BackgroundColor"     Value="{DynamicResource CardSurfaceMuted}" />
        <Setter Property="TextColor"           Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize"            Value="Medium" />
        <Setter Property="VerticalOptions"     Value="Center" />
        <Setter Property="FontFamily"          Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="SelectedStockHeaderLabel" TargetType="Label">
        <Setter Property="TextColor"             Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontSize"              Value="Large" />
        <Setter Property="FontFamily"            Value="OpenSansSemibold" />
        <Setter Property="VerticalTextAlignment" Value="Center" />
        <Setter Property="VerticalOptions"       Value="Center" />
    </Style>

    <!-- ============================================================
         NEW DESIGN SYSTEM STYLES
         ============================================================ -->

    <!-- Large current-price readout on the quote strip -->
    <Style x:Key="QuotePriceLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize"   Value="26" />
        <Setter Property="TextColor"  Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Order totals summary (Est. Total / Remaining Funds ...) -->
    <Style x:Key="OrderTotalsLabel" TargetType="Label">
        <Setter Property="FontSize"  Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
    </Style>

    <Style x:Key="OrderTotalsValue" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize"   Value="13" />
        <Setter Property="TextColor"  Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Full-width BUY / SELL action buttons -->
    <Style x:Key="BuyButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor"   Value="{DynamicResource BuyGreen}" />
        <Setter Property="TextColor"         Value="{DynamicResource White}" />
        <Setter Property="FontFamily"        Value="OpenSansSemibold" />
        <Setter Property="FontSize"          Value="15" />
        <Setter Property="CornerRadius"      Value="10" />
        <Setter Property="HeightRequest"     Value="44" />
        <Setter Property="HorizontalOptions" Value="Fill" />
    </Style>


</ResourceDictionary>
