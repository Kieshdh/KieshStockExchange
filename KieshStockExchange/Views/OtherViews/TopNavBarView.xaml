<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.OtherViewModels"
             x:Class="KieshStockExchange.Views.OtherViews.TopNavBarView"
             x:DataType="vm:TopNavBarViewModel">

    <Grid Style="{StaticResource TopNavBarStyle}"
          ColumnDefinitions="Auto,*,Auto">

        <!-- Brand cluster -->
        <HorizontalStackLayout Grid.Column="0"
                               Spacing="10"
                               VerticalOptions="Center">
            <Image Source="kse_logo.png"
                   HeightRequest="22"
                   WidthRequest="22"
                   VerticalOptions="Center" />
            <Label Text="Kiesh Stock Exchange"
                   Style="{StaticResource BrandLabel}" />
        </HorizontalStackLayout>

        <!-- Centered nav links -->
        <HorizontalStackLayout Grid.Column="1"
                               Spacing="4"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
            <Button x:Name="MarketLink"
                    Text="Market"
                    Command="{Binding NavigateMarketCommand}"
                    Style="{StaticResource NavLinkButton}" />
            <Button x:Name="TradeLink"
                    Text="Trade"
                    Command="{Binding NavigateTradeCommand}"
                    Style="{StaticResource NavLinkButton}" />
            <Button x:Name="PortfolioLink"
                    Text="Portfolio"
                    Command="{Binding NavigatePortfolioCommand}"
                    Style="{StaticResource NavLinkButton}" />
            <Button x:Name="AccountLink"
                    Text="Account"
                    Command="{Binding NavigateAccountCommand}"
                    Style="{StaticResource NavLinkButton}" />
            <Button x:Name="AdminLink"
                    Text="Admin"
                    Command="{Binding NavigateAdminCommand}"
                    Style="{StaticResource NavLinkButton}" />
            <Button x:Name="BotsLink"
                    Text="Bots"
                    Command="{Binding NavigateBotsCommand}"
                    Style="{StaticResource NavLinkButton}" />
        </HorizontalStackLayout>

        <!-- Right cluster: Funds chip -->
        <Border Grid.Column="2"
                Style="{StaticResource FundsChipBorder}"
                VerticalOptions="Center">
            <HorizontalStackLayout Spacing="6"
                                   VerticalOptions="Center">
                <Label Text="Funds"
                       Style="{StaticResource FundsChipKeyLabel}"
                       VerticalTextAlignment="Center" />
                <Label Text="{Binding FundsDisplay}"
                       Style="{StaticResource FundsChipValueLabel}"
                       VerticalTextAlignment="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- 1 px divider at the bottom of the nav bar -->
        <BoxView Style="{StaticResource TopNavBarBottomBorder}"
                 Grid.ColumnSpan="3" />
    </Grid>
</ContentView>
