<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:navbar="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AccountViewModels"
             xmlns:theme="clr-namespace:KieshStockExchange.Services.OtherServices.Interfaces"
             x:Class="KieshStockExchange.Views.AccountPageViews.AccountPage"
             x:DataType="vm:AccountViewModel"
             Title="Account">

    <Grid Style="{StaticResource MainGrid}"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="8"
          Padding="0,0,0,8">

        <!-- Top nav -->
        <navbar:TopNavBarView Grid.Row="0"
                              BindingContext="{Binding TopNavBarVm}" />

        <!-- Page heading -->
        <Grid Grid.Row="1"
              Style="{StaticResource PageHeadingGrid}">
            <Label Grid.Column="0"
                   Text="Account"
                   Style="{StaticResource PageHeadingTitle}" />
            <Label Grid.Column="1"
                   Text="Profile, security and preferences"
                   Style="{StaticResource PageHeadingSub}" />
        </Grid>

        <!-- Body: two columns -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              Padding="24,0,24,0">

            <!-- LEFT column: Identity + Security -->
            <VerticalStackLayout Grid.Column="0"
                                 Spacing="12"
                                 VerticalOptions="Start">

                <!-- Identity card -->
                <Border Style="{StaticResource DashboardCardStyle}"
                        Padding="20">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Identity"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Username"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding UserName}"
                                   IsReadOnly="True"
                                   Style="{StaticResource FormEntryStyle}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Full name"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding FullName}"
                                   IsReadOnly="True"
                                   Style="{StaticResource FormEntryStyle}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Email"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding Email}"
                                   IsReadOnly="True"
                                   Style="{StaticResource FormEntryStyle}" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="24">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="4">
                                <Label Text="Date of birth"
                                       Style="{StaticResource FormLabelStyle}" />
                                <Label Text="{Binding BirthDateDisplay}"
                                       Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="Member since"
                                       Style="{StaticResource FormLabelStyle}" />
                                <Label Text="{Binding MemberSinceDisplay}"
                                       Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Security card -->
                <Border Style="{StaticResource DashboardCardStyle}"
                        Padding="20">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Security"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <Button Text="Change username"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding ChangeUsernameCommand}" />

                        <Button Text="Change email"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding ChangeEmailCommand}" />

                        <Button Text="Change password"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding ChangePasswordCommand}" />

                        <Button Text="Log out"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding LogoutCommand}" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- RIGHT column: Funds + Preferences -->
            <VerticalStackLayout Grid.Column="1"
                                 Spacing="12"
                                 VerticalOptions="Start">

                <!-- Funds card -->
                <Border Style="{StaticResource DashboardCardStyle}"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Available Funds"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <Label Text="{Binding FundsDisplay}"
                               Style="{StaticResource QuotePriceLabel}"
                               HorizontalOptions="Start" />

                        <Label Text="{Binding BaseCurrency}"
                               Style="{StaticResource MutedLabelStyle}" />

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              Margin="0,4,0,0">
                            <Button Grid.Column="0"
                                    Text="Deposit"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Command="{Binding OpenDepositWithdrawCommand}" />
                            <Button Grid.Column="1"
                                    Text="Withdraw"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Command="{Binding OpenDepositWithdrawCommand}" />
                        </Grid>

                        <Button Text="Convert currency"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding OpenConvertCurrencyCommand}" />

                        <Button Text="Transaction history"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding OpenFundHistoryCommand}" />

                    </VerticalStackLayout>
                </Border>

                <!-- Preferences card -->
                <Border Style="{StaticResource DashboardCardStyle}"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Preferences"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Theme"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Picker x:Name="ThemePicker"
                                    Style="{StaticResource ThemePickerStyle}">
                                <Picker.ItemDisplayBinding>
                                    <Binding Path="DisplayName"
                                             x:DataType="theme:ThemeOption" />
                                </Picker.ItemDisplayBinding>
                            </Picker>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Base currency"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Picker Style="{StaticResource ThemePickerStyle}"
                                    ItemsSource="{Binding AvailableCurrencies}"
                                    SelectedItem="{Binding SelectedBaseCurrency, Mode=TwoWay}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
