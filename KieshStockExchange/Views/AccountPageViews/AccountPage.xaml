<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:navbar="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AccountViewModels"
             xmlns:theme="clr-namespace:KieshStockExchange.Services.OtherServices.Interfaces"
             x:Class="KieshStockExchange.Views.AccountPageViews.AccountPage"
             x:DataType="vm:AccountViewModel"
             Title="Account">

    <Grid Style="{StaticResource MainGrid}"
          RowDefinitions="Auto,*"
          RowSpacing="8"
          Padding="0,0,0,8">

        <!-- Top nav -->
        <navbar:TopNavBarView Grid.Row="0"
                              BindingContext="{Binding TopNavBarVm}" />

        <!-- Toast overlay (top-right of content area; passes clicks through empty space) -->
        <navbar:ToastHostView Grid.Row="1" Grid.RowSpan="5"
                              VerticalOptions="Start" HorizontalOptions="End"
                              Margin="0,8,16,0"
                              ZIndex="200" />

        <!-- Body: two columns, scrollable. Inside ScrollView the inner Grids see infinite
             vertical space, so card rows are Auto-sized; each Border carries a MinimumHeightRequest
             so the cards keep a substantial presence even when their content is sparse. -->
        <ScrollView Grid.Row="1"
                    Padding="24,0,24,0">
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

            <!-- LEFT column: Identity + Preferences -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="12">

                <!-- Identity card -->
                <Border Grid.Row="0"
                        Style="{StaticResource DashboardCardStyle}"
                        MinimumHeightRequest="340"
                        Padding="20">
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Identity"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Username"
                                       Style="{StaticResource FormLabelStyle}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="✎"
                                        Style="{StaticResource TradeTableButton}"
                                        Command="{Binding ChangeUsernameCommand}" />
                            </Grid>
                            <Entry Text="{Binding UserName}"
                                   IsReadOnly="True"
                                   Style="{StaticResource FormEntryStyle}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Full name"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding FullName}"
                                   IsReadOnly="True"
                                   Style="{StaticResource FormEntryStyle}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Email"
                                       Style="{StaticResource FormLabelStyle}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="✎"
                                        Style="{StaticResource TradeTableButton}"
                                        Command="{Binding ChangeEmailCommand}" />
                            </Grid>
                            <Entry Text="{Binding Email}"
                                   IsReadOnly="True"
                                   Style="{StaticResource FormEntryStyle}" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="24">
                            <VerticalStackLayout Grid.Column="0"
                                                 Spacing="4">
                                <Label Text="Date of birth"
                                       Style="{StaticResource FormLabelStyle}" />
                                <Label Text="{Binding BirthDateDisplay}"
                                       Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="4">
                                <Label Text="Member since"
                                       Style="{StaticResource FormLabelStyle}" />
                                <Label Text="{Binding MemberSinceDisplay}"
                                       Style="{StaticResource MutedLabelStyle}" />
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Preferences card -->
                <Border Grid.Row="1"
                        Style="{StaticResource DashboardCardStyle}"
                        MinimumHeightRequest="200"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Preferences"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Theme"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Picker x:Name="ThemePicker"
                                    Style="{StaticResource ThemePickerStyle}">
                                <Picker.ItemDisplayBinding>
                                    <Binding Path="DisplayName"
                                             x:DataType="theme:ThemeOption" />
                                </Picker.ItemDisplayBinding>
                            </Picker>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Base currency"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Picker Style="{StaticResource ThemePickerStyle}"
                                    ItemsSource="{Binding AvailableCurrencies}"
                                    SelectedItem="{Binding SelectedBaseCurrency, Mode=TwoWay}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- RIGHT column: Funds + Activity + Security -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="12">

                <!-- Funds card -->
                <Border Grid.Row="0"
                        Style="{StaticResource DashboardCardStyle}"
                        MinimumHeightRequest="340"
                        Padding="20">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Available Funds"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <Label Text="{Binding FundsDisplay}"
                               Style="{StaticResource QuotePriceLabel}"
                               HorizontalOptions="Start" />

                        <Label Text="{Binding BaseCurrency}"
                               Style="{StaticResource MutedLabelStyle}" />

                        <!-- Reserved-in-base-currency: only visible when > 0; "Reserved $0" would be noise. -->
                        <Label Text="{Binding ReservedDisplay}"
                               IsVisible="{Binding HasReserved}"
                               Style="{StaticResource MutedLabelStyle}"
                               FontSize="12" />

                        <!-- Sibling currencies: the user's OTHER non-zero funds, surfaced here so a
                             multi-currency user doesn't need to navigate to Portfolio to confirm a
                             balance. Hidden when the user only operates in one currency. -->
                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding HasOtherCurrencyFunds}"
                                             Margin="0,4,0,0">
                            <BoxView HeightRequest="1"
                                     Color="{DynamicResource Divider}"
                                     Margin="0,0,0,2" />
                            <Label Text="Other currencies"
                                   Style="{StaticResource MutedLabelStyle}"
                                   FontSize="11" />
                            <CollectionView ItemsSource="{Binding OtherCurrencyFunds}"
                                            SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AccountFundRow">
                                        <Grid ColumnDefinitions="Auto,*"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="8"
                                              Padding="0,3">
                                            <Label Grid.Row="0" Grid.Column="0"
                                                   Text="{Binding Currency}"
                                                   Style="{StaticResource FormLabelStyle}"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding AvailableDisplay}"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="End"
                                                   VerticalOptions="Center" />
                                            <Label Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding ReservedDisplay, StringFormat='reserved {0}'}"
                                                   IsVisible="{Binding HasReserved}"
                                                   Style="{StaticResource MutedLabelStyle}"
                                                   FontSize="10"
                                                   HorizontalOptions="End" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              Margin="0,4,0,0">
                            <Button Grid.Column="0"
                                    Text="Deposit"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Command="{Binding OpenDepositWithdrawCommand}" />
                            <Button Grid.Column="1"
                                    Text="Withdraw"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Command="{Binding OpenDepositWithdrawCommand}" />
                        </Grid>

                        <Button Text="Convert currency"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding OpenConvertCurrencyCommand}" />

                        <Button Text="Transaction history"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding OpenFundHistoryCommand}" />

                    </VerticalStackLayout>
                </Border>

                <!-- Activity card: read-only summary of historical trading. Sits between Funds
                     and Security so the money-related cards stay grouped. -->
                <Border Grid.Row="1"
                        Style="{StaticResource DashboardCardStyle}"
                        MinimumHeightRequest="260"
                        Padding="20">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Activity"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <!-- Empty state — shown only until the user has at least one trade. -->
                        <Label Text="No activity yet"
                               IsVisible="{Binding HasActivity, Converter={StaticResource InvertedBoolConverter}}"
                               Style="{StaticResource MutedLabelStyle}" />

                        <VerticalStackLayout Spacing="6"
                                             IsVisible="{Binding HasActivity}">

                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12"
                                  RowDefinitions="Auto,Auto"
                                  RowSpacing="6">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="Trades placed"
                                       Style="{StaticResource FormLabelStyle}" />
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding TradesPlaced}"
                                       FontAttributes="Bold"
                                       HorizontalOptions="End" />

                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="Stocks traded"
                                       Style="{StaticResource FormLabelStyle}" />
                                <Label Grid.Row="1" Grid.Column="1"
                                       Text="{Binding StocksTraded}"
                                       FontAttributes="Bold"
                                       HorizontalOptions="End" />
                            </Grid>

                            <!-- Per-currency volume: currencies don't sum, so each shows its own row.
                                 Same pattern as the Funds "Other currencies" sub-list above. -->
                            <VerticalStackLayout Spacing="4"
                                                 IsVisible="{Binding HasVolume}"
                                                 Margin="0,4,0,0">
                                <BoxView HeightRequest="1"
                                         Color="{DynamicResource Divider}"
                                         Margin="0,0,0,2" />
                                <Label Text="Volume traded"
                                       Style="{StaticResource MutedLabelStyle}"
                                       FontSize="11" />
                                <CollectionView ItemsSource="{Binding VolumeByCurrency}"
                                                SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AccountVolumeRow">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8"
                                                  Padding="0,2">
                                                <Label Grid.Column="0"
                                                       Text="{Binding Currency}"
                                                       Style="{StaticResource FormLabelStyle}"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding AmountDisplay}"
                                                       FontAttributes="Bold"
                                                       HorizontalOptions="End"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                            <!-- Realised P&L: weighted-avg cost basis per (stock, currency). One
                                 row per currency, coloured green/red on sign via DataTriggers. -->
                            <VerticalStackLayout Spacing="4"
                                                 IsVisible="{Binding HasPnL}"
                                                 Margin="0,4,0,0">
                                <BoxView HeightRequest="1"
                                         Color="{DynamicResource Divider}"
                                         Margin="0,0,0,2" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           Text="Realised P&amp;L"
                                           Style="{StaticResource MutedLabelStyle}"
                                           FontSize="11" />
                                    <Label Grid.Column="1"
                                           Text="approx."
                                           IsVisible="{Binding PnLIsApproximate}"
                                           Style="{StaticResource MutedLabelStyle}"
                                           FontSize="10" />
                                </Grid>
                                <CollectionView ItemsSource="{Binding PnLByCurrency}"
                                                SelectionMode="None">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AccountPnLRow">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8"
                                                  Padding="0,2">
                                                <Label Grid.Column="0"
                                                       Text="{Binding Currency}"
                                                       Style="{StaticResource FormLabelStyle}"
                                                       VerticalOptions="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding AmountDisplay}"
                                                       FontAttributes="Bold"
                                                       HorizontalOptions="End"
                                                       VerticalOptions="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsPositive}"
                                                                     Value="True">
                                                            <Setter Property="TextColor"
                                                                    Value="{DynamicResource BuyGreen}" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsNegative}"
                                                                     Value="True">
                                                            <Setter Property="TextColor"
                                                                    Value="{DynamicResource SellRed}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>
                            </VerticalStackLayout>

                            <!-- Best / worst stock: gated independently — both hidden until a
                                 positive (or negative) ledger exists. -->
                            <VerticalStackLayout Spacing="4"
                                                 IsVisible="{Binding HasBestStock}"
                                                 Margin="0,4,0,0">
                                <Label Text="Best stock"
                                       Style="{StaticResource MutedLabelStyle}"
                                       FontSize="11" />
                                <Label Text="{Binding BestStockDisplay}"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource BuyGreen}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="4"
                                                 IsVisible="{Binding HasWorstStock}">
                                <Label Text="Worst stock"
                                       Style="{StaticResource MutedLabelStyle}"
                                       FontSize="11" />
                                <Label Text="{Binding WorstStockDisplay}"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource SellRed}" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Security card -->
                <Border Grid.Row="2"
                        Style="{StaticResource DashboardCardStyle}"
                        MinimumHeightRequest="160"
                        Padding="20">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="Security"
                               Style="{StaticResource SectionHeaderLabelStyle}" />

                        <Button Text="Change password"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding ChangePasswordCommand}" />

                        <Button Text="Log out"
                                Style="{StaticResource SecondaryActionButtonStyle}"
                                Command="{Binding LogoutCommand}" />

                    </VerticalStackLayout>
                </Border>

            </Grid>
            </Grid>
        </ScrollView>
    </Grid>
</ContentPage>
