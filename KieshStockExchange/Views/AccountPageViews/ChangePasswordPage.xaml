<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AccountViewModels"
               x:Class="KieshStockExchange.Views.AccountPageViews.ChangePasswordPage"
               x:DataType="vm:ChangePasswordViewModel"
               Color="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border Style="{StaticResource DashboardCardStyle}"
            Padding="22"
            WidthRequest="480">
        <VerticalStackLayout Spacing="14">

            <Label Text="Change Password"
                   Style="{StaticResource SectionHeaderLabelStyle}" />

            <Label Text="Enter your current password to set a new one."
                   Style="{StaticResource MutedLabelStyle}" />

            <VerticalStackLayout Spacing="4">
                <Label Text="Current password"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding CurrentPassword}"
                       IsPassword="True"
                       Placeholder="Enter current password"
                       Style="{StaticResource FormEntryStyle}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="New password"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding NewPassword}"
                       IsPassword="True"
                       Placeholder="At least 8 characters"
                       Style="{StaticResource FormEntryStyle}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="4">
                <Label Text="Confirm new password"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding ConfirmPassword}"
                       IsPassword="True"
                       Placeholder="Repeat new password"
                       Style="{StaticResource FormEntryStyle}" />
            </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource RegistrationErrorLabel}"
                   IsVisible="{Binding HasError}" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="8"
                  Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Text="Save"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                <Button Grid.Column="1"
                        Text="Cancel"
                        Style="{StaticResource SecondaryActionButtonStyle}"
                        Command="{Binding CancelCommand}" />
            </Grid>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
