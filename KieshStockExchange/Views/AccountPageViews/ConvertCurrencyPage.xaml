<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AccountViewModels"
               x:Class="KieshStockExchange.Views.AccountPageViews.ConvertCurrencyPage"
               x:DataType="vm:ConvertCurrencyViewModel"
               Color="Transparent"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Border Style="{StaticResource DashboardCardStyle}"
            Padding="20"
            WidthRequest="560">
        <ScrollView MaximumHeightRequest="640">
            <VerticalStackLayout Spacing="10">

                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Convert currency"
                           Style="{StaticResource SectionHeaderLabelStyle}" />
                    <Button Grid.Column="1"
                            Text="X"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            WidthRequest="32"
                            HeightRequest="32"
                            Padding="0"
                            Command="{Binding CancelCommand}" />
                </Grid>

                <Label Text="Move cash between two of your funds. The rate shown is the static reference rate; the converted amount is rounded to the target currency."
                       Style="{StaticResource MutedLabelStyle}" />

                <!-- From / To pickers side-by-side to cut vertical height. -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="From" Style="{StaticResource FormLabelStyle}" />
                        <Picker ItemsSource="{Binding AvailableCurrencies}"
                                SelectedItem="{Binding FromCurrency, Mode=TwoWay}"
                                Style="{StaticResource ThemePickerStyle}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="To" Style="{StaticResource FormLabelStyle}" />
                        <Picker ItemsSource="{Binding AvailableCurrencies}"
                                SelectedItem="{Binding ToCurrency, Mode=TwoWay}"
                                Style="{StaticResource ThemePickerStyle}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="2">
                    <Label Text="Available balance" Style="{StaticResource FormLabelStyle}" />
                    <Label Text="{Binding AvailableBalanceDisplay}" Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>

                <!-- Amount / You-receive side-by-side for the same reason. -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Amount" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding AmountString}"
                               Keyboard="Numeric"
                               Placeholder="0.00"
                               Style="{StaticResource FormEntryStyle}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="You receive" Style="{StaticResource FormLabelStyle}" />
                        <Label Text="{Binding ConvertedAmountDisplay}" Style="{StaticResource QuotePriceLabel}" />
                        <Label Text="{Binding RateDisplay}" Style="{StaticResource MutedLabelStyle}" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Note (optional)" Style="{StaticResource FormLabelStyle}" />
                    <Entry Text="{Binding Note}"
                           Placeholder="Reason or reference"
                           Style="{StaticResource FormEntryStyle}" />
                </VerticalStackLayout>

                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource RegistrationErrorLabel}"
                       IsVisible="{Binding HasError}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="8"
                      Margin="0,4,0,0">
                    <Button Grid.Column="0"
                            Text="Convert"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding ConvertCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    <Button Grid.Column="1"
                            Text="Cancel"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding CancelCommand}" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Border>
</toolkit:Popup>
