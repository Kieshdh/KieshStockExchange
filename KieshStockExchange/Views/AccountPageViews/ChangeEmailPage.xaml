<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.AccountPageViews.ChangeEmailPage"
             Title="Change Email">

    <Grid Style="{StaticResource MainGrid}"
          Padding="20">
        <Border Style="{StaticResource DashboardCardStyle}"
                Padding="22"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
            <VerticalStackLayout Spacing="14">

                <Label Text="Change Email"
                       Style="{StaticResource SectionHeaderLabelStyle}" />

                <Label Text="Confirm your password to update your email address."
                       Style="{StaticResource MutedLabelStyle}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="New email address"
                           Style="{StaticResource FormLabelStyle}" />
                    <Entry Text="{Binding NewEmail}"
                           Keyboard="Email"
                           Placeholder="Enter new email"
                           Style="{StaticResource FormEntryStyle}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Current password"
                           Style="{StaticResource FormLabelStyle}" />
                    <Entry Text="{Binding CurrentPassword}"
                           IsPassword="True"
                           Placeholder="Confirm with your password"
                           Style="{StaticResource FormEntryStyle}" />
                </VerticalStackLayout>

                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource RegistrationErrorLabel}"
                       IsVisible="{Binding HasError}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="8"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Text="Save"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    <Button Grid.Column="1"
                            Text="Cancel"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding CancelCommand}" />
                </Grid>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
