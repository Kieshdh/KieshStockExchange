<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.AdminPageViews.Tables.SortableHeader"
             x:Name="Root">
    <Border Style="{StaticResource SortableHeaderButton}">
        <HorizontalStackLayout Spacing="4"
                               VerticalOptions="Center"
                               HorizontalOptions="Center">
            <Label Text="{Binding Text, Source={x:Reference Root}}"
                   Style="{StaticResource TableHeaderLabel}"
                   VerticalOptions="Center" />
            <Label Text="{Binding ArrowGlyph, Source={x:Reference Root}}"
                   Style="{StaticResource SortableHeaderArrow}"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnTapped" />
        </Border.GestureRecognizers>
    </Border>
</ContentView>
