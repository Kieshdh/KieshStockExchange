<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.AdminPageViews.AdminPage"
             x:Name="AdminPageRoot"
             xmlns:local="clr-namespace:KieshStockExchange.ViewModels.AdminViewModels"
             xmlns:adminViews="clr-namespace:KieshStockExchange.Views.AdminPageViews"
             xmlns:navbar="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:other="clr-namespace:KieshStockExchange.Views.OtherViews"
             Title="Admin"
             x:DataType="local:AdminViewModel">

    <Grid Style="{StaticResource MainGrid}"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="8"
          Padding="0,0,0,8">

        <!-- Row 0: Top nav -->
        <navbar:TopNavBarView Grid.Row="0"
                              BindingContext="{Binding TopNavBarVm}" />

        <!-- Toast overlay (top-right of content area; passes clicks through empty space) -->
        <other:ToastHostView Grid.Row="1" Grid.RowSpan="5"
                             VerticalOptions="Start" HorizontalOptions="End"
                             Margin="0,8,16,0"
                             ZIndex="200" />

        <!-- Row 1: Page heading -->
        <Grid Grid.Row="1" Style="{StaticResource PageHeadingGrid}">
            <Label Grid.Column="0"
                   Text="Admin"
                   Style="{StaticResource PageHeadingTitle}" />
            <Label Grid.Column="1"
                   Text="Manage users, stocks, orders, and balances"
                   Style="{StaticResource PageHeadingSub}" />
        </Grid>

        <!-- Row 2: Tab area with loading overlay on top -->
        <Grid Grid.Row="2" Margin="24,0,24,0">

            <!-- Tab content (hidden while loading) -->
            <Border Style="{StaticResource TradeContentOutline}"
                    Padding="0"
                    IsVisible="{Binding DoneLoading}">
                <other:SegmentedTabView
                        HeaderContainerHorizontalOptions="Start"
                        ContainerStyle="{StaticResource SegmentedRailContainer}"
                        SelectedButtonStyle="{StaticResource RailSegmentSelected}"
                        UnselectedButtonStyle="{StaticResource RailSegmentUnselected}"
                        ShowUnderline="True"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">

                    <other:SegmentedTabView.HeaderRightContent>
                        <Button x:Name="RefreshButton"
                                Text="↻ Refresh"
                                Style="{StaticResource AdminRefreshButton}" />
                    </other:SegmentedTabView.HeaderRightContent>

                    <other:SegmentedTabView.Tabs>

                        <!-- Tab BindingContexts + Refresh.Command wired in code-behind. -->
                        <other:SegmentedTabItem Header="Users">
                            <other:SegmentedTabItem.Content>
                                <adminViews:UserTableView x:Name="UsersTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <other:SegmentedTabItem Header="Stocks">
                            <other:SegmentedTabItem.Content>
                                <adminViews:StockTableView x:Name="StocksTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <other:SegmentedTabItem Header="Orders">
                            <other:SegmentedTabItem.Content>
                                <adminViews:OrderTableView x:Name="OrdersTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <other:SegmentedTabItem Header="Transactions">
                            <other:SegmentedTabItem.Content>
                                <adminViews:TransactionTableView x:Name="TransactionsTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <other:SegmentedTabItem Header="Funds">
                            <other:SegmentedTabItem.Content>
                                <adminViews:FundTableView x:Name="FundsTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <other:SegmentedTabItem Header="Positions">
                            <other:SegmentedTabItem.Content>
                                <adminViews:PositionTableView x:Name="PositionsTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                    </other:SegmentedTabView.Tabs>
                </other:SegmentedTabView>
            </Border>

            <!-- Loading overlay floats on top while IsLoading is true -->
            <Border Style="{StaticResource AdminLoadingOverlay}"
                    IsVisible="{Binding IsLoading}">
                <VerticalStackLayout Spacing="12"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                    <ActivityIndicator Style="{StaticResource AdminLoadingActivity}"
                                       IsRunning="{Binding IsLoading}" />
                    <Label Text="{Binding LoadingText}"
                           Style="{StaticResource AdminMetricValue}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </Grid>
    </Grid>
</ContentPage>
