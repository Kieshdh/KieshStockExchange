<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AdminViewModels"
             xmlns:navbar="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:other="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:adminViews="clr-namespace:KieshStockExchange.Views.AdminPageViews"
             x:Class="KieshStockExchange.Views.AdminPageViews.BotDashboardPage"
             x:Name="BotDashboardPageRoot"
             Title="Bot Dashboard"
             x:DataType="vm:BotDashboardViewModel">

    <Grid Style="{StaticResource MainGrid}"
          RowDefinitions="Auto,*"
          RowSpacing="8"
          Padding="0,0,0,8">

        <!-- Top nav -->
        <navbar:TopNavBarView Grid.Row="0"
                              BindingContext="{Binding TopNavBarVm}" />

        <!-- Toast overlay (top-right of content area; passes clicks through empty space) -->
        <navbar:ToastHostView Grid.Row="1" Grid.RowSpan="5"
                              VerticalOptions="Start" HorizontalOptions="End"
                              Margin="0,8,16,0"
                              ZIndex="200" />

        <!-- Bot dashboard body -->
        <ScrollView Grid.Row="1" Padding="24,0,24,0">
            <VerticalStackLayout Spacing="10">

                <!-- Header row: title + status + start/stop -->
                <Border Style="{StaticResource AdminCardStyle}">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="AI Bot Dashboard"
                               Style="{StaticResource AdminCardTitle}" />

                        <Ellipse Grid.Column="1" Style="{StaticResource AdminStatusDot.Online}"
                                 IsVisible="{Binding IsRunning}" />
                        <Ellipse Grid.Column="1" Style="{StaticResource AdminStatusDot.Offline}"
                                 IsVisible="{Binding IsRunning, Converter={StaticResource InvertedBoolConverter}}" />

                        <Label Grid.Column="2" Text="{Binding StatusText}"
                               Style="{StaticResource AdminMetricValue}" />

                        <Button Grid.Column="4" Text="Start"
                                Style="{StaticResource AdminPrimaryButton}"
                                Command="{Binding StartBotsCommand}"
                                IsVisible="{Binding IsRunning, Converter={StaticResource InvertedBoolConverter}}" />
                        <Button Grid.Column="5" Text="Stop"
                                Style="{StaticResource AdminDangerButton}"
                                Command="{Binding StopBotsCommand}"
                                IsVisible="{Binding IsRunning}" />
                    </Grid>
                </Border>

                <!-- KPI stack on the left, bot activity chart on the right. -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="12,0">
                    <VerticalStackLayout Grid.Column="0" Spacing="10" MinimumWidthRequest="180">
                        <Border Style="{StaticResource AdminBotStatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Active / Max" Style="{StaticResource AdminBotStatLabel}" />
                                <Label Text="{Binding BotCapDisplay}" Style="{StaticResource AdminBotStatValue}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource AdminBotStatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Tick" Style="{StaticResource AdminBotStatLabel}" />
                                <Label Text="{Binding TickCount, StringFormat='{0:N0}'}" Style="{StaticResource AdminBotStatValue}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource AdminBotStatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Trades" Style="{StaticResource AdminBotStatLabel}" />
                                <Label Text="{Binding TradesPlaced, StringFormat='{0:N0}'}" Style="{StaticResource AdminBotStatValue}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource AdminBotStatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Failures" Style="{StaticResource AdminBotStatLabel}" />
                                <Label Text="{Binding Failures, StringFormat='{0:N0}'}" Style="{StaticResource AdminBotStatValue}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource AdminBotStatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Uptime" Style="{StaticResource AdminBotStatLabel}" />
                                <Label Text="{Binding UptimeText}" Style="{StaticResource AdminBotStatValue}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Style="{StaticResource AdminBotStatCard}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Last fill" Style="{StaticResource AdminBotStatLabel}" />
                                <Label Text="{Binding LastTradeText}" Style="{StaticResource AdminBotStatValue}" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Bot activity: single chart with series + range pickers. -->
                    <Border Grid.Column="1" Style="{StaticResource AdminCardStyle}">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="Bot activity"
                                       Style="{StaticResource AdminCardSubtitle}"
                                       VerticalOptions="Center" />
                                <other:SegmentedTabView Grid.Column="1"
                                    SelectedIndex="{Binding SeriesIndex, Mode=TwoWay}"
                                    SelectedButtonStyle="{StaticResource AdminSelectedSegment}"
                                    UnselectedButtonStyle="{StaticResource AdminUnselectedSegment}"
                                    HeaderContainerHorizontalOptions="Start"
                                    MinTabWidth="0"
                                    VerticalOptions="Center">
                                    <other:SegmentedTabView.Tabs>
                                        <other:SegmentedTabItem Header="Trades" />
                                        <other:SegmentedTabItem Header="Volume" />
                                        <other:SegmentedTabItem Header="Active" />
                                    </other:SegmentedTabView.Tabs>
                                </other:SegmentedTabView>
                                <other:SegmentedTabView Grid.Column="2"
                                    SelectedIndex="{Binding ActivityRangeIndex, Mode=TwoWay}"
                                    SelectedButtonStyle="{StaticResource AdminSelectedSegment}"
                                    UnselectedButtonStyle="{StaticResource AdminUnselectedSegment}"
                                    HeaderContainerHorizontalOptions="End"
                                    MinTabWidth="0"
                                    VerticalOptions="Center">
                                    <other:SegmentedTabView.Tabs>
                                        <other:SegmentedTabItem Header="15m" />
                                        <other:SegmentedTabItem Header="1h" />
                                        <other:SegmentedTabItem Header="6h" />
                                        <other:SegmentedTabItem Header="24h" />
                                    </other:SegmentedTabView.Tabs>
                                </other:SegmentedTabView>
                            </Grid>

                            <Label Text="{Binding CurrentSeriesCaption}" Style="{StaticResource AdminBotStatLabel}" />
                            <GraphicsView x:Name="ActivityChart" HeightRequest="280" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Bot scaler + 24h stats side-by-side. -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">

                <!-- Scaler controls -->
                <Border Grid.Column="0" Style="{StaticResource AdminCardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Bot scaler" Style="{StaticResource AdminCardSubtitle}" />

                        <Grid ColumnDefinitions="Auto,120,Auto,Auto,Auto,120,Auto,Auto,*" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="Max cap"
                                   Style="{StaticResource AdminMetricLabel}"
                                   VerticalOptions="Center" />
                            <Entry Grid.Column="1" Style="{StaticResource AdminEntry}"
                                   Keyboard="Numeric" Placeholder="no cap"
                                   Text="{Binding MaxBotCapText, Mode=TwoWay}" />
                            <Button Grid.Column="2" Text="Apply"
                                    Style="{StaticResource AdminPrimaryButton}"
                                    Command="{Binding ApplyMaxBotCapCommand}" />

                            <BoxView Grid.Column="3" WidthRequest="1" Margin="8,4"
                                     Color="{StaticResource Gray400}" />

                            <Label Grid.Column="4" Text="Min cap"
                                   Style="{StaticResource AdminMetricLabel}"
                                   VerticalOptions="Center" />
                            <Entry Grid.Column="5" Style="{StaticResource AdminEntry}"
                                   Keyboard="Numeric" Placeholder="0"
                                   Text="{Binding MinBotCapText, Mode=TwoWay}" />
                            <Button Grid.Column="6" Text="Apply"
                                    Style="{StaticResource AdminPrimaryButton}"
                                    Command="{Binding ApplyMinBotCapCommand}" />
                        </Grid>

                        <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="Auto-scale"
                                   Style="{StaticResource AdminMetricLabel}"
                                   VerticalOptions="Center" />
                            <Switch Grid.Column="1" IsToggled="{Binding ScalerEnabled, Mode=TwoWay}"
                                    VerticalOptions="Center" />
                            <Label Grid.Column="2"
                                   Text="{Binding ScalerEnabled, StringFormat='{0}'}"
                                   Style="{StaticResource AdminMetricValue}"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="4" Text="Load"
                                   Style="{StaticResource AdminMetricLabel}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="5" Text="{Binding LoadFractionText}"
                                   Style="{StaticResource AdminMetricValue}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Label Text="{Binding TickLatencyText, StringFormat='Tick work EWMA: {0}'}"
                               Style="{StaticResource AdminMutedNote}" />
                    </VerticalStackLayout>
                </Border>

                <!-- 24h stats -->
                <Border Grid.Column="1" Style="{StaticResource AdminCardStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="Last 24h"
                                   Style="{StaticResource AdminCardSubtitle}"
                                   VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="Refresh"
                                    Style="{StaticResource AdminGhostButton}"
                                    Command="{Binding Refresh24hStatsCommand}"
                                    MinimumWidthRequest="70" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="16">
                            <Label Grid.Column="0" Text="Trades"
                                   Style="{StaticResource AdminBotStatLabel}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding Last24hTrades, StringFormat='{0:N0}'}"
                                   Style="{StaticResource AdminMetricValue}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="Volume"
                                   Style="{StaticResource AdminBotStatLabel}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="{Binding Last24hVolumeText}"
                                   Style="{StaticResource AdminMetricValue}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="4" Text="Active bots"
                                   Style="{StaticResource AdminBotStatLabel}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="5" Text="{Binding Last24hActiveBots, StringFormat='{0:N0}'}"
                                   Style="{StaticResource AdminMetricValue}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                </Grid>

                <!-- Failure breakdown (reasons + top stocks) -->
                <Border Style="{StaticResource AdminCardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Failure breakdown"
                               Style="{StaticResource AdminCardSubtitle}" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border Grid.Column="0" Style="{StaticResource AdminInsetPanel}">
                                <Label Text="{Binding FailuresByReasonText}"
                                       Style="{StaticResource AdminMutedNote}" />
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource AdminInsetPanel}">
                                <Label Text="{Binding FailuresByStockText}"
                                       Style="{StaticResource AdminMutedNote}" />
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- CSV exports: four side-by-side cards -->
                <Grid ColumnDefinitions="*,*,*,*"
                      ColumnSpacing="10"
                      Padding="12,0">

                    <Border Grid.Column="0" Style="{StaticResource AdminCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Failures"
                                   Style="{StaticResource AdminCardSubtitle}" />
                            <Button Text="Export CSV"
                                    Style="{StaticResource AdminPrimaryButton}"
                                    Command="{Binding ExportFailuresCommand}"
                                    HorizontalOptions="Start"
                                    MinimumWidthRequest="120" />
                            <Label Text="{Binding ExportFailuresStatusText}"
                                   Style="{StaticResource AdminMutedNote}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource AdminCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Economy snapshots"
                                   Style="{StaticResource AdminCardSubtitle}" />
                            <Button Text="Export CSV"
                                    Style="{StaticResource AdminPrimaryButton}"
                                    Command="{Binding ExportEconomyCommand}"
                                    HorizontalOptions="Start"
                                    MinimumWidthRequest="120" />
                            <Label Text="{Binding ExportEconomyStatusText}"
                                   Style="{StaticResource AdminMutedNote}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource AdminCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Sentiment snapshots"
                                   Style="{StaticResource AdminCardSubtitle}" />
                            <Button Text="Export CSV"
                                    Style="{StaticResource AdminPrimaryButton}"
                                    Command="{Binding ExportSentimentCommand}"
                                    HorizontalOptions="Start"
                                    MinimumWidthRequest="120" />
                            <Label Text="{Binding ExportSentimentStatusText}"
                                   Style="{StaticResource AdminMutedNote}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource AdminCardStyle}">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Reservation ledger"
                                   Style="{StaticResource AdminCardSubtitle}" />
                            <Button Text="Export CSV"
                                    Style="{StaticResource AdminPrimaryButton}"
                                    Command="{Binding ExportLedgerCommand}"
                                    HorizontalOptions="Start"
                                    MinimumWidthRequest="120" />
                            <Label Text="{Binding ExportLedgerStatusText}"
                                   Style="{StaticResource AdminMutedNote}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Recent failures (last 100, scrollable) -->
                <Border Style="{StaticResource AdminCardStyle}">
                    <Border Style="{StaticResource AdminInsetPanel}">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Recent failures (last 100)"
                                   Style="{StaticResource AdminMetricLabel}" />
                            <ScrollView MaximumHeightRequest="240">
                                <Label Text="{Binding RecentFailuresText}"
                                       Style="{StaticResource AdminMutedNote}" />
                            </ScrollView>
                        </VerticalStackLayout>
                    </Border>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
