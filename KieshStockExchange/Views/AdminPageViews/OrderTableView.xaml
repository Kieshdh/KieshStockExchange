<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AdminViewModels"
             x:Class="KieshStockExchange.Views.AdminPageViews.OrderTableView"
             x:Name="OrderTableRoot"
             x:DataType="vm:OrderTableViewModel">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Column headers -->
        <Grid ColumnDefinitions="50, 5*, 3*, 2*, 3*, 3*, 3*, 3*, 3*, 5*, 3"
              Style="{StaticResource TableHeaderGrid}">
            <Label Text="ID"          Grid.Column="0"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Created"     Grid.Column="1"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Username"    Grid.Column="2"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Symbol"      Grid.Column="3"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="OrderType"   Grid.Column="4"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Price"       Grid.Column="5"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Quantity"    Grid.Column="6"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Total Price" Grid.Column="7"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="Status"      Grid.Column="8"  Style="{StaticResource TableHeaderLabel}"/>
            <Label Text="LastUpdated" Grid.Column="9"  Style="{StaticResource TableHeaderLabel}"/>
        </Grid>

        <!-- Date range + status filter toolbar -->
        <HorizontalStackLayout Grid.Row="1" Spacing="8" Padding="10,4">
            <Label Text="From:" VerticalOptions="Center"/>
            <DatePicker Date="{Binding FromDate, Mode=TwoWay}" VerticalOptions="Center"/>
            <Label Text="To:" VerticalOptions="Center"/>
            <DatePicker Date="{Binding ToDate, Mode=TwoWay}" VerticalOptions="Center"/>
            <Button Text="7d"  Command="{Binding SetLast7DaysCommand}"  Style="{StaticResource TableSortingButton}"/>
            <Button Text="30d" Command="{Binding SetLast30DaysCommand}" Style="{StaticResource TableSortingButton}"/>
            <Button Text="All" Command="{Binding SetAllTimeCommand}"    Style="{StaticResource TableSortingButton}"/>
            <Label Text="Status:" VerticalOptions="Center"/>
            <Picker SelectedItem="{Binding StatusFilter, Mode=TwoWay}" VerticalOptions="Center" MinimumWidthRequest="120">
                <Picker.Items>
                    <x:String></x:String>
                    <x:String>Open</x:String>
                    <x:String>Filled</x:String>
                    <x:String>Cancelled</x:String>
                </Picker.Items>
            </Picker>
        </HorizontalStackLayout>

        <!-- CollectionView with a centred loading spinner overlay while a page loads -->
        <Grid Grid.Row="2">
        <CollectionView ItemsSource="{Binding PagedItems}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:OrderTableObject">
                    <Grid ColumnDefinitions="50, 5*, 3*, 2*, 3*, 3*, 3*, 3*, 3*, 5*, 3"
                          Style="{StaticResource TableRowGrid}">
                        <Label Text="{Binding Order.OrderId}"          Grid.Column="0"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.CreatedAtDisplay}"  Grid.Column="1"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding User.Username}"           Grid.Column="2"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Stock.Symbol}"            Grid.Column="3"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.OrderType}"         Grid.Column="4"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.PriceDisplay}"      Grid.Column="5"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.Quantity}"          Grid.Column="6"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.TotalAmountDisplay}" Grid.Column="7" Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.Status}"            Grid.Column="8"  Style="{StaticResource TableRowLabel}"/>
                        <Label Text="{Binding Order.UpdatedAtDisplay}"  Grid.Column="9"  Style="{StaticResource TableRowLabel}"/>

                        <BoxView Grid.Column="0"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="1"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="2"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="3"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="4"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="5"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="6"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="7"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="8"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="9"  Style="{StaticResource TableVerticalSeparator}"/>
                        <BoxView Grid.Column="10" Style="{StaticResource TableVerticalSeparator}"/>

                        <BoxView Style="{StaticResource TableHorizontalSeparator}"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="40"
                               HeightRequest="40" />
        </Grid>

        <!-- Pager -->
        <HorizontalStackLayout Style="{StaticResource PageNumberStackLayout}" Grid.Row="3"
                    BindableLayout.ItemsSource="{Binding VisiblePageNumbers}">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="vm:PageButton">
                    <Button Text="{Binding Page}"
                            Command="{Binding GoToCommand}"
                            CommandParameter="{Binding Page}"
                            Style="{StaticResource PageNumberButton}"/>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </HorizontalStackLayout>

    </Grid>
</ContentView>
