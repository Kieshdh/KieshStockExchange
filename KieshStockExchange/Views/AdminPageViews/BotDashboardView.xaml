<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.AdminViewModels"
             x:Class="KieshStockExchange.Views.AdminPageViews.BotDashboardView"
             x:DataType="vm:BotDashboardViewModel">
    <Border Style="{StaticResource AdminCardStyle}">
        <VerticalStackLayout Spacing="10">

            <!-- Header row: title + status + start/stop -->
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="8">
                <Label Grid.Column="0" Text="AI Bot Dashboard"
                       Style="{StaticResource AdminCardTitle}" />

                <Ellipse Grid.Column="1" Style="{StaticResource AdminStatusDot.Online}"
                         IsVisible="{Binding IsRunning}" />
                <Ellipse Grid.Column="1" Style="{StaticResource AdminStatusDot.Offline}"
                         IsVisible="{Binding IsRunning, Converter={StaticResource InvertedBoolConverter}}" />

                <Label Grid.Column="2" Text="{Binding StatusText}"
                       Style="{StaticResource AdminMetricValue}" />

                <Button Grid.Column="4" Text="Start"
                        Style="{StaticResource AdminPrimaryButton}"
                        Command="{Binding StartBotsCommand}"
                        IsVisible="{Binding IsRunning, Converter={StaticResource InvertedBoolConverter}}" />
                <Button Grid.Column="5" Text="Stop"
                        Style="{StaticResource AdminDangerButton}"
                        Command="{Binding StopBotsCommand}"
                        IsVisible="{Binding IsRunning}" />
            </Grid>

            <Border Style="{StaticResource AdminCardDivider}" />

            <!-- Live metrics grid: 4 cells per row, alternating label/value -->
            <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                  RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnSpacing="12" RowSpacing="6">

                <Label Grid.Row="0" Grid.Column="0" Text="Loaded"   Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="0" Grid.Column="1" Text="{Binding LoadedBots}" Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Row="0" Grid.Column="2" Text="Online"   Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="0" Grid.Column="3" Text="{Binding OnlineBots}" Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Row="0" Grid.Column="4" Text="Cap"      Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="0" Grid.Column="5" Text="{Binding ActiveBotCap, TargetNullValue=none, FallbackValue=none}"
                       Style="{StaticResource AdminMetricValue}" />

                <Label Grid.Row="1" Grid.Column="0" Text="Tick"     Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="1" Grid.Column="1" Text="{Binding TickCount}"   Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Row="1" Grid.Column="2" Text="Uptime"   Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="1" Grid.Column="3" Text="{Binding UptimeText}"  Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Row="1" Grid.Column="4" Text="Last fill" Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="1" Grid.Column="5" Text="{Binding LastTradeText}" Style="{StaticResource AdminMetricValue}" />

                <Label Grid.Row="2" Grid.Column="0" Text="Trades"   Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="2" Grid.Column="1" Text="{Binding TradesPlaced}" Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Row="2" Grid.Column="2" Text="Failures" Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Row="2" Grid.Column="3" Text="{Binding Failures}"     Style="{StaticResource AdminMetricValue}" />
            </Grid>

            <Border Style="{StaticResource AdminCardDivider}" />

            <!-- Cap setter row -->
            <Grid ColumnDefinitions="Auto,120,Auto,Auto,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Active bot cap"
                       Style="{StaticResource AdminMetricLabel}"
                       VerticalOptions="Center" />
                <Entry Grid.Column="1" Style="{StaticResource AdminEntry}"
                       Keyboard="Numeric" Placeholder="leave blank = no cap"
                       Text="{Binding BotCapText, Mode=TwoWay}" />
                <Button Grid.Column="2" Text="Apply"
                        Style="{StaticResource AdminPrimaryButton}"
                        Command="{Binding ApplyBotCapCommand}" />
                <Label Grid.Column="4" Text="Capped at runtime; resets on app restart."
                       Style="{StaticResource AdminMetricLabel}"
                       HorizontalOptions="End" VerticalOptions="Center" />
            </Grid>

            <Border Style="{StaticResource AdminCardDivider}" />

            <!-- 24h stats -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="12">
                <Label Grid.Column="0" Text="Last 24h"
                       Style="{StaticResource AdminCardSubtitle}" />
                <Button Grid.Column="1" Text="Refresh"
                        Style="{StaticResource AdminGhostButton}"
                        Command="{Binding Refresh24hStatsCommand}"
                        MinimumWidthRequest="70" />

                <Label Grid.Column="3" Text="Trades"  Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Column="4" Text="{Binding Last24hTrades}" Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Column="5" Text="Volume"  Style="{StaticResource AdminMetricLabel}" />
                <Label Grid.Column="6" Text="{Binding Last24hVolumeText}" Style="{StaticResource AdminMetricValue}" />
                <Label Grid.Column="7" Text="{Binding Last24hActiveBots, StringFormat='Active bots: {0}'}"
                       Style="{StaticResource AdminMetricValue}" />
            </Grid>

            <!-- Recent failures -->
            <Border Style="{StaticResource AdminInsetPanel}">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Recent failures" Style="{StaticResource AdminMetricLabel}" />
                    <Label Text="{Binding RecentFailuresText}"
                           Style="{StaticResource AdminMutedNote}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </Border>
</ContentView>
