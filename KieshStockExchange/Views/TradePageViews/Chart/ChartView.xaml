<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:style="clr-namespace:KieshStockExchange.Models.ChartDrawing.Style"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             xmlns:local="clr-namespace:KieshStockExchange.Views.TradePageViews"
             xmlns:tools="clr-namespace:KieshStockExchange.Models.ChartDrawing.Tools"
             x:Class="KieshStockExchange.Views.TradePageViews.ChartView"
             x:Name="ChartRoot"
             x:DataType="vm:ChartViewModel">

    <!-- The chart shell: it owns the candle GraphicsView + gesture handling and the canvas-only overlays
         (OHLCV, MA settings), and hosts the three extracted sub-views — ChartToolbarView (Row 0, inherits
         ChartViewModel) plus ChartToolRailView + ChartPenPanelView (Row 1, bound to the child Drawing VM).
         Child DECLARATION ORDER inside Row 1 is the Z-order: chart under the rail under the overlays under
         the pen panel. -->
    <Border BackgroundColor="{DynamicResource ChartBg}"
            Stroke="{DynamicResource Divider}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 10"
            Padding="0">
    <Grid RowDefinitions="Auto,*"
          BackgroundColor="Transparent"
          MinimumHeightRequest="300">

        <!-- Toolbar (spans the full width). Autofit + Snapshot bubble back to this view's code-behind. -->
        <local:ChartToolbarView Grid.Row="0"
                                YAutoFitRequested="OnYAutoFitClicked"
                                SnapshotRequested="OnSnapshotClicked" />

        <!-- Row 1: the left tool rail is a self-contained sidebar in col 0 (Auto width); the chart & its
             overlays fill col 1 ENTIRELY to its right. The group flyouts are separate col-1 overlays that
             hover over the chart (below). The toolbar (Row 0) spans the full width above both. -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

        <!-- Chart (Z-order bottom) -->
        <GraphicsView x:Name="Chart" Grid.Column="1"
                      Style="{StaticResource ChartSurface}">
            <GraphicsView.GestureRecognizers>
                <PanGestureRecognizer x:Name="ChartPan" />
                <PointerGestureRecognizer x:Name="ChartPointer" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- Left tool rail — a self-contained sidebar in col 0 only; the chart sits entirely to its right. -->
        <local:ChartToolRailView Grid.Column="0"
                                 BindingContext="{Binding Drawing}" />

        <!-- OHLCV overlay: top-left of the chart canvas. InputTransparent so
             pan / wheel gestures still reach the GraphicsView underneath. -->
        <HorizontalStackLayout Grid.Column="1"
                               VerticalOptions="Start"
                               HorizontalOptions="Start"
                               Margin="14,10,0,0"
                               Spacing="14"
                               InputTransparent="True">

            <HorizontalStackLayout Spacing="4">
                <Label Text="O" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.OpenDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="H" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.HighDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="L" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.LowDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="C" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.CloseDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcCloseValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="VOL" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.Volume, FallbackValue='', StringFormat='{0:N0}'}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

        </HorizontalStackLayout>

        <!-- MA settings overlay: anchored top-right of the chart canvas. -->
        <Border Grid.Column="1"
                IsVisible="{Binding IsMaSettingsOpen}"
                BackgroundColor="{DynamicResource ChartPanel}"
                Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                Padding="10"
                Margin="0,10,72,0"
                VerticalOptions="Start"
                HorizontalOptions="End"
                MinimumWidthRequest="380">
            <VerticalStackLayout Spacing="8">
                <Label Text="Moving averages" Style="{StaticResource ChartOhlcValue}" />
                <CollectionView ItemsSource="{Binding MaSeries}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MaConfig">
                            <Grid ColumnDefinitions="Auto,60,60,80,80,28"
                                  ColumnSpacing="8" Padding="0,4"
                                  HorizontalOptions="Fill">
                                <Switch Grid.Column="0" IsToggled="{Binding Enabled}" />
                                <Label Grid.Column="1" Text="{Binding Label}"
                                       Style="{StaticResource ChartOhlcValue}"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="2" Text="{Binding Period}" Keyboard="Numeric"
                                       FontSize="12" />
                                <Picker Grid.Column="3"
                                        ItemsSource="{Binding MaKinds}"
                                        SelectedItem="{Binding Kind}"
                                        FontSize="12" />
                                <Picker Grid.Column="4"
                                        ItemsSource="{Binding MaColorOptions}"
                                        SelectedItem="{Binding SelectedColorOption}"
                                        FontSize="12">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="Name" x:DataType="style:MaColorOption" />
                                    </Picker.ItemDisplayBinding>
                                </Picker>
                                <Button Grid.Column="5" Text="✕"
                                        Style="{StaticResource ChartIconButton}"
                                        Command="{Binding RemoveCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="+ Add MA"
                        Style="{StaticResource ChartLiveButton.Off}"
                        Command="{Binding AddMaCommand}" />

                <!-- Open-order line colours. Two pickers: one each for the buy
                     and sell limit lines drawn on the chart. Defaults to the
                     Bull/Bear theme colours (Binance/TradingView convention). -->
                <Label Text="Open orders" Style="{StaticResource ChartOhlcValue}" Margin="0,8,0,0" />
                <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Padding="0,2">
                    <Label Grid.Column="0" Text="Buy"
                           Style="{StaticResource ChartOhlcValue}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MaColorOptions}"
                            SelectedItem="{Binding BuyOrderColorOption}"
                            FontSize="12">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" x:DataType="style:MaColorOption" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>
                <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Padding="0,2">
                    <Label Grid.Column="0" Text="Sell"
                           Style="{StaticResource ChartOhlcValue}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MaColorOptions}"
                            SelectedItem="{Binding SellOrderColorOption}"
                            FontSize="12">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" x:DataType="style:MaColorOption" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Group flyouts: a VERTICAL column of the group's tools hovering over the chart just right of the
             rail, vertically centred. Hosted here (not in the rail view) so the rail stays a clean column;
             bound through Drawing.* against the shell's ChartViewModel. -->
        <Border Grid.Column="1" IsVisible="{Binding Drawing.IsLinesGroupOpen}"
                HorizontalOptions="Start" VerticalOptions="Center" Margin="2,0,0,0"
                BackgroundColor="{DynamicResource ChartPanel}" Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1" StrokeShape="RoundRectangle 6" Padding="4">
            <VerticalStackLayout Spacing="3">
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_trend.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Trend}" />
                    <Label Text="Trend" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Trend}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_ray.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Ray}" />
                    <Label Text="Ray" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Ray}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_extendedline.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.ExtendedLine}" />
                    <Label Text="Extended" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.ExtendedLine}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_hline.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.HLine}" />
                    <Label Text="Horizontal" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.HLine}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_hray.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.HRay}" />
                    <Label Text="H-Ray" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.HRay}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_vline.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.VLine}" />
                    <Label Text="Vertical" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.VLine}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_polyline.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Polyline}" />
                    <Label Text="Polyline" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Polyline}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_alert.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Alert}" />
                    <Label Text="Alert" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Alert}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
        <Border Grid.Column="1" IsVisible="{Binding Drawing.IsShapesGroupOpen}"
                HorizontalOptions="Start" VerticalOptions="Center" Margin="2,0,0,0"
                BackgroundColor="{DynamicResource ChartPanel}" Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1" StrokeShape="RoundRectangle 6" Padding="4">
            <VerticalStackLayout Spacing="3">
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_rectangle.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Rectangle}" />
                    <Label Text="Rectangle" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Rectangle}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_ellipse.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Ellipse}" />
                    <Label Text="Ellipse" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Ellipse}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="6">
                    <Button ImageSource="tool_arrow.png" Style="{StaticResource PenToolTile}"
                            Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Arrow}" />
                    <Label Text="Arrow" Style="{StaticResource ToolFlyoutLabel}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Drawing.PickGroupToolCommand}" CommandParameter="{x:Static tools:DrawTool.Arrow}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Pen tray + colour pickers (Z-order top). Bound to the child Drawing VM. -->
        <local:ChartPenPanelView Grid.Column="1" BindingContext="{Binding Drawing}" />

        </Grid>
    </Grid>
    </Border>
</ContentView>
