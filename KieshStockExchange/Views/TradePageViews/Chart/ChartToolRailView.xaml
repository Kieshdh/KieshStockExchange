<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tools="clr-namespace:KieshStockExchange.Models.ChartDrawing.Tools"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.TradePageViews.ChartToolRailView"
             x:DataType="vm:ChartDrawingViewModel">

    <!-- LEFT DRAWING-TOOL RAIL — a SELF-CONTAINED sidebar in its own column; the chart sits ENTIRELY to its
         right (nothing overlaps). Each group tile arms its last-picked tool and carries a thin › click-strip
         beside it that opens the group flyout — the flyout itself is hosted by the shell as an overlay OVER
         the chart, so this rail never spans onto it. No border stroke: the panel fill alone defines the
         sidebar. Binds the Drawing VM (set by ChartView). -->
    <Border VerticalOptions="Fill" HorizontalOptions="Start"
            Padding="3"
            BackgroundColor="{DynamicResource ChartPanel}"
            StrokeThickness="0"
            StrokeShape="Rectangle">
        <!-- Scroll the tool list so every group stays reachable when the rail is taller than the window. -->
        <ScrollView VerticalScrollBarVisibility="Default">
        <VerticalStackLayout Spacing="3" VerticalOptions="Start" HorizontalOptions="Start">
            <!-- Cursor -->
            <Button ImageSource="tool_cursor.png" Style="{StaticResource PenToolTile}" HorizontalOptions="Start"
                    Command="{Binding SelectDrawToolCommand}"
                    CommandParameter="{x:Static tools:DrawTool.None}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                 Value="{x:Static tools:DrawTool.None}">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        <Setter Property="BorderColor"     Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- LINES group: the tile arms the current line tool; a thin › click-strip beside it toggles
                 the group flyout (highlights on hover). -->
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="2" HorizontalOptions="Start">
                <Button Grid.Column="0" ImageSource="{Binding LinesGroupIcon}" Style="{StaticResource PenToolTile}"
                        Command="{Binding SelectDrawToolCommand}" CommandParameter="{Binding LinesGroupTool}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsLinesGroupActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="BorderColor"     Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource ToolGroupStrip}"
                        Command="{Binding ToggleToolGroupCommand}" CommandParameter="lines" />
            </Grid>

            <!-- SHAPES group: tile arms the current shape; thin › click-strip beside it toggles the flyout. -->
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="2" HorizontalOptions="Start">
                <Button Grid.Column="0" ImageSource="{Binding ShapesGroupIcon}" Style="{StaticResource PenToolTile}"
                        Command="{Binding SelectDrawToolCommand}" CommandParameter="{Binding ShapesGroupTool}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsShapesGroupActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="BorderColor"     Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource ToolGroupStrip}"
                        Command="{Binding ToggleToolGroupCommand}" CommandParameter="shapes" />
            </Grid>

            <!-- POSITION group: Long · Short · Manual · Fib. -->
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="2" HorizontalOptions="Start">
                <Button Grid.Column="0" ImageSource="{Binding PositionGroupIcon}" Style="{StaticResource PenToolTile}"
                        Command="{Binding SelectDrawToolCommand}" CommandParameter="{Binding PositionGroupTool}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsPositionGroupActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="BorderColor"     Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource ToolGroupStrip}"
                        Command="{Binding ToggleToolGroupCommand}" CommandParameter="position" />
            </Grid>

            <!-- DRAW group (combined Drawing + Text): Freehand · Text · Comment. -->
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="2" HorizontalOptions="Start">
                <Button Grid.Column="0" ImageSource="{Binding DrawingGroupIcon}" Style="{StaticResource PenToolTile}"
                        Command="{Binding SelectDrawToolCommand}" CommandParameter="{Binding DrawingGroupTool}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsDrawingGroupActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="BorderColor"     Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource ToolGroupStrip}"
                        Command="{Binding ToggleToolGroupCommand}" CommandParameter="drawing" />
            </Grid>

            <BoxView HeightRequest="1" Color="{StaticResource ChartGrid}" Margin="2,1" HorizontalOptions="Start" WidthRequest="42" />

            <!-- MEASURE + MAGNIFIER group: Measure · Magnifier(+). The zoom-out(−) is the standalone button below
                 (pops up once there's a box-zoom to step back). -->
            <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="2" HorizontalOptions="Start">
                <Button Grid.Column="0" ImageSource="{Binding MeasureGroupIcon}" Style="{StaticResource PenToolTile}"
                        Command="{Binding SelectDrawToolCommand}" CommandParameter="{Binding MeasureGroupTool}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsMeasureGroupActive}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="BorderColor"     Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Column="1" Style="{StaticResource ToolGroupStrip}"
                        Command="{Binding ToggleToolGroupCommand}" CommandParameter="measure" />
            </Grid>

            <!-- Magnifier zoom-OUT (an action; steps back the box-zoom stack; hidden when the stack is empty). -->
            <Button ImageSource="tool_magnifier_minus.png" Style="{StaticResource PenToolTile}" HorizontalOptions="Start"
                    IsVisible="{Binding CanZoomOut}"
                    Command="{Binding ZoomOutViewportCommand}" />

            <!-- Undo / redo / eye — actions (undo/redo grey out on empty history; eye highlights while hidden). -->
            <BoxView HeightRequest="1" Color="{StaticResource ChartGrid}" Margin="2,1" HorizontalOptions="Start" WidthRequest="32" />
            <Button ImageSource="tool_undo.png" Style="{StaticResource PenToolTile}" HorizontalOptions="Start"
                    Command="{Binding UndoCommand}" />
            <Button ImageSource="tool_redo.png" Style="{StaticResource PenToolTile}" HorizontalOptions="Start"
                    Command="{Binding RedoCommand}" />
            <!-- Delete-all — opens a Delete last / Delete all / Cancel sheet (spares locked). TODO tool_delete.png icon. -->
            <Button Text="🗑" Style="{StaticResource PenToolTile}" HorizontalOptions="Start"
                    Command="{Binding DeleteAllCommand}" />
            <Button ImageSource="tool_eye.png" Style="{StaticResource PenToolTile}" HorizontalOptions="Start"
                    Command="{Binding ToggleDrawingsHiddenCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding DrawingsHidden}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        <Setter Property="BorderColor"     Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </VerticalStackLayout>
        </ScrollView>
    </Border>
</ContentView>
