<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.TradePageViews.TradePage"
             x:Name="TradePageRoot"
             xmlns:local="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             xmlns:other="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:views="clr-namespace:KieshStockExchange.Views.TradePageViews"
             x:DataType="local:TradeViewModel"
             Title="TradePage" >
        <!-- No page-level ScrollView: the grid fills the page so the chart row is a real height
             constraint (the panel's inner ScrollView only works when its cell is bounded). Below the
             nav + picker, the chart area gets 70% and the tables 30% of the remaining height. -->
        <Grid x:Name="RootGrid"
              Style="{StaticResource MainGrid}"
              RowDefinitions="Auto, Auto, 7*, 3*"
              ColumnDefinitions="*, Auto, Auto"
              RowSpacing="8"
              ColumnSpacing="8"
              Padding="8" >

            <!-- Navigation bar at the Top -->
            <other:TopNavBarView Grid.Row="0"
                                 x:Name="TopNav"
                                 Grid.ColumnSpan="3"
                                 BindingContext="{Binding TopNavBarVm}" />

            <!-- Toast overlay. ColumnSpan=3 + HorizontalOptions=End keeps it
                 floating at the right edge without contributing 320px to
                 Column 2's auto-measurement (which would push PlaceOrder/
                 OrderBook out of alignment). -->
            <other:ToastHostView Grid.Row="1" Grid.RowSpan="5"
                                 Grid.Column="0" Grid.ColumnSpan="3"
                                 VerticalOptions="Start" HorizontalOptions="End"
                                 Margin="0,8,8,0"
                                 ZIndex="200" />

            <!-- Stock picker and price display — full-width symbol bar above the chart/book/panel. -->
            <Border Style="{StaticResource TradeContentOutline}"
                   x:Name="SymbolBar"
                   Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                   Margin="0">
                <Grid ColumnDefinitions="Auto, Auto, Auto, Auto" ColumnSpacing="10">
                    <Picker ItemsSource="{Binding TradingPairs}" Grid.Column="0"
                            SelectedItem="{Binding PickerSelection, Mode=TwoWay}"
                            Style="{StaticResource StockSelectorPicker}">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Display" x:DataType="local:TradingPair" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                    <!-- Star toggle: ★ when watched, ☆ otherwise. -->
                    <Button Grid.Column="1"
                            Command="{Binding ToggleSelectedWatchCommand}"
                            Style="{StaticResource WatchStarButton}">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsSelectedWatched}" Value="True">
                                <Setter Property="Text"      Value="&#x2605;" />
                                <Setter Property="TextColor" Value="{DynamicResource BuyGreen}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsSelectedWatched}" Value="False">
                                <Setter Property="Text"      Value="&#x2606;" />
                                <Setter Property="TextColor" Value="{DynamicResource TextMuted}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    <Label Text="{Binding Selected.CurrentPriceDisplay}" Grid.Column="2"
                           Style="{StaticResource SelectedStockHeaderLabel}" />
                    <Label Text="{Binding Selected.CompanyName}" Grid.Column="3"
                           Style="{StaticResource SelectedStockHeaderLabel}" />
                </Grid>
            </Border>

            <!-- The chart that displays the price - ChartView is its own card. Height is pinned in
                 code-behind (UpdateTradeLayout) to the chart row's 70% share so the bottom table's
                 content can't perturb the star-row split and inflate the chart. -->
            <views:ChartView Grid.Row="2" Grid.Column="0"
                             x:Name="ChartCard"
                             VerticalOptions="Fill" HorizontalOptions="Fill"
                             BindingContext="{Binding ChartVm}"/>

            <!-- Orderbook + order panel live in the star row (row 2). The panel's inner ScrollView
                 reports its full content as desired height, which would inflate this star row past
                 its share (pushing the pinned footer/button below the window). Their heights are set
                 imperatively in code-behind (UpdatePanelHeights) to the row's true height — a
                 loop-free calc from the page height, so it stays correct across window resizes. -->
            <views:OrderBookView Grid.Row="2" Grid.Column="1"
                                 x:Name="OrderBookHost" 
                                 WidthRequest="230" VerticalOptions="Fill"
                                 BindingContext="{Binding OrderBookVm}"/>

            <!-- PlaceOrderView -->
            <ContentView Grid.Column="2" Grid.Row="2"
                         x:Name="PlaceHost"
                         WidthRequest="260" VerticalOptions="Fill" 
                         IsVisible="{Binding IsPlacing}">
                <views:PlaceOrderView BindingContext="{Binding PlacingVm}" />
            </ContentView>
            <!-- ModifyOrderView -->
            <ContentView Grid.Column="2" Grid.Row="2"
                         x:Name="ModifyHost"
                         WidthRequest="260" VerticalOptions="Fill" 
                         IsVisible="{Binding IsModifying}">
                <views:ModifyOrderView BindingContext="{Binding ModifyingVm}" />
            </ContentView>

            <!-- Shows the current orders, order history and current positions.
                 Spans all 3 columns so the table is as wide as the page. Width is pinned in
                 code-behind (UpdateTradeLayout) to the page width: a `*`-column table measured
                 unbounded balloons its desired width and, via this colspan, inflates the Auto
                 columns (orderbook/panel) — which pushed the page wider than the window and clipped
                 the right side (incl. the Open Orders cancel button) when a table had data. -->
            <Border Style="{StaticResource TradeContentOutline}"
                    x:Name="TablesCard" HorizontalOptions="Start" VerticalOptions="Fill"
                    Grid.Row="3" Grid.ColumnSpan="3"
                    Margin="0" Padding="8,3,8,6">
                <other:SegmentedTabView HeaderContainerHorizontalOptions="Start"
                        ContainerStyle="{StaticResource SegmentedRailContainer}"
                        SelectedButtonStyle="{StaticResource RailSegmentSelectedCompact}"
                        UnselectedButtonStyle="{StaticResource RailSegmentUnselectedCompact}"
                        ShowUnderline="True" >

                    <!-- §F11: "current stock only" filter — one toggle for Open Orders / Order History /
                         Transactions (Positions stay unfiltered). Label tracks the selected symbol. -->
                    <other:SegmentedTabView.HeaderRightContent>
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding TablesFilterLabel}"
                                   Style="{StaticResource MutedLabelStyle}"
                                   VerticalOptions="Center" />
                            <CheckBox IsChecked="{Binding CurrentStockOnly}"
                                      VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </other:SegmentedTabView.HeaderRightContent>

                    <!-- Tab BindingContexts wired in code-behind. -->
                    <other:SegmentedTabView.Tabs>
                        <!-- Open Orders Table-->
                        <other:SegmentedTabItem Header="Open Orders">
                            <other:SegmentedTabItem.Content>
                                <views:OpenOrdersView x:Name="OpenOrdersTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <!-- Order History Table-->
                        <other:SegmentedTabItem Header="Order History">
                            <other:SegmentedTabItem.Content>
                                <views:OrderHistoryView x:Name="OrderHistoryTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <!-- Transaction History Table-->
                        <other:SegmentedTabItem Header="Transaction History">
                            <other:SegmentedTabItem.Content>
                                <views:TransactionHistoryView x:Name="TransactionHistoryTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <!-- Current Positions Table -->
                        <other:SegmentedTabItem Header="Positions">
                            <other:SegmentedTabItem.Content>
                                <views:UserPositionsView x:Name="PositionsTab" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>
                    </other:SegmentedTabView.Tabs>
                </other:SegmentedTabView>
            </Border>
        </Grid>
</ContentPage>
