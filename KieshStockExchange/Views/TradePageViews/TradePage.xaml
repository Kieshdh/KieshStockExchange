<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.TradePageViews.TradePage"
             x:Name="TradePageRoot"
             xmlns:local="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             xmlns:other="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:views="clr-namespace:KieshStockExchange.Views.TradePageViews"
             xmlns:models="clr-namespace:KieshStockExchange.Models"
             x:DataType="local:TradeViewModel"
             Title="TradePage" >
    <ScrollView>
        <Grid Style="{StaticResource MainGrid}"
              RowDefinitions="Auto, Auto, *, Auto"
              ColumnDefinitions="*, Auto, Auto"
              RowSpacing="8"
              ColumnSpacing="8"
              Padding="8" >

            <!-- Navigation bar at the Top -->
            <other:TopNavBarView Grid.Row="0"
                                 Grid.ColumnSpan="3"
                                 BindingContext="{Binding TopNavBarVm}" />

            <!-- Stock picker and price display -->
            <Border Style="{StaticResource TradeContentOutline}"
                   Grid.Row="1" Grid.Column="0"
                   Margin="0">
                <Grid ColumnDefinitions="Auto, Auto, Auto" ColumnSpacing="10">
                    <Picker ItemsSource="{Binding TradingPairs}" Grid.Column="0"
                            SelectedItem="{Binding PickerSelection, Mode=TwoWay}"
                            Style="{StaticResource StockSelectorPicker}">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Display" x:DataType="local:TradingPair" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                    <Label Text="{Binding Selected.CurrentPriceDisplay}" Grid.Column="1"
                           Style="{StaticResource SelectedStockHeaderLabel}" />
                    <Label Text="{Binding Selected.CompanyName}" Grid.Column="2"
                           Style="{StaticResource SelectedStockHeaderLabel}" />
                </Grid>
            </Border>

            <!-- The chart that displays the price - ChartView is its own card -->
            <views:ChartView Grid.Row="2" Grid.Column="0"
                             BindingContext="{Binding ChartVm}"/>

            <!-- The Orderbook that displays current orders - OrderBookView is its own card -->
            <views:OrderBookView Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                                 BindingContext="{Binding OrderBookVm}"/>

            <!-- Right-hand trade panel — two sibling cards share the same Grid
                 cell, only one is visible at a time. Default is PlaceOrderView;
                 swaps to ModifyOrderView while IOrderEditService.IsEditing flips
                 true (driven by chart-drag or the ✎ button on the open-orders
                 table). The placing VM keeps its state — no rebinds, no rebuild.

                 Each panel is wrapped in a ContentView that inherits the page's
                 TradeViewModel BindingContext (so IsVisible can read IsPlacing /
                 IsModifying directly), then the inner panel swaps its own
                 BindingContext to the sub-VM. Avoids {Binding Source=...} and
                 lets these bindings compile under x:DataType=TradeViewModel. -->
            <ContentView Grid.Column="2" Grid.Row="1" Grid.RowSpan="2"
                         WidthRequest="260"
                         IsVisible="{Binding IsPlacing}">
                <views:PlaceOrderView BindingContext="{Binding PlacingVm}" />
            </ContentView>
            <ContentView Grid.Column="2" Grid.Row="1" Grid.RowSpan="2"
                         WidthRequest="260"
                         IsVisible="{Binding IsModifying}">
                <views:ModifyOrderView BindingContext="{Binding ModifyingVm}" />
            </ContentView>

            <!-- Shows the current orders, order history and current positions.
                 Spans all 3 columns so the table is as wide as the page. -->
            <Border Style="{StaticResource TradeContentOutline}"
                    Grid.Row="3" Grid.ColumnSpan="3"
                    Margin="0">
                <other:SegmentedTabView HeaderContainerHorizontalOptions="Start"
                        ContainerStyle="{StaticResource SegmentedRailContainer}"
                        SelectedButtonStyle="{StaticResource RailSegmentSelected}"
                        UnselectedButtonStyle="{StaticResource RailSegmentUnselected}"
                        ShowUnderline="True" >

                    <!-- Content -->
                    <other:SegmentedTabView.Tabs>
                        <!-- Open Orders Table-->
                        <other:SegmentedTabItem Header="Open Orders">
                            <other:SegmentedTabItem.Content>
                                <views:OpenOrdersView BindingContext="{Binding OpenOrdersVm}" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <!-- Order History Table-->
                        <other:SegmentedTabItem Header="Order History">
                            <other:SegmentedTabItem.Content>
                                <views:OrderHistoryView BindingContext="{Binding OrderHistoryVm}" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <!-- Transaction History Table-->
                        <other:SegmentedTabItem Header="Transaction History">
                            <other:SegmentedTabItem.Content>
                                <views:TransactionHistoryView BindingContext="{Binding TransactionVm}" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>

                        <!-- Current Positions Table -->
                        <other:SegmentedTabItem Header="Positions">
                            <other:SegmentedTabItem.Content>
                                <views:UserPositionsView BindingContext="{Binding PositionsVm}" />
                            </other:SegmentedTabItem.Content>
                        </other:SegmentedTabItem>
                    </other:SegmentedTabView.Tabs>
                </other:SegmentedTabView>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>