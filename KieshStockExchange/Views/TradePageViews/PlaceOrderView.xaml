<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:KieshStockExchange.Views.OtherViews"
             x:Class="KieshStockExchange.Views.TradePageViews.PlaceOrderView">

    <Border Style="{StaticResource TradingPanelStyle}">
        <VerticalStackLayout Spacing="12">

            <!-- Card head: title + Buy/Sell pill -->
            <Grid ColumnDefinitions="*,Auto"
                  VerticalOptions="Center">
                <Label Grid.Column="0"
                       Text="Place Order"
                       Style="{StaticResource SectionHeaderLabelStyle}"
                       VerticalOptions="Center" />
                <views:SegmentedTabView Grid.Column="1"
                    SelectedIndex="{Binding SelectedSideIndex}"
                    SelectedButtonStyle="{StaticResource SelectedSegmentButtonStyle}"
                    UnselectedButtonStyle="{StaticResource UnselectedSegmentButtonStyle}"
                    HeaderContainerHorizontalOptions="End"
                    MinTabWidth="50">
                    <views:SegmentedTabView.Tabs>
                        <views:SegmentedTabItem Header="Buy"
                                                SelectedButtonStyle="{StaticResource Seg_Selected_Buy}" />
                        <views:SegmentedTabItem Header="Sell"
                                                SelectedButtonStyle="{StaticResource Seg_Selected_Sell}" />
                    </views:SegmentedTabView.Tabs>
                </views:SegmentedTabView>
            </Grid>

            <!-- Order type segment, left-aligned -->
            <views:SegmentedTabView
                SelectedIndex="{Binding SelectedTypeIndex}"
                SelectedButtonStyle="{StaticResource SelectedSegmentButtonStyle}"
                UnselectedButtonStyle="{StaticResource UnselectedSegmentButtonStyle}"
                HeaderContainerHorizontalOptions="Start">
                <views:SegmentedTabView.Tabs>
                    <views:SegmentedTabItem Header="Market" />
                    <views:SegmentedTabItem Header="Limit" />
                </views:SegmentedTabView.Tabs>
            </views:SegmentedTabView>

            <!-- Available assets row -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                <Label Grid.Column="0"
                       Text="{Binding AssetText}"
                       Style="{StaticResource OrderTotalsLabel}"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1"
                       Text="{Binding AvailableAssetsText}"
                       Style="{StaticResource OrderTotalsValue}"
                       VerticalTextAlignment="Center" />
            </Grid>

            <!-- "Convert cash first" hint when the user has no Fund in the selected currency. -->
            <Label Text="{Binding HintText}"
                   IsVisible="{Binding HasHint}"
                   Style="{StaticResource MutedLabelStyle}"
                   TextColor="{DynamicResource SellRed}"
                   Margin="0,2,0,0" />

            <!-- Limit price (Limit mode only) -->
            <VerticalStackLayout Spacing="0"
                                 IsVisible="{Binding IsLimitSelected}">
                <Label Text="Limit price"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding LimitPriceString, Mode=TwoWay}"
                       Placeholder="{Binding Selected.CurrentPriceDisplay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>

            <!-- Quantity -->
            <VerticalStackLayout Spacing="0">
                <Label Text="Quantity"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding QuantityString, Mode=TwoWay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>

            <!-- Slippage guard (Market mode only) -->
            <VerticalStackLayout Spacing="0"
                                 IsVisible="{Binding IsMarketSelected}">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="4">
                    <Label Grid.Column="0"
                           Text="Slippage guard"
                           Style="{StaticResource FormLabelStyle}"
                           Margin="0"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="None"
                           Style="{StaticResource OrderTotalsLabel}"
                           VerticalTextAlignment="Center" />
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding NoSlippageGuard}"
                              VerticalOptions="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Slider Grid.Column="0"
                            Minimum="0" Maximum="0.05"
                            Value="{Binding SlippagePrc, Mode=TwoWay}"
                            VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding SlippagePrc, StringFormat='±{0:P2}'}"
                           Style="{StaticResource OrderTotalsValue}"
                           VerticalTextAlignment="Center"
                           MinimumWidthRequest="60" />
                </Grid>
            </VerticalStackLayout>

            <!-- Divider + order value -->
            <BoxView HeightRequest="1"
                     BackgroundColor="{DynamicResource Divider}"
                     Margin="0,4,0,0" />
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Order value"
                       Style="{StaticResource OrderTotalsLabel}" />
                <Label Grid.Column="1"
                       Text="{Binding OrderValue}"
                       Style="{StaticResource OrderTotalsValue}" />
            </Grid>

            <!-- Submit CTA — green for Buy, red for Sell (via DataTrigger,
                 so it follows the active theme tokens, not the legacy
                 ForestGreen/OrangeRed exposed by SubmitButtonColor). -->
            <Button Text="{Binding SubmitButtonText}"
                    Command="{Binding PlaceOrderCommand}"
                    Style="{StaticResource BuyButtonStyle}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsSellSelected}"
                                 Value="True">
                        <Setter Property="BackgroundColor" Value="{DynamicResource SellRed}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

        </VerticalStackLayout>
    </Border>
</ContentView>
