<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.TradePageViews.PlaceOrderView"
             x:DataType="vm:PlaceOrderViewModel">

    <Border Style="{StaticResource TradingPanelStyle}">
        <!-- §3.6 P4: the ticket can grow tall (stop + bracket SL + up to 3 TP rows), so the body
             scrolls within the panel. The TradePage parent bounds the panel height. -->
        <ScrollView>
        <VerticalStackLayout Spacing="12">

            <!-- Card head: title + Buy/Sell pill -->
            <Grid ColumnDefinitions="*,Auto"
                  VerticalOptions="Center">
                <Label Grid.Column="0"
                       Text="Place Order"
                       Style="{StaticResource SectionHeaderLabelStyle}"
                       VerticalOptions="Center" />
                <views:SegmentedTabView Grid.Column="1"
                    SelectedIndex="{Binding SelectedSideIndex}"
                    SelectedButtonStyle="{StaticResource SelectedSegmentButtonStyle}"
                    UnselectedButtonStyle="{StaticResource UnselectedSegmentButtonStyle}"
                    HeaderContainerHorizontalOptions="End"
                    MinTabWidth="50">
                    <views:SegmentedTabView.Tabs>
                        <views:SegmentedTabItem Header="Buy"
                                                SelectedButtonStyle="{StaticResource Seg_Selected_Buy}" />
                        <views:SegmentedTabItem Header="Sell"
                                                SelectedButtonStyle="{StaticResource Seg_Selected_Sell}" />
                    </views:SegmentedTabView.Tabs>
                </views:SegmentedTabView>
            </Grid>

            <!-- Order type segment, left-aligned -->
            <views:SegmentedTabView
                SelectedIndex="{Binding SelectedTypeIndex}"
                SelectedButtonStyle="{StaticResource SelectedSegmentButtonStyle}"
                UnselectedButtonStyle="{StaticResource UnselectedSegmentButtonStyle}"
                HeaderContainerHorizontalOptions="Start">
                <views:SegmentedTabView.Tabs>
                    <views:SegmentedTabItem Header="Market" />
                    <views:SegmentedTabItem Header="Limit" />
                </views:SegmentedTabView.Tabs>
            </views:SegmentedTabView>

            <!-- Trigger modifier: Trigger + Market = stop-market, Trigger + Limit = stop-limit (§3.6 P2) -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
                <Label Grid.Column="0"
                       Text="Trigger order"
                       Style="{StaticResource FormLabelStyle}"
                       Margin="0"
                       VerticalOptions="Center" />
                <CheckBox Grid.Column="1"
                          IsChecked="{Binding IsStopOrder}"
                          VerticalOptions="Center" />
            </Grid>

            <!-- Trigger price (Trigger mode only) -->
            <VerticalStackLayout Spacing="0"
                                 IsVisible="{Binding IsStopOrder}">
                <Label Text="Trigger price"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding StopPriceString, Mode=TwoWay}"
                       Placeholder="{Binding Selected.CurrentPriceDisplay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
                <Label Text="Activates the order when the market reaches this level."
                       Style="{StaticResource MutedLabelStyle}"
                       FontSize="11" Margin="0,2,0,0" />
            </VerticalStackLayout>

            <!-- §3.6 P4 bracket toggle (long entry only: Buy, not a standalone stop) -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4"
                  IsVisible="{Binding ShowBracket}">
                <Label Grid.Column="0"
                       Text="Bracket (stop-loss + take-profits)"
                       Style="{StaticResource FormLabelStyle}"
                       Margin="0"
                       VerticalOptions="Center" />
                <CheckBox Grid.Column="1"
                          IsChecked="{Binding IsBracketOrder}"
                          VerticalOptions="Center" />
            </Grid>

            <!-- Bracket legs (visible when bracket is on): a protective stop-loss + up to 3 TPs. -->
            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding IsBracketOrder}">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Stop-loss price" Style="{StaticResource FormLabelStyle}" />
                    <Entry Text="{Binding BracketStopPriceString, Mode=TwoWay}"
                           Placeholder="below entry"
                           Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                </VerticalStackLayout>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Text="{Binding Tp1PriceString, Mode=TwoWay}"
                           Placeholder="TP1 price" Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1" Text="{Binding Tp1QtyString, Mode=TwoWay}"
                           Placeholder="TP1 qty" Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Text="{Binding Tp2PriceString, Mode=TwoWay}"
                           Placeholder="TP2 price" Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1" Text="{Binding Tp2QtyString, Mode=TwoWay}"
                           Placeholder="TP2 qty" Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Entry Grid.Column="0" Text="{Binding Tp3PriceString, Mode=TwoWay}"
                           Placeholder="TP3 price" Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                    <Entry Grid.Column="1" Text="{Binding Tp3QtyString, Mode=TwoWay}"
                           Placeholder="TP3 qty" Style="{StaticResource FormEntryStyle}"
                           Keyboard="Numeric" HorizontalTextAlignment="End" />
                </Grid>
            </VerticalStackLayout>

            <!-- Available assets — both funds and shares, for both sides. -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                <Label Grid.Column="0"
                       Text="Available funds"
                       Style="{StaticResource OrderTotalsLabel}"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1"
                       Text="{Binding AvailableFundsDisplay}"
                       Style="{StaticResource OrderTotalsValue}"
                       VerticalTextAlignment="Center" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Shares (available / total)"
                       Style="{StaticResource OrderTotalsLabel}"
                       VerticalTextAlignment="Center" />
                <Label Grid.Column="1"
                       Text="{Binding AvailableSharesDisplay}"
                       Style="{StaticResource OrderTotalsValue}"
                       VerticalTextAlignment="Center" />
            </Grid>

            <!-- "Convert cash first" hint when the user has no Fund in the selected currency. -->
            <Label Text="{Binding HintText}"
                   IsVisible="{Binding HasHint}"
                   Style="{StaticResource MutedLabelStyle}"
                   TextColor="{DynamicResource SellRed}"
                   Margin="0,2,0,0" />

            <!-- Limit price (Limit mode only; with a trigger on, this is the stop-limit limit) -->
            <VerticalStackLayout Spacing="0"
                                 IsVisible="{Binding IsLimitSelected}">
                <Label Text="Limit price"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding LimitPriceString, Mode=TwoWay}"
                       Placeholder="{Binding Selected.CurrentPriceDisplay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
                <Label Text="Fills at this price or better."
                       Style="{StaticResource MutedLabelStyle}"
                       FontSize="11" Margin="0,2,0,0"
                       IsVisible="{Binding IsStopOrder}" />
            </VerticalStackLayout>

            <!-- Quantity -->
            <VerticalStackLayout Spacing="0">
                <Label Text="Quantity"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding QuantityString, Mode=TwoWay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>

            <!-- Slippage guard (plain Market mode only — hidden when Stop is on) -->
            <VerticalStackLayout Spacing="0"
                                 IsVisible="{Binding ShowSlippageGuard}">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="4">
                    <Label Grid.Column="0"
                           Text="Slippage guard"
                           Style="{StaticResource FormLabelStyle}"
                           Margin="0"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="None"
                           Style="{StaticResource OrderTotalsLabel}"
                           VerticalTextAlignment="Center" />
                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding NoSlippageGuard}"
                              VerticalOptions="Center" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Slider Grid.Column="0"
                            Minimum="0" Maximum="0.01"
                            Value="{Binding SlippagePrc, Mode=TwoWay}"
                            VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding SlippagePrc, StringFormat='±{0:P2}'}"
                           Style="{StaticResource OrderTotalsValue}"
                           VerticalTextAlignment="Center"
                           MinimumWidthRequest="60" />
                </Grid>
            </VerticalStackLayout>

            <!-- Divider + order value -->
            <BoxView HeightRequest="1"
                     BackgroundColor="{DynamicResource Divider}"
                     Margin="0,4,0,0" />
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Order value"
                       Style="{StaticResource OrderTotalsLabel}" />
                <Label Grid.Column="1"
                       Text="{Binding OrderValue}"
                       Style="{StaticResource OrderTotalsValue}" />
            </Grid>

            <!-- Submit CTA — green for Buy, red for Sell (via DataTrigger,
                 so it follows the active theme tokens, not the legacy
                 ForestGreen/OrangeRed exposed by SubmitButtonColor). -->
            <Button Text="{Binding SubmitButtonText}"
                    Command="{Binding PlaceOrderCommand}"
                    Style="{StaticResource BuyButtonStyle}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsSellSelected}"
                                 Value="True">
                        <Setter Property="BackgroundColor" Value="{DynamicResource SellRed}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <!-- Blocking validation error (e.g. wrong-side trigger) — set on a rejected submit. -->
            <Label Text="{Binding ValidationMessage}"
                   IsVisible="{Binding HasValidationMessage}"
                   Style="{StaticResource MutedLabelStyle}"
                   TextColor="{DynamicResource SellRed}"
                   Margin="0,2,0,0" />

        </VerticalStackLayout>
        </ScrollView>
    </Border>
</ContentView>
