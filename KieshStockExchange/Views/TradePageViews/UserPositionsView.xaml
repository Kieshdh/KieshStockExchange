<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.TradePageViews.UserPositionsView"
             x:Name="PositionRoot"
             x:DataType="vm:UserPositionsViewModel">

    <Grid RowDefinitions="Auto,*" Style="{StaticResource TradeTableContainerGrid}">

        <!-- Table headers -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,*,*,*,*,*"
              Style="{StaticResource TradeTableHeaderGrid}">
            <Label Grid.Column="0" Text="Symbol"    Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="1" Text="Price"     Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="2" Text="Amount"    Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="3" Text="Reserved"  Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="4" Text="Available" Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="5" Text="Total"     Style="{StaticResource TradeTableHeaderLabel}" />
        </Grid>

        <!-- Rows -->
        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding CurrentView}"
                            SelectionMode="None">
                <CollectionView.EmptyView>
                    <StackLayout Padding="12" Spacing="4">
                        <Label Text="No open positions" Opacity="0.7" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PositionRow">
                        <Grid ColumnDefinitions="*,*,*,*,*,*"
                              Style="{StaticResource TradeTableRowGrid}">
                            <HorizontalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding Symbol}" Style="{StaticResource TradeTableSymbolLabel}" VerticalOptions="Center" />
                                <Label Style="{StaticResource TableSymbolNavGlyph}">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToStockCommand}" CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Price}"     Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="2" Text="{Binding Qty}"       Style="{StaticResource TradeTableRowLabel}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsShort}" Value="True">
                                        <Setter Property="TextColor" Value="OrangeRed" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Grid.Column="3" Text="{Binding Reserved}"  Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="4" Text="{Binding Available}" Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="5" Text="{Binding Total}"     Style="{StaticResource TradeTableRowLabel}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentView>
