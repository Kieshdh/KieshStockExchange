<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.TradePageViews.ModifyOrderView"
             x:DataType="vm:ModifyOrderViewModel">

    <Border Style="{StaticResource TradingPanelStyle}">
        <VerticalStackLayout Spacing="12">

            <!-- Card head: title + side/type chip (read-only — user can't change side/type while modifying) -->
            <Grid ColumnDefinitions="*,Auto"
                  VerticalOptions="Center">
                <Label Grid.Column="0"
                       Text="Modify order"
                       Style="{StaticResource SectionHeaderLabelStyle}"
                       VerticalOptions="Center" />
                <Border Grid.Column="1"
                        StrokeThickness="0"
                        Padding="10,4"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsBuyOrder}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="{DynamicResource BuyGreen}" />
                        </DataTrigger>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsBuyOrder}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="{DynamicResource SellRed}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Label Text="{Binding SideTypeChip}"
                           TextColor="White"
                           FontSize="12"
                           FontAttributes="Bold" />
                </Border>
            </Grid>

            <!-- Order summary line — what the user is editing -->
            <Label Text="{Binding Summary}"
                   Style="{StaticResource OrderTotalsLabel}"
                   FontSize="12" />

            <!-- Quantity -->
            <VerticalStackLayout Spacing="0">
                <Label Text="Quantity"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding QuantityString, Mode=TwoWay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>

            <!-- Primary price field: limit price for a normal order, trigger price for a stop.
                 The label flips via PriceFieldLabel (§3.6 P3). This is the field the chart drag
                 tracks. -->
            <VerticalStackLayout Spacing="0">
                <Label Text="{Binding PriceFieldLabel}"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding PriceString, Mode=TwoWay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>

            <!-- Stop-limit only: the separate limit price the stop promotes to (§3.6 P3). -->
            <VerticalStackLayout Spacing="0"
                                 IsVisible="{Binding IsStopLimit}">
                <Label Text="Limit price"
                       Style="{StaticResource FormLabelStyle}" />
                <Entry Text="{Binding LimitPriceString, Mode=TwoWay}"
                       Style="{StaticResource FormEntryStyle}"
                       Keyboard="Numeric"
                       HorizontalTextAlignment="End" />
            </VerticalStackLayout>

            <!-- Error message (only visible when set) -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}"
                   TextColor="{DynamicResource SellRed}"
                   FontSize="12" />

            <!-- Non-blocking warning: the edited price crosses the market (fills like a market order). -->
            <Label Text="{Binding WarningMessage}"
                   IsVisible="{Binding HasWarning}"
                   Style="{StaticResource MutedLabelStyle}"
                   FontSize="12" />

            <!-- Row 1: Cancel (back out) · Remove (cancel the order). Row 2: full-width Confirm. -->
            <VerticalStackLayout Spacing="8" Margin="0,4,0,0">
                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="Cancel"
                            FontSize="13"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource UnselectedSegmentButtonStyle}" />
                    <Button Grid.Column="1"
                            Text="Remove"
                            FontSize="13"
                            Command="{Binding RemoveCommand}"
                            Style="{StaticResource BuyButtonStyle}"
                            BackgroundColor="{DynamicResource SellRed}" />
                </Grid>
                <Button Text="Confirm modification"
                        FontSize="13"
                        Command="{Binding ConfirmCommand}"
                        Style="{StaticResource BuyButtonStyle}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsBuyOrder}"
                                     Value="False">
                            <Setter Property="BackgroundColor" Value="{DynamicResource SellRed}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </Border>
</ContentView>
