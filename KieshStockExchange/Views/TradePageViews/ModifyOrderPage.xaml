<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.TradePageViews.ModifyOrderPage"
             Title="Modify order">

    <Grid Style="{StaticResource MainGrid}"
          Padding="20">
        <Border Style="{StaticResource DashboardCardStyle}"
                Padding="22"
                HorizontalOptions="Fill"
                VerticalOptions="Start">
            <VerticalStackLayout Spacing="14">

                <Label Text="Modify order"
                       Style="{StaticResource SectionHeaderLabelStyle}" />

                <Label Text="{Binding Summary}"
                       Style="{StaticResource MutedLabelStyle}" />

                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding PriceLabel}"
                           Style="{StaticResource FormLabelStyle}" />
                    <Entry Text="{Binding PriceString}"
                           IsEnabled="{Binding CanEditPrice}"
                           Keyboard="Numeric"
                           Placeholder="0.00"
                           Style="{StaticResource FormEntryStyle}" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="Quantity"
                           Style="{StaticResource FormLabelStyle}" />
                    <Entry Text="{Binding QuantityString}"
                           Keyboard="Numeric"
                           Placeholder="0"
                           Style="{StaticResource FormEntryStyle}" />
                </VerticalStackLayout>

                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource RegistrationErrorLabel}"
                       IsVisible="{Binding HasError}" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="8"
                      Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Text="Confirm"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Command="{Binding ConfirmCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
                    <Button Grid.Column="1"
                            Text="Cancel"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Command="{Binding CancelCommand}" />
                </Grid>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
