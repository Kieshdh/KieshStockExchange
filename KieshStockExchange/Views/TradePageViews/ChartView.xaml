<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KieshStockExchange.Models;assembly=KieshStockExchange.Shared"
             xmlns:helpers="clr-namespace:KieshStockExchange.Services.MarketDataServices.Helpers"
             xmlns:tools="clr-namespace:KieshStockExchange.Models.ChartDrawing.Tools"
             xmlns:style="clr-namespace:KieshStockExchange.Models.ChartDrawing.Style"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.TradePageViews.ChartView"
             x:Name="ChartRoot"
             x:DataType="vm:ChartViewModel">

    <Border BackgroundColor="{DynamicResource ChartBg}"
            Stroke="{DynamicResource Divider}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 10"
            Padding="0">
    <Grid RowDefinitions="Auto,*"
          BackgroundColor="Transparent"
          MinimumHeightRequest="300">

        <!-- Toolbar -->
        <Grid Grid.Row="0" Style="{StaticResource ChartToolbar}"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">

            <!-- Resolution segments -->
            <HorizontalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                <Button Text="15s"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FifteenSeconds}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FifteenSeconds}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="1m"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.OneMinute}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.OneMinute}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="5m"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FiveMinutes}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FiveMinutes}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="15m"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FifteenMinutes}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FifteenMinutes}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="1h"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.OneHour}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.OneHour}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="4h"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FourHours}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FourHours}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="1D"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.OneDay}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.OneDay}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Chart-type toggle (cycles Candles -> Hollow -> Bars -> Line -> Area -> Heikin-Ashi) -->
                <BoxView WidthRequest="1" Color="{StaticResource ChartGrid}" Margin="4,4" VerticalOptions="Fill" />
                <Button Text="{Binding ChartStyleLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding CycleChartStyleCommand}" />

                <!-- Volume display toggle (cycles Overlay -> Pane -> Off) -->
                <Button Text="{Binding VolumeModeLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding CycleVolumeModeCommand}" />

                <!-- Market Mood (Fear/Greed) sub-pane toggle -->
                <Button Text="{Binding MoodPaneLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding ToggleMoodPaneCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding ShowMoodPane}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Order-book depth heatmap toggle -->
                <Button Text="{Binding DepthLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding ToggleDepthCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding ShowDepth}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Price-scale toggle (cycles Linear -> Log -> Percent) -->
                <Button Text="{Binding ScaleModeLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding CycleScaleModeCommand}" />

                <!-- Pen tray: a plain text label ("Line" + the current tool glyph) + ▾; tapping toggles
                     the pen panel. Replaces the old cycle + "+ Line" buttons. -->
                <Button Text="{Binding PenToolLabel, StringFormat='{0} ▾'}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding TogglePenPanelCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsPenPanelOpen}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>

            <!-- Spacer -->
            <BoxView Grid.Column="1" Color="Transparent" />

            <!-- Y-axis auto-fit toggle -->
            <Button Grid.Column="2" Text="Autofit"
                    Style="{StaticResource ChartLiveButton.Off}"
                    Clicked="OnYAutoFitClicked">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsYAutoFit}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        <Setter Property="TextColor"       Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <!-- MA settings toggle -->
            <Button Grid.Column="3" Text="MA"
                    Style="{StaticResource ChartLiveButton.Off}"
                    Command="{Binding ToggleMaSettingsCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsMaSettingsOpen}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        <Setter Property="TextColor"       Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <!-- Zoom out -->
            <Button Grid.Column="4" Text="−"
                    Style="{StaticResource ChartIconButton}"
                    Command="{Binding ZoomOutCommand}" />
            <!-- Zoom in -->
            <Button Grid.Column="5" Text="+"
                    Style="{StaticResource ChartIconButton}"
                    Command="{Binding ZoomInCommand}" />
            <!-- Separator -->
            <BoxView Grid.Column="6" Style="{StaticResource ChartToolbarSeparator}" />
            <!-- Live -->
            <Button Grid.Column="7" Text="LIVE"
                    Style="{StaticResource ChartLiveButton.Off}"
                    Command="{Binding GoLiveCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsLive}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartBull}" />
                        <Setter Property="TextColor"       Value="{StaticResource White}" />
                        <Setter Property="BorderColor"     Value="{StaticResource ChartBull}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- Chart -->
        <GraphicsView x:Name="Chart" Grid.Row="1"
                      Style="{StaticResource ChartSurface}">
            <GraphicsView.GestureRecognizers>
                <PanGestureRecognizer x:Name="ChartPan" />
                <PointerGestureRecognizer x:Name="ChartPointer" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- OHLCV overlay: top-left of the chart canvas. InputTransparent so
             pan / wheel gestures still reach the GraphicsView underneath. -->
        <HorizontalStackLayout Grid.Row="1"
                               VerticalOptions="Start"
                               HorizontalOptions="Start"
                               Margin="14,10,0,0"
                               Spacing="14"
                               InputTransparent="True">

            <HorizontalStackLayout Spacing="4">
                <Label Text="O" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.OpenDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="H" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.HighDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="L" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.LowDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="C" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.CloseDisplay, FallbackValue=''}">
                    <Label.Style>
                        <Style TargetType="Label" BasedOn="{StaticResource ChartOhlcValue}">
                            <Style.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding DisplayedCandle.IsBullish}" Value="True">
                                    <Setter Property="TextColor" Value="{DynamicResource ChartBull}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding DisplayedCandle.IsBearish}" Value="True">
                                    <Setter Property="TextColor" Value="{DynamicResource ChartBear}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="VOL" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.Volume, FallbackValue='', StringFormat='{0:N0}'}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

        </HorizontalStackLayout>

        <!-- MA settings overlay: anchored top-right of the chart canvas. -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsMaSettingsOpen}"
                BackgroundColor="{DynamicResource ChartPanel}"
                Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                Padding="10"
                Margin="0,10,72,0"
                VerticalOptions="Start"
                HorizontalOptions="End"
                MinimumWidthRequest="380">
            <VerticalStackLayout Spacing="8">
                <Label Text="Moving averages" Style="{StaticResource ChartOhlcValue}" />
                <CollectionView ItemsSource="{Binding MaSeries}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MaConfig">
                            <Grid ColumnDefinitions="Auto,60,60,80,80,28"
                                  ColumnSpacing="8" Padding="0,4"
                                  HorizontalOptions="Fill">
                                <Switch Grid.Column="0" IsToggled="{Binding Enabled}" />
                                <Label Grid.Column="1" Text="{Binding Label}"
                                       Style="{StaticResource ChartOhlcValue}"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="2" Text="{Binding Period}" Keyboard="Numeric"
                                       FontSize="12" />
                                <Picker Grid.Column="3"
                                        ItemsSource="{Binding MaKinds}"
                                        SelectedItem="{Binding Kind}"
                                        FontSize="12" />
                                <Picker Grid.Column="4"
                                        ItemsSource="{Binding MaColorOptions}"
                                        SelectedItem="{Binding SelectedColorOption}"
                                        FontSize="12">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="Name" x:DataType="style:MaColorOption" />
                                    </Picker.ItemDisplayBinding>
                                </Picker>
                                <Button Grid.Column="5" Text="✕"
                                        Style="{StaticResource ChartIconButton}"
                                        Command="{Binding RemoveCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="+ Add MA"
                        Style="{StaticResource ChartLiveButton.Off}"
                        Command="{Binding AddMaCommand}" />

                <!-- Open-order line colours. Two pickers: one each for the buy
                     and sell limit lines drawn on the chart. Defaults to the
                     Bull/Bear theme colours (Binance/TradingView convention). -->
                <Label Text="Open orders" Style="{StaticResource ChartOhlcValue}" Margin="0,8,0,0" />
                <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Padding="0,2">
                    <Label Grid.Column="0" Text="Buy"
                           Style="{StaticResource ChartOhlcValue}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MaColorOptions}"
                            SelectedItem="{Binding BuyOrderColorOption}"
                            FontSize="12">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" x:DataType="style:MaColorOption" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>
                <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Padding="0,2">
                    <Label Grid.Column="0" Text="Sell"
                           Style="{StaticResource ChartOhlcValue}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MaColorOptions}"
                            SelectedItem="{Binding SellOrderColorOption}"
                            FontSize="12">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" x:DataType="style:MaColorOption" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- THE PEN TRAY: a unified pen/style panel, top-right (clones the MA-panel chrome). With no
             selection it edits the saved DEFAULT pen (TOOL row + "+ Line" footer); with a drawing
             selected it edits that drawing (Set-as-default + Delete footer). Every option is a live
             specimen of itself rather than a text label. -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsPenPanelOpen}"
                BackgroundColor="{DynamicResource ChartPanel}"
                Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                Padding="10"
                Margin="0,10,72,0"
                VerticalOptions="Start"
                HorizontalOptions="End"
                WidthRequest="340">
            <VerticalStackLayout Spacing="8">

                <!-- Header + close -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding PenPanelHeader}"
                           Style="{StaticResource ChartOhlcValue}" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="✕"
                            Style="{StaticResource ChartIconButton}"
                            Command="{Binding ClosePenPanelCommand}" />
                </Grid>

                <!-- Live preview of the exact current pen -->
                <GraphicsView Drawable="{Binding PenSpecimen}"
                              HeightRequest="34" HorizontalOptions="Fill" InputTransparent="True" />

                <!-- TOOL row (default mode only): ⊘ cursor / ─ HLine / ╱ Trend / ↗ Ray / ↦ HRay / ⋀⋁ Poly -->
                <VerticalStackLayout Spacing="4" IsVisible="{Binding IsDefaultPenMode}">
                    <Label Text="TOOL" Style="{StaticResource ChartOhlcKey}" />
                    <HorizontalStackLayout Spacing="4">
                        <Button Text="⊘" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static tools:DrawTool.None}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static tools:DrawTool.None}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="─" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static tools:DrawTool.HLine}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static tools:DrawTool.HLine}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="╱" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static tools:DrawTool.Trend}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static tools:DrawTool.Trend}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="↗" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static tools:DrawTool.Ray}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static tools:DrawTool.Ray}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="↦" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static tools:DrawTool.HRay}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static tools:DrawTool.HRay}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="/\/▸" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static tools:DrawTool.Polyline}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static tools:DrawTool.Polyline}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- COLOR (2×5 swatch grid; 18% basis = 5 per row, SpaceBetween = flush to both edges) -->
                <Label Text="COLOR" Style="{StaticResource ChartOhlcKey}" />
                <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="SpaceBetween"
                            BindableLayout.ItemsSource="{Binding PenColorTiles}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:PenColorTile">
                            <Border FlexLayout.Basis="18%" HeightRequest="22" Margin="0,2"
                                    BackgroundColor="{Binding Color}"
                                    Stroke="Transparent" StrokeThickness="2"
                                    StrokeShape="RoundRectangle 3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Command}"
                                                          CommandParameter="{Binding Color}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource White}" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- WIDTH·DASH / END·HEAD — one aligned 2×8 grid. Labels sit in col0 + col4; the six *
                     columns hold uniformly-sized, evenly-spaced image tiles that fill their column. Row 0
                     = width dots | dash lines; row 1 = ending specimens | head specimens. Each cell binds
                     its tile by index (full path from the VM) so the compiled bindings stay warning-free. -->
                <Grid ColumnDefinitions="Auto,*,*,*,Auto,*,*,*"
                      RowDefinitions="Auto,Auto" ColumnSpacing="4" RowSpacing="4">

                    <!-- Row 0: WIDTH (dots) | DASH -->
                    <Label Grid.Row="0" Grid.Column="0" Text="Width" Style="{StaticResource ChartOhlcKey}"
                           VerticalOptions="Center" Margin="0,0,4,0" />
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenWidthTiles[0].Command}"
                                                  CommandParameter="{Binding PenWidthTiles[0].Thickness}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenWidthTiles[0].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenWidthTiles[0].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenWidthTiles[1].Command}"
                                                  CommandParameter="{Binding PenWidthTiles[1].Thickness}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenWidthTiles[1].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenWidthTiles[1].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenWidthTiles[2].Command}"
                                                  CommandParameter="{Binding PenWidthTiles[2].Thickness}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenWidthTiles[2].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenWidthTiles[2].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Label Grid.Row="0" Grid.Column="4" Text="Dash" Style="{StaticResource ChartOhlcKey}"
                           VerticalOptions="Center" Margin="4,0,4,0" />
                    <Border Grid.Row="0" Grid.Column="5" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenDashTiles[0].Command}"
                                                  CommandParameter="{Binding PenDashTiles[0].Dash}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenDashTiles[0].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenDashTiles[0].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenDashTiles[1].Command}"
                                                  CommandParameter="{Binding PenDashTiles[1].Dash}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenDashTiles[1].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenDashTiles[1].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="7" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenDashTiles[2].Command}"
                                                  CommandParameter="{Binding PenDashTiles[2].Dash}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenDashTiles[2].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenDashTiles[2].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>

                    <!-- Row 1: END (ending specimens) | HEAD (head specimens) -->
                    <Label Grid.Row="1" Grid.Column="0" Text="End" Style="{StaticResource ChartOhlcKey}"
                           VerticalOptions="Center" Margin="0,0,4,0" />
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenEndingTiles[0].Command}"
                                                  CommandParameter="{Binding PenEndingTiles[0].Ending}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenEndingTiles[0].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenEndingTiles[0].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenEndingTiles[1].Command}"
                                                  CommandParameter="{Binding PenEndingTiles[1].Ending}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenEndingTiles[1].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenEndingTiles[1].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenEndingTiles[2].Command}"
                                                  CommandParameter="{Binding PenEndingTiles[2].Ending}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenEndingTiles[2].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenEndingTiles[2].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Label Grid.Row="1" Grid.Column="4" Text="Head" Style="{StaticResource ChartOhlcKey}"
                           VerticalOptions="Center" Margin="4,0,4,0" />
                    <Border Grid.Row="1" Grid.Column="5" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenHeadTiles[0].Command}"
                                                  CommandParameter="{Binding PenHeadTiles[0].Head}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenHeadTiles[0].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenHeadTiles[0].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding CanEditHead}" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                                <Setter Property="InputTransparent" Value="True" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenHeadTiles[1].Command}"
                                                  CommandParameter="{Binding PenHeadTiles[1].Head}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenHeadTiles[1].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenHeadTiles[1].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding CanEditHead}" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                                <Setter Property="InputTransparent" Value="True" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                    <Border Grid.Row="1" Grid.Column="7" Style="{StaticResource PenSpecimenTile}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PenHeadTiles[2].Command}"
                                                  CommandParameter="{Binding PenHeadTiles[2].Head}" />
                        </Border.GestureRecognizers>
                        <GraphicsView Drawable="{Binding PenHeadTiles[2].Specimen}" Style="{StaticResource PenSpecimenView}" />
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding PenHeadTiles[2].IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource White}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding CanEditHead}" Value="False">
                                <Setter Property="Opacity" Value="0.3" />
                                <Setter Property="InputTransparent" Value="True" />
                            </DataTrigger>
                        </Border.Triggers>
                    </Border>
                </Grid>

                <!-- Footer: default mode = add a line; selected mode = set-as-default + delete -->
                <Button Text="+ Line at current price"
                        IsVisible="{Binding IsDefaultPenMode}"
                        Style="{StaticResource ChartLiveButton.Off}"
                        Command="{Binding AddHLineAtCurrentCommand}" />
                <HorizontalStackLayout Spacing="6" IsVisible="{Binding HasSelectedDrawing}">
                    <Button Text="Set as default ✓"
                            Style="{StaticResource ChartLiveButton.Off}"
                            Command="{Binding SetSelectedAsDefaultCommand}" />
                    <Button Text="🗑 Delete"
                            Style="{StaticResource ChartLiveButton.Off}"
                            Command="{Binding DeleteSelectedDrawingCommand}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
    </Border>
</ContentView>
