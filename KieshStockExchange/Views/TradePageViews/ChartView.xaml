<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KieshStockExchange.Models;assembly=KieshStockExchange.Shared"
             xmlns:helpers="clr-namespace:KieshStockExchange.Services.MarketDataServices.Helpers"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.TradePageViews.ChartView"
             x:Name="ChartRoot"
             x:DataType="vm:ChartViewModel">

    <Border BackgroundColor="{DynamicResource ChartBg}"
            Stroke="{DynamicResource Divider}"
            StrokeThickness="1"
            StrokeShape="RoundRectangle 10"
            Padding="0">
    <Grid RowDefinitions="Auto,*"
          BackgroundColor="Transparent"
          MinimumHeightRequest="300">

        <!-- Toolbar -->
        <Grid Grid.Row="0" Style="{StaticResource ChartToolbar}"
              ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">

            <!-- Resolution segments -->
            <HorizontalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                <Button Text="15s"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FifteenSeconds}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FifteenSeconds}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="1m"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.OneMinute}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.OneMinute}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="5m"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FiveMinutes}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FiveMinutes}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="15m"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FifteenMinutes}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FifteenMinutes}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="1h"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.OneHour}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.OneHour}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="4h"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.FourHours}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.FourHours}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="1D"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding SelectResolutionCommand}"
                        CommandParameter="{x:Static models:CandleResolution.OneDay}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding SelectedResolution}"
                                     Value="{x:Static models:CandleResolution.OneDay}">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Chart-type toggle (cycles Candles -> Hollow -> Bars -> Line -> Area -> Heikin-Ashi) -->
                <BoxView WidthRequest="1" Color="{StaticResource ChartGrid}" Margin="4,4" VerticalOptions="Fill" />
                <Button Text="{Binding ChartStyleLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding CycleChartStyleCommand}" />

                <!-- Volume display toggle (cycles Overlay -> Pane -> Off) -->
                <Button Text="{Binding VolumeModeLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding CycleVolumeModeCommand}" />

                <!-- Market Mood (Fear/Greed) sub-pane toggle -->
                <Button Text="{Binding MoodPaneLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding ToggleMoodPaneCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding ShowMoodPane}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Order-book depth heatmap toggle -->
                <Button Text="{Binding DepthLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding ToggleDepthCommand}">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding ShowDepth}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                            <Setter Property="TextColor"       Value="{StaticResource White}" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Price-scale toggle (cycles Linear -> Log -> Percent) -->
                <Button Text="{Binding ScaleModeLabel}"
                        Style="{StaticResource ChartResolutionButton.Unselected}"
                        Command="{Binding CycleScaleModeCommand}" />

                <!-- Pen tray: a live specimen of the current pen (exact colour/width/dash/ending) + a
                     ▾; tapping toggles the pen panel. Replaces the old cycle + "+ Line" buttons. -->
                <Border Style="{StaticResource ChartPenButton}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding TogglePenPanelCommand}" />
                    </Border.GestureRecognizers>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsPenPanelOpen}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        </DataTrigger>
                    </Border.Triggers>
                    <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                        <GraphicsView Drawable="{Binding PenSpecimen}"
                                      WidthRequest="34" HeightRequest="14"
                                      VerticalOptions="Center" InputTransparent="True" />
                        <Label Text="▾" FontSize="9"
                               TextColor="{DynamicResource ChartAxis}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>

            <!-- Spacer -->
            <BoxView Grid.Column="1" Color="Transparent" />

            <!-- Y-axis auto-fit toggle -->
            <Button Grid.Column="2" Text="Autofit"
                    Style="{StaticResource ChartLiveButton.Off}"
                    Clicked="OnYAutoFitClicked">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsYAutoFit}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        <Setter Property="TextColor"       Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <!-- MA settings toggle -->
            <Button Grid.Column="3" Text="MA"
                    Style="{StaticResource ChartLiveButton.Off}"
                    Command="{Binding ToggleMaSettingsCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsMaSettingsOpen}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                        <Setter Property="TextColor"       Value="{StaticResource White}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
            <!-- Zoom out -->
            <Button Grid.Column="4" Text="−"
                    Style="{StaticResource ChartIconButton}"
                    Command="{Binding ZoomOutCommand}" />
            <!-- Zoom in -->
            <Button Grid.Column="5" Text="+"
                    Style="{StaticResource ChartIconButton}"
                    Command="{Binding ZoomInCommand}" />
            <!-- Separator -->
            <BoxView Grid.Column="6" Style="{StaticResource ChartToolbarSeparator}" />
            <!-- Live -->
            <Button Grid.Column="7" Text="LIVE"
                    Style="{StaticResource ChartLiveButton.Off}"
                    Command="{Binding GoLiveCommand}">
                <Button.Triggers>
                    <DataTrigger TargetType="Button"
                                 Binding="{Binding IsLive}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource ChartBull}" />
                        <Setter Property="TextColor"       Value="{StaticResource White}" />
                        <Setter Property="BorderColor"     Value="{StaticResource ChartBull}" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- Chart -->
        <GraphicsView x:Name="Chart" Grid.Row="1"
                      Style="{StaticResource ChartSurface}">
            <GraphicsView.GestureRecognizers>
                <PanGestureRecognizer x:Name="ChartPan" />
                <PointerGestureRecognizer x:Name="ChartPointer" />
            </GraphicsView.GestureRecognizers>
        </GraphicsView>

        <!-- OHLCV overlay: top-left of the chart canvas. InputTransparent so
             pan / wheel gestures still reach the GraphicsView underneath. -->
        <HorizontalStackLayout Grid.Row="1"
                               VerticalOptions="Start"
                               HorizontalOptions="Start"
                               Margin="14,10,0,0"
                               Spacing="14"
                               InputTransparent="True">

            <HorizontalStackLayout Spacing="4">
                <Label Text="O" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.OpenDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="H" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.HighDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="L" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.LowDisplay, FallbackValue=''}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="C" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.CloseDisplay, FallbackValue=''}">
                    <Label.Style>
                        <Style TargetType="Label" BasedOn="{StaticResource ChartOhlcValue}">
                            <Style.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding DisplayedCandle.IsBullish}" Value="True">
                                    <Setter Property="TextColor" Value="{DynamicResource ChartBull}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding DisplayedCandle.IsBearish}" Value="True">
                                    <Setter Property="TextColor" Value="{DynamicResource ChartBear}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Label.Style>
                </Label>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="4">
                <Label Text="VOL" Style="{StaticResource ChartOhlcKey}" />
                <Label Text="{Binding DisplayedCandle.Volume, FallbackValue='', StringFormat='{0:N0}'}"
                       Style="{StaticResource ChartOhlcValue}" />
            </HorizontalStackLayout>

        </HorizontalStackLayout>

        <!-- MA settings overlay: anchored top-right of the chart canvas. -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsMaSettingsOpen}"
                BackgroundColor="{DynamicResource ChartPanel}"
                Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                Padding="10"
                Margin="0,10,72,0"
                VerticalOptions="Start"
                HorizontalOptions="End"
                MinimumWidthRequest="380">
            <VerticalStackLayout Spacing="8">
                <Label Text="Moving averages" Style="{StaticResource ChartOhlcValue}" />
                <CollectionView ItemsSource="{Binding MaSeries}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MaConfig">
                            <Grid ColumnDefinitions="Auto,60,60,80,80,28"
                                  ColumnSpacing="8" Padding="0,4"
                                  HorizontalOptions="Fill">
                                <Switch Grid.Column="0" IsToggled="{Binding Enabled}" />
                                <Label Grid.Column="1" Text="{Binding Label}"
                                       Style="{StaticResource ChartOhlcValue}"
                                       VerticalOptions="Center" />
                                <Entry Grid.Column="2" Text="{Binding Period}" Keyboard="Numeric"
                                       FontSize="12" />
                                <Picker Grid.Column="3"
                                        ItemsSource="{Binding MaKinds}"
                                        SelectedItem="{Binding Kind}"
                                        FontSize="12" />
                                <Picker Grid.Column="4"
                                        ItemsSource="{Binding MaColorOptions}"
                                        SelectedItem="{Binding SelectedColorOption}"
                                        FontSize="12">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="Name" x:DataType="helpers:MaColorOption" />
                                    </Picker.ItemDisplayBinding>
                                </Picker>
                                <Button Grid.Column="5" Text="✕"
                                        Style="{StaticResource ChartIconButton}"
                                        Command="{Binding RemoveCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <Button Text="+ Add MA"
                        Style="{StaticResource ChartLiveButton.Off}"
                        Command="{Binding AddMaCommand}" />

                <!-- Open-order line colours. Two pickers: one each for the buy
                     and sell limit lines drawn on the chart. Defaults to the
                     Bull/Bear theme colours (Binance/TradingView convention). -->
                <Label Text="Open orders" Style="{StaticResource ChartOhlcValue}" Margin="0,8,0,0" />
                <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Padding="0,2">
                    <Label Grid.Column="0" Text="Buy"
                           Style="{StaticResource ChartOhlcValue}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MaColorOptions}"
                            SelectedItem="{Binding BuyOrderColorOption}"
                            FontSize="12">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" x:DataType="helpers:MaColorOption" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>
                <Grid ColumnDefinitions="80,*" ColumnSpacing="8" Padding="0,2">
                    <Label Grid.Column="0" Text="Sell"
                           Style="{StaticResource ChartOhlcValue}"
                           VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding MaColorOptions}"
                            SelectedItem="{Binding SellOrderColorOption}"
                            FontSize="12">
                        <Picker.ItemDisplayBinding>
                            <Binding Path="Name" x:DataType="helpers:MaColorOption" />
                        </Picker.ItemDisplayBinding>
                    </Picker>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- THE PEN TRAY: a unified pen/style panel, top-right (clones the MA-panel chrome). With no
             selection it edits the saved DEFAULT pen (TOOL row + "+ Line" footer); with a drawing
             selected it edits that drawing (Set-as-default + Delete footer). Every option is a live
             specimen of itself rather than a text label. -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsPenPanelOpen}"
                BackgroundColor="{DynamicResource ChartPanel}"
                Stroke="{DynamicResource ChartGrid}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 8"
                Padding="10"
                Margin="0,10,72,0"
                VerticalOptions="Start"
                HorizontalOptions="End"
                WidthRequest="300">
            <VerticalStackLayout Spacing="8">

                <!-- Header + close -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="{Binding PenPanelHeader}"
                           Style="{StaticResource ChartOhlcValue}" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="✕"
                            Style="{StaticResource ChartIconButton}"
                            Command="{Binding ClosePenPanelCommand}" />
                </Grid>

                <!-- Live preview of the exact current pen -->
                <GraphicsView Drawable="{Binding PenSpecimen}"
                              HeightRequest="34" HorizontalOptions="Fill" InputTransparent="True" />

                <!-- TOOL row (default mode only): ⊘ cursor / ─ HLine / ╱ Trend / ↗ Ray / ↦ HRay / ⋀⋁ Poly -->
                <VerticalStackLayout Spacing="4" IsVisible="{Binding IsDefaultPenMode}">
                    <Label Text="TOOL" Style="{StaticResource ChartOhlcKey}" />
                    <HorizontalStackLayout Spacing="4">
                        <Button Text="⊘" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static helpers:DrawTool.None}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static helpers:DrawTool.None}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="─" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static helpers:DrawTool.HLine}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static helpers:DrawTool.HLine}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="╱" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static helpers:DrawTool.Trend}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static helpers:DrawTool.Trend}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="↗" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static helpers:DrawTool.Ray}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static helpers:DrawTool.Ray}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="↦" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static helpers:DrawTool.HRay}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static helpers:DrawTool.HRay}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="⋀⋁" Style="{StaticResource PenToolTile}"
                                Command="{Binding SelectDrawToolCommand}"
                                CommandParameter="{x:Static helpers:DrawTool.Polyline}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding DrawTool}"
                                             Value="{x:Static helpers:DrawTool.Polyline}">
                                    <Setter Property="BackgroundColor" Value="{StaticResource ChartGrid}" />
                                    <Setter Property="BorderColor"     Value="{StaticResource White}" />
                                    <Setter Property="TextColor"       Value="{StaticResource White}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- COLOR (2×5 swatch grid) -->
                <Label Text="COLOR" Style="{StaticResource ChartOhlcKey}" />
                <FlexLayout Wrap="Wrap" Direction="Row"
                            BindableLayout.ItemsSource="{Binding PenColorTiles}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:PenColorTile">
                            <Border WidthRequest="48" HeightRequest="22" Margin="2"
                                    BackgroundColor="{Binding Color}"
                                    Stroke="Transparent" StrokeThickness="2"
                                    StrokeShape="RoundRectangle 3">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Command}"
                                                          CommandParameter="{Binding Color}" />
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource White}" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

                <!-- WIDTH + DASH (live line specimens in the current colour) -->
                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6">
                    <Label Grid.Column="0" Text="WIDTH" Style="{StaticResource ChartOhlcKey}"
                           VerticalOptions="Center" />
                    <HorizontalStackLayout Grid.Column="1" Spacing="4"
                                           BindableLayout.ItemsSource="{Binding PenWidthTiles}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PenWidthTile">
                                <Border WidthRequest="34" HeightRequest="26"
                                        Stroke="Transparent" StrokeThickness="2"
                                        StrokeShape="RoundRectangle 3"
                                        BackgroundColor="{DynamicResource ChartBg}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Command}"
                                                              CommandParameter="{Binding Thickness}" />
                                    </Border.GestureRecognizers>
                                    <GraphicsView Drawable="{Binding Specimen}"
                                                  HorizontalOptions="Fill" VerticalOptions="Fill"
                                                  InputTransparent="True" />
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource White}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                    <Label Grid.Column="2" Text="DASH" Style="{StaticResource ChartOhlcKey}"
                           VerticalOptions="Center" />
                    <HorizontalStackLayout Grid.Column="3" Spacing="4"
                                           BindableLayout.ItemsSource="{Binding PenDashTiles}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:PenDashTile">
                                <Border WidthRequest="34" HeightRequest="26"
                                        Stroke="Transparent" StrokeThickness="2"
                                        StrokeShape="RoundRectangle 3"
                                        BackgroundColor="{DynamicResource ChartBg}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Command}"
                                                              CommandParameter="{Binding Dash}" />
                                    </Border.GestureRecognizers>
                                    <GraphicsView Drawable="{Binding Specimen}"
                                                  HorizontalOptions="Fill" VerticalOptions="Fill"
                                                  InputTransparent="True" />
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource White}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </Grid>

                <!-- ENDING (5 live specimens: none / end / start / both-out / both-forward) -->
                <Label Text="ENDING" Style="{StaticResource ChartOhlcKey}" />
                <HorizontalStackLayout Spacing="4"
                                       BindableLayout.ItemsSource="{Binding PenEndingTiles}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:PenEndingTile">
                            <Border WidthRequest="46" HeightRequest="28"
                                    Stroke="Transparent" StrokeThickness="2"
                                    StrokeShape="RoundRectangle 3"
                                    BackgroundColor="{DynamicResource ChartBg}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Command}"
                                                          CommandParameter="{Binding Ending}" />
                                </Border.GestureRecognizers>
                                <GraphicsView Drawable="{Binding Specimen}"
                                              HorizontalOptions="Fill" VerticalOptions="Fill"
                                              InputTransparent="True" />
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Stroke" Value="{StaticResource White}" />
                                    </DataTrigger>
                                </Border.Triggers>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>

                <!-- Footer: default mode = add a line; selected mode = set-as-default + delete -->
                <Button Text="+ Line at current price"
                        IsVisible="{Binding IsDefaultPenMode}"
                        Style="{StaticResource ChartLiveButton.Off}"
                        Command="{Binding AddHLineAtCurrentCommand}" />
                <HorizontalStackLayout Spacing="6" IsVisible="{Binding HasSelectedDrawing}">
                    <Button Text="Set as default ✓"
                            Style="{StaticResource ChartLiveButton.Off}"
                            Command="{Binding SetSelectedAsDefaultCommand}" />
                    <Button Text="🗑 Delete"
                            Style="{StaticResource ChartLiveButton.Off}"
                            Command="{Binding DeleteSelectedDrawingCommand}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
    </Border>
</ContentView>
