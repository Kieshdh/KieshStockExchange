<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.UserViewModels"
             x:Class="KieshStockExchange.Views.UserViews.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Register">

    <Grid Style="{StaticResource AuthPageGrid}">

        <!-- Split-card centered on the page. Form column is wider than the
             art column so the 2-column field grid breathes. -->
        <Border Style="{StaticResource AuthCardOuter}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="1100">
            <Grid ColumnDefinitions="*,2*">

                <!-- LEFT: brand-coloured art panel -->
                <Border Grid.Column="0"
                        Style="{StaticResource AuthArtPanel}">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                          RowSpacing="8">
                        <Label Grid.Row="0"
                               Text="KIESH STOCK EXCHANGE"
                               FontFamily="OpenSansSemibold"
                               FontSize="11"
                               CharacterSpacing="2"
                               TextColor="{DynamicResource TextOnPrimary}"
                               Opacity="0.85" />
                        <Label Grid.Row="1"
                               Text="Join the trading floor."
                               Style="{StaticResource AuthArtHeading}" />
                        <Label Grid.Row="2"
                               Text="Create your account to start tracking, trading, and managing your portfolio."
                               Style="{StaticResource AuthArtBody}" />
                        <HorizontalStackLayout Grid.Row="4"
                                               Spacing="8"
                                               VerticalOptions="End">
                            <Image Source="kse_logo.png"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   VerticalOptions="Center" />
                            <Label Text="KSE"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{DynamicResource TextOnPrimary}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- RIGHT: form -->
                <VerticalStackLayout Grid.Column="1"
                                     Padding="40,32"
                                     Spacing="20"
                                     VerticalOptions="Center">

                    <!-- Title -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Create your account"
                               FontFamily="OpenSansSemibold"
                               FontSize="24"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Set up your trading profile."
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Field grid: 2 columns x 4 rows -->
                    <Grid RowSpacing="14"
                          ColumnSpacing="18"
                          ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Username -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="0">
                            <Label Text="Username"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding Username}"
                                   Placeholder="Enter username"
                                   Style="{StaticResource FormEntryStyle}" />
                            <Label Text="Username must be 5-20 alphanumeric characters."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsUsernameInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="0">
                            <Label Text="Email"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding Email}"
                                   Placeholder="Enter email"
                                   Style="{StaticResource FormEntryStyle}"
                                   Keyboard="Email" />
                            <Label Text="Enter a valid email."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsEmailInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="0">
                            <Label Text="Password"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding Password}"
                                   Placeholder="Enter password"
                                   IsPassword="True"
                                   Style="{StaticResource FormEntryStyle}" />
                            <Label Text="Password must be at least 8 characters."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsPasswordInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="0">
                            <Label Text="Repeat password"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding ConfirmPassword}"
                                   Placeholder="Confirm password"
                                   IsPassword="True"
                                   Style="{StaticResource FormEntryStyle}" />
                            <Label Text="Passwords do not match."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsConfirmPasswordInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- First Name -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="0">
                            <Label Text="First name"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding FirstName}"
                                   Placeholder="Enter first name"
                                   Style="{StaticResource FormEntryStyle}" />
                            <Label Text="Only letters, spaces and some punctuation allowed."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsFirstNameInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Last Name -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="0">
                            <Label Text="Last name"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding LastName}"
                                   Placeholder="Enter last name"
                                   Style="{StaticResource FormEntryStyle}" />
                            <Label Text="Only letters, spaces and some punctuation allowed."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsLastNameInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Middle Name -->
                        <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="0">
                            <Label Text="Middle name(s)"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Entry Text="{Binding MiddleName}"
                                   Placeholder="Enter middle name(s)"
                                   Style="{StaticResource FormEntryStyle}" />
                            <Label Text="Only letters, spaces and some punctuation allowed."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsMiddleNameInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>

                        <!-- Birthday (3 pickers) -->
                        <VerticalStackLayout Grid.Row="3" Grid.Column="1" Spacing="0">
                            <Label Text="Birthday"
                                   Style="{StaticResource FormLabelStyle}" />
                            <Grid ColumnSpacing="8"
                                  ColumnDefinitions="3*,4*,3*">
                                <Picker Grid.Column="0"
                                        ItemsSource="{Binding DayOptions}"
                                        SelectedItem="{Binding BirthDay, Mode=TwoWay}"
                                        Style="{StaticResource RegistrationPicker}" />
                                <Picker Grid.Column="1"
                                        ItemsSource="{Binding MonthOptions}"
                                        SelectedItem="{Binding BirthMonth, Mode=TwoWay}"
                                        Style="{StaticResource RegistrationPicker}" />
                                <Picker Grid.Column="2"
                                        ItemsSource="{Binding YearOptions}"
                                        SelectedItem="{Binding BirthYear, Mode=TwoWay}"
                                        Style="{StaticResource RegistrationPicker}" />
                            </Grid>
                            <Label Text="Select a valid birth date (18+)."
                                   Style="{StaticResource RegistrationErrorLabel}"
                                   IsVisible="{Binding IsBirthDateInvalid}"
                                   Margin="0,4,0,0" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Create account button (full-width primary) -->
                    <Button Text="Create account"
                            Command="{Binding ExecuteRegisterCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />

                    <!-- Sign in link -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4">
                        <Label Text="Have an account?"
                               Style="{StaticResource LoginPromptLabel}"
                               VerticalTextAlignment="Center" />
                        <Label Text="Sign in"
                               Style="{StaticResource LoginLinkLabelSmall}"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSignInClicked"
                                                      NumberOfTapsRequired="1" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
