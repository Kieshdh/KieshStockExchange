<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KieshStockExchange.Views.UserViews.LoginPage"
             Title="Login">

    <Grid Style="{StaticResource AuthPageGrid}">

        <!-- Split-card centered on the page. -->
        <Border Style="{StaticResource AuthCardOuter}"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="820"
                HeightRequest="500">
            <Grid ColumnDefinitions="*,*">

                <!-- LEFT: brand-coloured art panel -->
                <Border Grid.Column="0"
                        Style="{StaticResource AuthArtPanel}">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                          RowSpacing="8">
                        <Label Grid.Row="0"
                               Text="KIESH STOCK EXCHANGE"
                               FontFamily="OpenSansSemibold"
                               FontSize="11"
                               CharacterSpacing="2"
                               TextColor="{DynamicResource TextOnPrimary}"
                               Opacity="0.85" />
                        <Label Grid.Row="1"
                               Text="The trading floor, on your desktop."
                               Style="{StaticResource AuthArtHeading}" />
                        <Label Grid.Row="2"
                               Text="Live order books, limit orders, portfolio tracking. Sign in to continue."
                               Style="{StaticResource AuthArtBody}" />
                        <HorizontalStackLayout Grid.Row="4"
                                               Spacing="8"
                                               VerticalOptions="End">
                            <Image Source="kse_logo.png"
                                   HeightRequest="22"
                                   WidthRequest="22"
                                   VerticalOptions="Center" />
                            <Label Text="KSE"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{DynamicResource TextOnPrimary}"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- RIGHT: form -->
                <VerticalStackLayout Grid.Column="1"
                                     Padding="40,32"
                                     Spacing="20"
                                     VerticalOptions="Center">

                    <!-- Title -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Sign In"
                               FontFamily="OpenSansSemibold"
                               FontSize="24"
                               TextColor="{DynamicResource TextPrimary}" />
                        <Label Text="Sign in to continue"
                               FontSize="13"
                               TextColor="{DynamicResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Inputs -->
                    <VerticalStackLayout Spacing="12">
                        <!-- Username -->
                        <Border Style="{StaticResource LoginBaseBorder}">
                            <StackLayout Orientation="Horizontal">
                                <Border Style="{StaticResource LoginImageBorder}">
                                    <Image Source="user_icon.png"
                                           Style="{StaticResource LoginImage}" />
                                </Border>
                                <Entry Text="{Binding Username}"
                                       Placeholder="Username"
                                       Style="{StaticResource LoginEntry}"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="Center" />
                            </StackLayout>
                        </Border>

                        <!-- Password -->
                        <Border Style="{StaticResource LoginBaseBorder}">
                            <StackLayout Orientation="Horizontal">
                                <Border Style="{StaticResource LoginImageBorder}">
                                    <Image Source="password_icon.png"
                                           Style="{StaticResource LoginImage}" />
                                </Border>
                                <Entry Text="{Binding Password}"
                                       Placeholder="Password"
                                       IsPassword="True"
                                       Style="{StaticResource LoginEntry}"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="Center" />
                            </StackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Sign In (full-width primary) -->
                    <Button Text="Sign In"
                            Command="{Binding LoginCommand}"
                            Style="{StaticResource PrimaryActionButtonStyle}" />

                    <!-- Register link -->
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           Spacing="4">
                        <Label Text="No account?"
                               Style="{StaticResource LoginPromptLabel}"
                               VerticalTextAlignment="Center" />
                        <Label Text="Register"
                               Style="{StaticResource LoginLinkLabelSmall}"
                               VerticalTextAlignment="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegisterClicked"
                                                      NumberOfTapsRequired="1" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
