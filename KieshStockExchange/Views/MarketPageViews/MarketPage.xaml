<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.MarketViewModels"
             xmlns:helpers="clr-namespace:KieshStockExchange.Services.MarketDataServices.Helpers"
             xmlns:navbar="clr-namespace:KieshStockExchange.Views.OtherViews"
             x:Class="KieshStockExchange.Views.MarketPageViews.MarketPage"
             x:Name="MarketPageRoot"
             x:DataType="vm:MarketViewModel"
             Title="Market">

    <Grid Style="{StaticResource MainGrid}"
          RowDefinitions="Auto,Auto,Auto,*"
          RowSpacing="8"
          Padding="0,0,0,8">

        <!-- Top nav -->
        <navbar:TopNavBarView Grid.Row="0"
                              BindingContext="{Binding TopNavBarVm}" />

        <!-- Toast overlay (top-right of content area; passes clicks through empty space) -->
        <navbar:ToastHostView Grid.Row="1" Grid.RowSpan="5"
                              VerticalOptions="Start" HorizontalOptions="End"
                              Margin="0,8,16,0"
                              ZIndex="200" />

        <!-- ============== MY WATCHLIST CARD ============== -->
        <Border Grid.Row="1"
                Style="{StaticResource DashboardCardStyle}"
                Padding="0"
                Margin="24,0,24,0"
                IsVisible="{Binding HasWatchlist}">
            <Grid RowDefinitions="Auto,Auto,*">
                <Label Grid.Row="0"
                       Text="My Watchlist"
                       Style="{StaticResource SectionHeaderLabelStyle}"
                       Padding="16,14,16,8" />

                <Grid Grid.Row="1"
                      Style="{StaticResource TableHeaderGridStyle}"
                      ColumnDefinitions="*,*,*,Auto,Auto,Auto,Auto"
                      ColumnSpacing="8"
                      Padding="16,8">
                    <Label Grid.Column="0" Text="SYMBOL" Style="{StaticResource TableHeaderLabelStyle}" HorizontalTextAlignment="Start" />
                    <Label Grid.Column="1" Text="LAST"   Style="{StaticResource TableHeaderLabelStyle}" HorizontalTextAlignment="End" />
                    <Label Grid.Column="2" Text="CHANGE" Style="{StaticResource TableHeaderLabelStyle}" HorizontalTextAlignment="End" />
                    <Label Grid.Column="3" Text=""       Style="{StaticResource TableHeaderLabelStyle}" WidthRequest="36" />
                    <Label Grid.Column="4" Text=""       Style="{StaticResource TableHeaderLabelStyle}" WidthRequest="36" />
                    <Label Grid.Column="5" Text=""       Style="{StaticResource TableHeaderLabelStyle}" WidthRequest="64" />
                    <Label Grid.Column="6" Text=""       Style="{StaticResource TableHeaderLabelStyle}" WidthRequest="28" />
                </Grid>

                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding Watchlist}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MarketRow">
                            <Grid ColumnDefinitions="*,*,*,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="8"
                                  Padding="16,6">
                                <Label Grid.Column="0"
                                       Text="{Binding Symbol}"
                                       Style="{StaticResource TradeTableSymbolLabel}"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding LastPriceDisplay}"
                                       Style="{StaticResource TradeTableRowLabel}"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center" />
                                <Label Grid.Column="2"
                                       Text="{Binding ChangePctDisplay}"
                                       HorizontalTextAlignment="End"
                                       VerticalTextAlignment="Center">
                                    <Label.Style>
                                        <Style TargetType="Label" BasedOn="{StaticResource TradeTableRowLabel}">
                                            <Style.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsBullish}" Value="True">
                                                    <Setter Property="TextColor" Value="{DynamicResource BuyGreen}" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsBearish}" Value="True">
                                                    <Setter Property="TextColor" Value="{DynamicResource SellRed}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                                <Button Grid.Column="3"
                                        Text="&#x25B2;"
                                        Style="{StaticResource WatchStarButton}"
                                        WidthRequest="32"
                                        FontSize="12"
                                        Command="{Binding Source={x:Reference MarketPageRoot}, Path=BindingContext.MoveWatchUpCommand, x:DataType=vm:MarketViewModel}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="4"
                                        Text="&#x25BC;"
                                        Style="{StaticResource WatchStarButton}"
                                        WidthRequest="32"
                                        FontSize="12"
                                        Command="{Binding Source={x:Reference MarketPageRoot}, Path=BindingContext.MoveWatchDownCommand, x:DataType=vm:MarketViewModel}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="5"
                                        Text="Trade"
                                        Style="{StaticResource TableActionButton}"
                                        Command="{Binding TradeCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Grid.Column="6"
                                        Text="&#x2605;"
                                        Style="{StaticResource WatchStarButton}"
                                        TextColor="{DynamicResource BuyGreen}"
                                        Command="{Binding ToggleWatchCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- ============== TOP STRIP: Top Gainers + Top Losers ============== -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              Padding="24,0,24,0">

            <!-- Top Gainers card -->
            <Border Grid.Column="0"
                    Style="{StaticResource DashboardCardStyle}"
                    Padding="0">
                <VerticalStackLayout>
                    <Label Text="Top Gainers"
                           Style="{StaticResource SectionHeaderLabelStyle}"
                           Padding="16,14,16,8" />
                    <CollectionView ItemsSource="{Binding Trending.TopGainers}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No movers yet."
                                   Style="{StaticResource MutedLabelStyle}"
                                   Padding="16,8" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="helpers:MoverRow">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Padding="16,8"
                                      ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Symbol}"
                                           Style="{StaticResource TradeTableSymbolLabel}"
                                           HorizontalTextAlignment="Start"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding LastPriceDisplay}"
                                           Style="{StaticResource TradeTableRowLabel}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding ChangePctDisplay}"
                                           Style="{StaticResource PositiveValueLabelStyle}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center"
                                           MinimumWidthRequest="64" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Top Losers card -->
            <Border Grid.Column="1"
                    Style="{StaticResource DashboardCardStyle}"
                    Padding="0">
                <VerticalStackLayout>
                    <Label Text="Top Losers"
                           Style="{StaticResource SectionHeaderLabelStyle}"
                           Padding="16,14,16,8" />
                    <CollectionView ItemsSource="{Binding Trending.TopLosers}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Label Text="No movers yet."
                                   Style="{StaticResource MutedLabelStyle}"
                                   Padding="16,8" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="helpers:MoverRow">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Padding="16,8"
                                      ColumnSpacing="8">
                                    <Label Grid.Column="0"
                                           Text="{Binding Symbol}"
                                           Style="{StaticResource TradeTableSymbolLabel}"
                                           HorizontalTextAlignment="Start"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="1"
                                           Text="{Binding LastPriceDisplay}"
                                           Style="{StaticResource TradeTableRowLabel}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding ChangePctDisplay}"
                                           Style="{StaticResource NegativeValueLabelStyle}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center"
                                           MinimumWidthRequest="64" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ============== BOTTOM: All Stocks ============== -->
        <Border Grid.Row="3"
                Style="{StaticResource DashboardCardStyle}"
                Padding="0"
                Margin="24,0,24,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Card head: title + currency tab strip + search + refresh -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto,Auto,Auto"
                      ColumnSpacing="8"
                      Padding="16,14,16,12">
                    <Label Grid.Column="0"
                           Text="All Stocks"
                           Style="{StaticResource SectionHeaderLabelStyle}"
                           VerticalTextAlignment="Center" />
                    <!-- USD / EUR / All currency tabs -->
                    <Border Grid.Column="1"
                            Style="{StaticResource SegmentedPillContainerStyle}">
                        <HorizontalStackLayout Spacing="0">
                            <Button Text="USD"
                                    Command="{Binding SelectCurrencyTabCommand}"
                                    CommandParameter="USD">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UnselectedSegmentButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsUsdTabActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource SelectedTabBg}" />
                                                <Setter Property="TextColor"       Value="{DynamicResource SelectedTabFg}" />
                                                <Setter Property="BorderColor"     Value="{DynamicResource Divider}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Text="EUR"
                                    Command="{Binding SelectCurrencyTabCommand}"
                                    CommandParameter="EUR">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UnselectedSegmentButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsEurTabActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource SelectedTabBg}" />
                                                <Setter Property="TextColor"       Value="{DynamicResource SelectedTabFg}" />
                                                <Setter Property="BorderColor"     Value="{DynamicResource Divider}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Text="&#x2605;"
                                    Command="{Binding SelectCurrencyTabCommand}"
                                    CommandParameter="Watchlist">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource UnselectedSegmentButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsWatchlistTabActive}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{DynamicResource SelectedTabBg}" />
                                                <Setter Property="TextColor"       Value="{DynamicResource SelectedTabFg}" />
                                                <Setter Property="BorderColor"     Value="{DynamicResource Divider}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </HorizontalStackLayout>
                    </Border>
                    <Entry Grid.Column="2"
                           Text="{Binding SearchText}"
                           Placeholder="Search symbol..."
                           Style="{StaticResource FormEntryStyle}"
                           WidthRequest="180" />
                    <Button Grid.Column="3"
                            Text="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            HeightRequest="36"
                            WidthRequest="84"
                            FontSize="12" />
                </Grid>

                <!-- Column headers -->
                <Grid Grid.Row="1"
                      Style="{StaticResource TableHeaderGridStyle}"
                      ColumnDefinitions="Auto,*,2*,*,*,*,Auto"
                      ColumnSpacing="8"
                      Padding="16,8">
                    <Label Grid.Column="0"
                           Text=""
                           Style="{StaticResource TableHeaderLabelStyle}"
                           WidthRequest="28" />
                    <Label Grid.Column="1"
                           Text="SYMBOL"
                           Style="{StaticResource TableHeaderLabelStyle}"
                           HorizontalTextAlignment="Start" />
                    <Label Grid.Column="2"
                           Text="NAME"
                           Style="{StaticResource TableHeaderLabelStyle}"
                           HorizontalTextAlignment="Start" />
                    <Label Grid.Column="3"
                           Text="LAST"
                           Style="{StaticResource TableHeaderLabelStyle}"
                           HorizontalTextAlignment="End" />
                    <Label Grid.Column="4"
                           Text="CHANGE"
                           Style="{StaticResource TableHeaderLabelStyle}"
                           HorizontalTextAlignment="End" />
                    <Label Grid.Column="5"
                           Text="VOLUME"
                           Style="{StaticResource TableHeaderLabelStyle}"
                           HorizontalTextAlignment="End" />
                    <Label Grid.Column="6"
                           Text=""
                           Style="{StaticResource TableHeaderLabelStyle}"
                           WidthRequest="64" />
                </Grid>

                <!-- Rows -->
                <RefreshView Grid.Row="2"
                             Command="{Binding RefreshCommand}"
                             IsRefreshing="{Binding IsBusy}">
                    <CollectionView ItemsSource="{Binding PagedStocks}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <StackLayout Padding="16">
                                <Label Text="No stocks to show."
                                       Style="{StaticResource MutedLabelStyle}"
                                       HorizontalOptions="Center" />
                            </StackLayout>
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:MarketRow">
                                <Grid ColumnDefinitions="Auto,*,2*,*,*,*,Auto"
                                      ColumnSpacing="8"
                                      Padding="16,8">

                                    <!-- Star toggle: ★ when watched, ☆ otherwise. Swap via DataTrigger. -->
                                    <Button Grid.Column="0"
                                            Command="{Binding ToggleWatchCommand}"
                                            CommandParameter="{Binding .}"
                                            Style="{StaticResource WatchStarButton}">
                                        <Button.Triggers>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsWatched}" Value="True">
                                                <Setter Property="Text"      Value="&#x2605;" />
                                                <Setter Property="TextColor" Value="{DynamicResource BuyGreen}" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Button" Binding="{Binding IsWatched}" Value="False">
                                                <Setter Property="Text"      Value="&#x2606;" />
                                                <Setter Property="TextColor" Value="{DynamicResource TextMuted}" />
                                            </DataTrigger>
                                        </Button.Triggers>
                                    </Button>

                                    <Label Grid.Column="1"
                                           Text="{Binding Symbol}"
                                           Style="{StaticResource TradeTableSymbolLabel}"
                                           HorizontalTextAlignment="Start"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="2"
                                           Text="{Binding CompanyName}"
                                           Style="{StaticResource TradeTableRowLabel}"
                                           HorizontalTextAlignment="Start"
                                           VerticalTextAlignment="Center" />
                                    <Label Grid.Column="3"
                                           Text="{Binding LastPriceDisplay}"
                                           Style="{StaticResource TradeTableRowLabel}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center" />

                                    <!-- Daily change: green when bullish, red when bearish, default otherwise -->
                                    <Label Grid.Column="4"
                                           Text="{Binding ChangePctDisplay}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center">
                                        <Label.Style>
                                            <Style TargetType="Label" BasedOn="{StaticResource TradeTableRowLabel}">
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsBullish}" Value="True">
                                                        <Setter Property="TextColor" Value="{DynamicResource BuyGreen}" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsBearish}" Value="True">
                                                        <Setter Property="TextColor" Value="{DynamicResource SellRed}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Label.Style>
                                    </Label>

                                    <!-- Daily dollar volume (sum of price*shares for the session) -->
                                    <Label Grid.Column="5"
                                           Text="{Binding DollarVolumeDisplay}"
                                           Style="{StaticResource TradeTableRowLabel}"
                                           HorizontalTextAlignment="End"
                                           VerticalTextAlignment="Center" />

                                    <Button Grid.Column="6"
                                            Text="Trade"
                                            Style="{StaticResource TableActionButton}"
                                            HorizontalOptions="End"
                                            Command="{Binding TradeCommand}"
                                            CommandParameter="{Binding .}" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>

                <!-- Pager: prev / "page X / N" / next. -->
                <Grid Grid.Row="3"
                      ColumnDefinitions="Auto,*,Auto"
                      Padding="16,8"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="Prev"
                            Command="{Binding PrevPageCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            HeightRequest="32"
                            WidthRequest="72"
                            FontSize="12" />
                    <Label Grid.Column="1"
                           Text="{Binding PageDisplay}"
                           Style="{StaticResource MutedLabelStyle}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Button Grid.Column="2"
                            Text="Next"
                            Command="{Binding NextPageCommand}"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            HeightRequest="32"
                            WidthRequest="72"
                            FontSize="12" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
