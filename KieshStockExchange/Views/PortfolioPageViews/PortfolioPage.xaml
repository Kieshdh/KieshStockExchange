<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:navbar="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:other="clr-namespace:KieshStockExchange.Views.OtherViews"
             xmlns:views="clr-namespace:KieshStockExchange.Views.PortfolioPageViews"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.PortfolioViewModels"
             x:Class="KieshStockExchange.Views.PortfolioPageViews.PortfolioPage"
             x:Name="PortfolioPageRoot"
             x:DataType="vm:PortfolioViewModel"
             Title="Portfolio">

    <Grid Style="{StaticResource MainGrid}"
          RowDefinitions="Auto,Auto,*"
          RowSpacing="8"
          Padding="0,0,0,8">

        <!-- Top nav -->
        <navbar:TopNavBarView Grid.Row="0"
                              BindingContext="{Binding TopNavBarVm}" />

        <!-- Toast overlay (top-right of content area; passes clicks through empty space) -->
        <other:ToastHostView Grid.Row="1" Grid.RowSpan="5"
                             VerticalOptions="Start" HorizontalOptions="End"
                             Margin="0,8,16,0"
                             ZIndex="200" />

        <!-- KPI cards row: Equity, Cash, All-time P/L, Allocation (2x wide) -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*,*,2*"
              ColumnSpacing="12"
              Padding="24,0,24,0">

            <!-- Total Equity (with today's change + % on the sub-line) -->
            <Border Grid.Column="0"
                    Style="{StaticResource DashboardCardStyle}"
                    Padding="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Total Equity"
                           Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding TotalEquityDisplay}"
                           Style="{StaticResource QuotePriceLabel}" />
                    <Label Text="{Binding TotalEquityChangeDisplay}"
                           Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <!-- Available Cash -->
            <Border Grid.Column="1"
                    Style="{StaticResource DashboardCardStyle}"
                    Padding="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Available Cash"
                           Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding CashDisplay}"
                           Style="{StaticResource QuotePriceLabel}" />
                    <Label Text="{Binding PositionCountDisplay}"
                           Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <!-- All-time P/L -->
            <Border Grid.Column="2"
                    Style="{StaticResource DashboardCardStyle}"
                    Padding="20">
                <VerticalStackLayout Spacing="6">
                    <Label Text="All-time P/L"
                           Style="{StaticResource MutedLabelStyle}" />
                    <Label Text="{Binding AllTimePlDisplay}"
                           Style="{StaticResource QuotePriceLabel}" />
                    <Label Text="{Binding AllTimePlSubDisplay}"
                           Style="{StaticResource MutedLabelStyle}" />
                </VerticalStackLayout>
            </Border>

            <!-- Allocation donut + legend (2x card width) -->
            <Border Grid.Column="3"
                    Style="{StaticResource DashboardCardStyle}"
                    Padding="16">
                <Grid ColumnDefinitions="140,*" ColumnSpacing="12">
                    <GraphicsView x:Name="AllocationPie"
                                  Grid.Column="0"
                                  HeightRequest="140"
                                  WidthRequest="140" />

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Start">
                        <Label Text="Allocation"
                               Style="{StaticResource MutedLabelStyle}" />
                        <CollectionView ItemsSource="{Binding AllocationSlices}"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:PortfolioAllocationSlice">
                                    <Grid ColumnDefinitions="14,*,Auto" ColumnSpacing="6" Padding="0,1">
                                        <BoxView Grid.Column="0"
                                                 WidthRequest="10" HeightRequest="10"
                                                 CornerRadius="2"
                                                 VerticalOptions="Center"
                                                 BackgroundColor="{Binding Color}" />
                                        <Label Grid.Column="1"
                                               Text="{Binding Label}"
                                               FontSize="11"
                                               VerticalTextAlignment="Center"
                                               LineBreakMode="TailTruncation" />
                                        <Label Grid.Column="2"
                                               Text="{Binding ShareDisplay}"
                                               Style="{StaticResource MutedLabelStyle}"
                                               FontSize="11"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Grid>
            </Border>

        </Grid>

        <!-- Tabbed table area -->
        <Grid Grid.Row="2" Margin="24,0,24,0">
        <Border Style="{StaticResource TradeContentOutline}"
                Padding="0">
            <other:SegmentedTabView
                    HeaderContainerHorizontalOptions="Start"
                    ContainerStyle="{StaticResource SegmentedRailContainer}"
                    SelectedButtonStyle="{StaticResource RailSegmentSelected}"
                    UnselectedButtonStyle="{StaticResource RailSegmentUnselected}"
                    ShowUnderline="True">

                <other:SegmentedTabView.Tabs>

                    <!-- Tab BindingContexts wired in code-behind. -->
                    <other:SegmentedTabItem Header="Currencies">
                        <other:SegmentedTabItem.Content>
                            <views:PortfolioCurrenciesView x:Name="CurrenciesTab" />
                        </other:SegmentedTabItem.Content>
                    </other:SegmentedTabItem>

                    <other:SegmentedTabItem Header="Holdings">
                        <other:SegmentedTabItem.Content>
                            <views:PortfolioHoldingsView x:Name="HoldingsTab" />
                        </other:SegmentedTabItem.Content>
                    </other:SegmentedTabItem>

                    <other:SegmentedTabItem Header="Open Orders">
                        <other:SegmentedTabItem.Content>
                            <views:PortfolioOpenOrdersView x:Name="OpenOrdersTab" />
                        </other:SegmentedTabItem.Content>
                    </other:SegmentedTabItem>

                    <other:SegmentedTabItem Header="Order History">
                        <other:SegmentedTabItem.Content>
                            <views:PortfolioOrderHistoryView x:Name="OrderHistoryTab" />
                        </other:SegmentedTabItem.Content>
                    </other:SegmentedTabItem>

                    <other:SegmentedTabItem Header="Transactions">
                        <other:SegmentedTabItem.Content>
                            <views:PortfolioTransactionHistoryView x:Name="TransactionsTab" />
                        </other:SegmentedTabItem.Content>
                    </other:SegmentedTabItem>

                    <other:SegmentedTabItem Header="Funds History">
                        <other:SegmentedTabItem.Content>
                            <views:PortfolioFundsHistoryView x:Name="FundsHistoryTab" />
                        </other:SegmentedTabItem.Content>
                    </other:SegmentedTabItem>

                </other:SegmentedTabView.Tabs>
            </other:SegmentedTabView>
        </Border>

        <!-- Loading overlay: a small spinner anchored top-right while a refresh is in flight -->
        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="End"
                           VerticalOptions="Start"
                           Margin="0,12,16,0"
                           WidthRequest="20"
                           HeightRequest="20" />
        </Grid>

    </Grid>
</ContentPage>
