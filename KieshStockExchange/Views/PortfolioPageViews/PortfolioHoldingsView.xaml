<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tradeVm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             x:Class="KieshStockExchange.Views.PortfolioPageViews.PortfolioHoldingsView"
             x:Name="PortfolioHoldingsRoot">

    <VerticalStackLayout Style="{StaticResource TradeTableContainer}">

        <!-- Table headers -->
        <Grid ColumnDefinitions="*,*,*,*,*,*,*"
              Style="{StaticResource TradeTableHeaderGrid}">
            <Label Grid.Column="0" Text="Symbol"    Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="1" Text="Price"     Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="2" Text="Amount"    Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="3" Text="Reserved"  Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="4" Text="Available" Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="5" Text="Total"     Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="6" Text="Action"    Style="{StaticResource TradeTableHeaderLabel}" />
        </Grid>

        <!-- Rows -->
        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding CurrentView}"
                            SelectionMode="None" Margin="0,4,0,0">
                <CollectionView.EmptyView>
                    <StackLayout Padding="12" Spacing="4">
                        <Label Text="No open positions" Opacity="0.7" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="tradeVm:PositionRow">
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*"
                              Style="{StaticResource TradeTableRowGrid}">
                            <Label Grid.Column="0" Text="{Binding Symbol}"    Style="{StaticResource TradeTableSymbolLabel}" />
                            <Label Grid.Column="1" Text="{Binding Price}"     Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="2" Text="{Binding Qty}"       Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="3" Text="{Binding Reserved}"  Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="4" Text="{Binding Available}" Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="5" Text="{Binding Total}"     Style="{StaticResource TradeTableRowLabel}" />

                            <Button Grid.Column="6" Text="Trade"
                                    Style="{StaticResource TableActionButton}"
                                    Command="{Binding Source={x:Reference PortfolioHoldingsRoot}, Path=BindingContext.TradeCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </VerticalStackLayout>
</ContentView>
