<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:adminViews="clr-namespace:KieshStockExchange.Views.AdminPageViews.Tables"
             xmlns:tradeVm="clr-namespace:KieshStockExchange.ViewModels.TradeViewModels"
             xmlns:vm="clr-namespace:KieshStockExchange.ViewModels.PortfolioViewModels"
             x:Class="KieshStockExchange.Views.PortfolioPageViews.PortfolioHoldingsView"
             x:Name="PortfolioHoldingsRoot"
             x:DataType="vm:PortfolioHoldingsViewModel">

    <VerticalStackLayout Style="{StaticResource TradeTableContainer}">

        <!-- Table headers -->
        <Grid ColumnDefinitions="*,*,*,*,*,*,120,*"
              Style="{StaticResource TradeTableHeaderGrid}">
            <Label Grid.Column="0" Text="Symbol"    Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="1" Text="Price"     Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="2" Text="Amount"    Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="3" Text="Reserved"  Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="4" Text="Available" Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="5" Text="Total"     Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="6" Text="Share"     Style="{StaticResource TradeTableHeaderLabel}" />
            <Label Grid.Column="7" Text="Action"    Style="{StaticResource TradeTableHeaderLabel}" />
        </Grid>

        <!-- Rows -->
        <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Pager.PagedItems}"
                            SelectionMode="None" Margin="0,4,0,0">
                <CollectionView.EmptyView>
                    <StackLayout Padding="12" Spacing="4">
                        <Label Text="No open positions" Opacity="0.7" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="tradeVm:PositionRow">
                        <Grid ColumnDefinitions="*,*,*,*,*,*,120,*"
                              Style="{StaticResource TradeTableRowGrid}">
                            <Label Grid.Column="0" Text="{Binding Symbol}"    Style="{StaticResource TradeTableSymbolLabel}" />
                            <Label Grid.Column="1" Text="{Binding Price}"     Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="2" Text="{Binding Qty}"       Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="3" Text="{Binding Reserved}"  Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="4" Text="{Binding Available}" Style="{StaticResource TradeTableRowLabel}" />
                            <Label Grid.Column="5" Text="{Binding Total}"     Style="{StaticResource TradeTableRowLabel}" />

                            <Grid Grid.Column="6" VerticalOptions="Center" Padding="8,0">
                                <BoxView HeightRequest="6" CornerRadius="3"
                                         BackgroundColor="{DynamicResource CardSurfaceMuted}"
                                         HorizontalOptions="Fill" />
                                <BoxView HeightRequest="6" CornerRadius="3"
                                         BackgroundColor="{DynamicResource BuyGreen}"
                                         HorizontalOptions="Start"
                                         WidthRequest="{Binding DepthRatio,
                                             Converter={StaticResource DepthRatioToWidthConverter},
                                             ConverterParameter=104}" />
                            </Grid>

                            <Button Grid.Column="7" Text="Trade"
                                    Style="{StaticResource TableActionButton}"
                                    Command="{Binding TradeCommand}"
                                    CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <adminViews:TablePagerView
            IsVisible="{Binding Pager.HasMultiplePages}"
            CurrentPage="{Binding Pager.CurrentPageDisplay}"
            TotalPages="{Binding Pager.TotalPages}"
            PageSize="{Binding Pager.PageSize, Mode=TwoWay}"
            AvailablePageSizes="{Binding Pager.AvailablePageSizes}"
            VisiblePages="{Binding Pager.VisiblePages}"
            CanGoPrev="{Binding Pager.CanGoPrev}"
            CanGoNext="{Binding Pager.CanGoNext}"
            GoToPageCommand="{Binding Pager.GoToPageCommand}"
            GoPrevCommand="{Binding Pager.GoPrevCommand}"
            GoNextCommand="{Binding Pager.GoNextCommand}"
            PagerSummary="{Binding Pager.PagerSummary}" />
    </VerticalStackLayout>
</ContentView>
