# 7d/7e — copy to .env.production (gitignored) and fill in real values.
# docker compose reads this via: docker compose --env-file .env.production up -d

# Postgres credentials (compose creates the DB with these on first run).
POSTGRES_DB=kse
POSTGRES_USER=kse
POSTGRES_PASSWORD=change-me-32-byte-random

# Connection string the server uses (must match the Postgres creds above).
KSE_DB_CONNECTION_STRING=Host=postgres;Port=5432;Database=kse;Username=kse;Password=change-me-32-byte-random

# JWT signing key — generate with: openssl rand -hex 32
KSE_AUTH_SIGNING_KEY=change-me-openssl-rand-hex-32

# Allowed CORS origin (your client domain). Native MAUI HttpClient doesn't send
# Origin, so this only matters if a browser client is ever added.
KSE_ALLOWED_ORIGIN=https://exchange.example.com

# Public domain Caddy fetches a cert for and serves.
DOMAIN=exchange.example.com
